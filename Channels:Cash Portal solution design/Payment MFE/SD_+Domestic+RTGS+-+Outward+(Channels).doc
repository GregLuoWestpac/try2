splay/~M062280" data-linked-resource-id=3D"1296375477" data-linked-resource=
-version=3D"2" data-linked-resource-type=3D"userinfo" data-base-url=3D"http=
s://confluence.srv.westpac.com.au">Tejas Koteswara Rao</a>&nbsp;<br><a clas=
s=3D"confluence-userlink user-mention" data-username=3D"M064401" href=3D"/d=
isplay/~M064401" data-linked-resource-id=3D"1309836187" data-linked-resourc=
e-version=3D"2" data-linked-resource-type=3D"userinfo" data-base-url=3D"htt=
ps://confluence.srv.westpac.com.au">Bobby Joseph</a>&nbsp;</p>
</div></td>
<td style=3D"text-align: left;vertical-align: top;" class=3D"confluenceTd">=
Closed</td>
</tr>
<tr>
<td style=3D"text-align: left;vertical-align: top;" class=3D"confluenceTd">=
#006</td>
<td class=3D"confluenceTd"><p>RTGS Error response codes</p></td>
