    if(entities.approvalWorkflowList[i].payloadObject.creditTransferTransac=
tionInformation[0].paymentTypeInformation.serviceLevel.contains("npp.clear.=
01-x2p1") then
    {
        Display "Osko"
    }
=20
    if(entities.approvalWorkflowList[i].payloadObject.creditTransferTransac=
tionInformation[0].paymentTypeInformation.serviceLevel.contains("npp.clear.=
01-sct")
       || (entities.approvalWorkflowList[i].payloadObject.creditTransferTra=
nsactionInformation[0].paymentTypeInformation.serviceLevel is undefined ) t=
hen
    {
        Display "Fast Payment"
    }
=20
    if(entities.approvalWorkflowList[i].payloadObject.creditTransferTransac=
tionInformation[0].paymentTypeInformation.serviceLevel =3D=3D=3D "NURG") th=
en
    {
        Display "Direct Entry(DE) or as per the UX"
    }
}</pre>
</div>
</div>
</div></td>
</tr>
