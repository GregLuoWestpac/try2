: js; gutter: false; theme: Confluence; collapse: true" data-theme=3D"Confl=
uence">//When calling DSR CAP API to search for maker or checker workflow r=
equests, Exp API will have to fetch the required UserID from either x-useri=
d request header or from x-access-token request header and then pass the re=
quired userid accordingly
=20
if(request.searchBy =3D=3D=3D "createdByUserId")
{
   var createdByUserId =3D apiHeaders['x-userId'] //or read userId from api=
Headers['x-access-token']
   // Map the above createdByUserId to DSR request.createdByUserId when cal=
ling DSR CAP API to search for maker workflow requests
}


