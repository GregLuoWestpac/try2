ht">{
  "searchBy": "approver",
  "approverStatus": [
    "ApprovalPending",
 &nbsp; &nbsp;"Rejected"=20
&nbsp; &nbsp;],
  &nbsp;"workflowStatus": [
        "ApprovalPending",
        "Rejected"
    ],
&nbsp; "types": [
    "w1cbeneficiary"
  ],
  "subTypes": [
    "addbeneficiary",
    "amendbeneficiary",
    "archivebeneficiary"
  ],
   "requestGroup": "Customer",
   "approvalChannel": "W1C-Customer"
}</pre>
