<pre style=3D"font-size: 12px;">openapi: 3.0.3

###########################################################################=
#####
#                       API Information                                    =
    #
###########################################################################=
#####
info:
  title: Payee Address Book
  contact:
    url: "https://mesh.westpac.com.au/components/apis/inf-bnkng-arrngmnt-ch=
nlaccsarrngmnt-instl-payee-v1"
  description: |
    This INF API interacts with the inf-bnkng-arrngmnt-chnlaccsarrngmnt-ins=
tl-payee-v1. Following operations are allowed:
    1. Get Payees by Group Id
    2. Create Group with Payees
  version: 1.0.0
  x-baseTypesVersion: 0.12.0 # The version of the base type on which the sp=
ec is based

servers:
  - url: "/inf/bnkng/arrngmnt/chnlaccsarrngmnt/instl/payee/v1"

security:
  - BasicAuth: []

tags:
  - name: Get Payees by Group Id
  - name: Create Payee
  - name: HealthCheck

###########################################################################=
#####
#                                   Paths                                 #
###########################################################################=
#####
paths:
  /healthcheck:
    get:
      tags:
        - HealthCheck
      description: retrieves HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        "200":
          $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/responses/200healthCheckStatusResponse"

  /groups/{id}/payees:
    get:
      tags:
        - Get Payees by Group Id
      description: &gt;
        Retrieve all the payees in a specific group
      operationId: getPayees
      parameters:
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userIdScheme"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-originatingBSB"
        - $ref: "#/components/parameters/id"

      responses:
        "200":
          $ref: "#/components/responses/200GetPayeesResponse"
        "400":
          $ref: "#/components/responses/400GetPayeesErrorResponse"
        "500":
          $ref: "#/components/responses/500ErrorResponse"

    post:
      tags:
        - Create Payee
      description: Create a new group with Payees
      operationId: createPayees
      parameters:
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userIdScheme"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-originatingBSB"
        - $ref: "#/components/parameters/id"
      requestBody:
        description: List of Payees to be added to the group
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreatePayeesRequest"
      responses:
        "200":
          $ref: "#/components/responses/201CreatePayeesResponse"
        "400":
          $ref: "#/components/responses/400CreatePayeesErrorResponse"
        "500":
          $ref: "#/components/responses/500ErrorResponse"

components:
  #########################################################################=
#######
  #                                   Parameters                           =
      #
  #########################################################################=
#######
  parameters:
    id:
      name: id
      in: path
      description: Unique identifier of the payee group.
      required: true
      schema:
        type: string
        pattern: ^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$

  #########################################################################=
#######
  #                           Responses                                    =
      #
  #########################################################################=
#######
  #Success Responses
  responses:
    200GetPayeesResponse:
      description: |
        __OK__

      content:
        application/json:
          schema:
            $ref: "#/components/schemas/GetPayeesResponse"

    201CreatePayeesResponse:
      description: Created
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/CreatePayeesResponse"

    # Client Error Responses
    400GetPayeesErrorResponse:
      description: |
        __Bad Request__

          Possible errors:
          &lt;table&gt;
            &lt;tr&gt;
              &lt;td&gt;Error Code&lt;/td&gt;
              &lt;td&gt;Error Message&lt;/td&gt;
              &lt;td&gt;Error Description&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1001&lt;/td&gt;
              &lt;td&gt;Missing request parameter&lt;/td&gt;
              &lt;td&gt;The [{parameterName}] is missing in the request.&lt=
;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1002&lt;/td&gt;
              &lt;td&gt;Invalid request parameter&lt;/td&gt;
              &lt;td&gt;The given [{parameterName}] has invalid value of [{=
parameterValue}].&lt;/td&gt;
            &lt;/tr&gt;
          &lt;table&gt;
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorResponse"
          example:
            result:
              errors:
                - code: 1001
                  message: Missing request parameter
                  details: The [id] is missing in the request.

    400CreatePayeesErrorResponse:
      description: |
        __Bad Request__

          Possible errors:
          &lt;table&gt;
            &lt;tr&gt;
              &lt;td&gt;Error Code&lt;/td&gt;
              &lt;td&gt;Error Message&lt;/td&gt;
              &lt;td&gt;Error Description&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1001&lt;/td&gt;
              &lt;td&gt;Missing request parameter&lt;/td&gt;
              &lt;td&gt;The [{parameterName}] is missing in the request.&lt=
;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1002&lt;/td&gt;
              &lt;td&gt;Invalid request parameter&lt;/td&gt;
              &lt;td&gt;The given [{parameterName}] has invalid value of [{=
parameterValue}].&lt;/td&gt;
            &lt;/tr&gt;
          &lt;table&gt;
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorResponse"
          example:
            result:
              errors:
                - code: 1001
                  message: Missing request parameter
                  details: The [id] is missing in the request.

    404ErrorResponse:
      description: |
        __Resource not found__
         Possible errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;n&lt;/td&gt;
            &lt;td&gt;A concise description of the error&lt;/td&gt;
            &lt;td&gt;Detailed information about the error.  Be careful whe=
n exposing provider errors that sensitive information is not revealed.&lt;/=
td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;2&lt;/td&gt;
            &lt;td&gt;Sample resource not found&lt;/td&gt;
            &lt;td&gt;A sample resource with the specified resourceId could=
 not be found &lt;/td&gt;
          &lt;/tr&gt;
        &lt;/table&gt;
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorResponse"

    500ErrorResponse:
      description: |
        __Internal Server Error__
        Possible errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10001&lt;/td&gt;
            &lt;td&gt;Host Unavailable&lt;/td&gt;
            &lt;td&gt;The downstream system failed to accept the request&lt=
;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10002&lt;/td&gt;
            &lt;td&gt;Provider Timeout&lt;/td&gt;
            &lt;td&gt;The downstream system failed to respond within the ex=
pected time periods&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10003&lt;/td&gt;
            &lt;td&gt;Provider System Error&lt;/td&gt;
            &lt;td&gt;[{Provider name}] system error: {Error message}]&lt;/=
td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10004&lt;/td&gt;
            &lt;td&gt;Technical Error&lt;/td&gt;
            &lt;td&gt;Unknown/Runtime Exception occurred during the API exe=
cution&lt;/td&gt;
          &lt;/tr&gt;
        &lt;/table&gt;
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorResponse"
          example:
            result:
              errors:
                - code: 10004
                  message: Technical Error
                  details: Unknown/Runtime Exception occurred during the AP=
I execution

  #########################################################################=
#######
  #                           Definitions                                  =
      #
  #########################################################################=
#######
  schemas:
    GetPayeesResponse:
      type: object
      properties:
        data:
          type: object
          properties:
            payees:
              type: array
              items:
                $ref: "#/components/schemas/Payee"

    Payee:
      description: Payee object
      type: object
      required:
        - payeeId
      properties:
        payeeId:
          description: Unique Identifier of a payee
          type: string
          pattern: ^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$
          example: 6577d3d6-0a37-49ca-9a2a-2368b257085f
        nickname:
          description: Nickname of the payee
          type: string
          pattern: ^.+$
          example: "Finance - Pear Tree Limited"
        description:
          description: Description of the payee
          type: string
          pattern: ^.*$
          example: "Pear Tree Ltd Dividend Account"
        payeeType:
          description: Payee type
          type: string
          enum:
            - DOMESTIC
            - BILLER
            - INTERNATIONAL
          example: DOMESTIC
        creationDate:
          description: dateTime when payee was created
          type: string
          format: date-time
          example: "2024-02-23T07:26:42.876Z"
        domestic:
          $ref: "#/components/schemas/Domestic"

    Domestic:
      description: Domestic
      type: object
      properties:
        payeeAccountType:
          type: string
          enum:
            - ACCOUNTID
            - PAYID
        accountName:
          type: string
          example: "Pear Tree"
          pattern: ^.*$
        accountId:
          $ref: "#/components/schemas/AccountId"
        payId:
          $ref: "#/components/schemas/PayId"

    AccountId:
      description: Account
      type: object
      required:
        - BSB
        - accountNumber
      properties:
        BSB:
          type: string
          pattern: '^\d{6}$'
          example: "035845"
        accountNumber:
          type: string
          pattern: "^[a-zA-Z0-9.]{1,28}$"
          example: "10235674897"

    PayId:
      title: PayID
      required:
        - identification
        - type
      type: object
      properties:
        identification:
          type: string
          pattern: ^.+$
          example: jon.doe@dummyhostname.com
        type:
          type: string
          enum:
            - MOBILE
            - EMAIL
            - PHONE
            - ABN
            - ORGANISATIONID
          example: EMAIL

    CreatePayeesRequest:
      description: List of Payees to be added
      type: object
      properties:
        payees:
          description: Array of payees
          type: array
          items:
            $ref: "#/components/schemas/CreatePayee"

    CreatePayee:
      type: object
      required:
        - nickname
        - payeeType
        - domestic
      properties:
        nickname:
          description: Nickname of Payee
          type: string
          pattern: ^.+$
          example: "Finance - Pear Tree Limited"
        description:
          description: Description
          type: string
          pattern: ^.*$
          example: "Pear Tree Ltd Dividend Account"
        payeeType:
          description: Payee type
          type: string
          enum:
            - DOMESTIC
            - BILLER
            - INTERNATIONAL
          example: DOMESTIC
        domestic:
          $ref: "#/components/schemas/CreateDomestic"

    CreateDomestic:
      description: domestic
      type: object
      required:
        - payeeAccountType
      properties:
        payeeAccountType:
          type: string
          enum:
            - ACCOUNTID
            - PAYID
        accountName:
          type: string
          pattern: ^.+$
          example: "Pear Tree"
        accountId:
          $ref: "#/components/schemas/AccountId"
        payId:
          $ref: "#/components/schemas/PayId"

    CreatePayeesResponse:
      type: object
      properties:
        data:
          type: object
          properties:
            groupId:
              type: string
              pattern: ^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$
              example: 1308e0fb-66f0-4684-87d2-83822ab4fe0b
            payeeIds:
              type: array
              items:
                type: string
                pattern: ^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$
              example: ["7c7a6104-3018-463a-adf5-bea4acdf21b4"]
    Error:
      required:
        - code
        - message
      type: object
      properties:
        code:
          type: integer
          description: Error Code.
          format: int32
