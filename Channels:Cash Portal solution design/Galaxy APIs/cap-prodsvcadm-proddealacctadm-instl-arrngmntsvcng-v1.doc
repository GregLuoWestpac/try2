<pre style=3D"font-size: 12px;">openapi: 3.0.3

###########################################################################=
#####
#                       API Information                                    =
    #
###########################################################################=
#####
info:
  title: Westpac One Core (CCMP) Arrangement Servicing
  contact:
    url: "https://mesh.westpac.com.au/components/apis/cap-prodsvcadm-prodde=
alacctadm-instl-arrngmntsvcng-v1"
  description: |
    This API maintains and retrieves Westpac Institutional Banking arrangem=
ents (accounts) information.
  version: 1.1.0
  x-baseSchemaVersion: "0.12.0"
###########################################################################=
#####
#                  Base Path                                               =
    #
###########################################################################=
#####

servers:
  - url: "/cap/prodsvcadm/proddealacctadm/instl/arrngmntsvcng/v1"

###########################################################################=
#####
#                                  Security                                =
    #
###########################################################################=
#####
security:
  - BasicAuth: [ ]
###########################################################################=
#####
#                      Paths                                               =
    #
###########################################################################=
#####

paths:
  /healthcheck:
    get:
      tags:
        - HealthCheck
      description: retrieves HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        '200':
          $ref: '#/components/responses/200healthCheckStatusResponse'

  /arrangements/summaryView:
    post:
      tags:
        - getArrangements
      description: &gt;-
        This endpoint retrieves arrangement details for a list of account I=
ds.
      operationId: getArrangements
      parameters:
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userId'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userIdScheme'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-originatingBSB'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/brandSilo'
      requestBody:
        description: &gt;
          Retrieve the accounts for a given search criteria.
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GetArrangementsRequest'
        required: true
      responses:
        '200':
          $ref: '#/components/responses/200GetArrangementsResponse'
        '400':
          $ref: '#/components/responses/400GetArrangementsErrorResponse'
        '500':
          $ref: '#/components/responses/500ErrorResponse'

  /arrangements/transactions:
    post:
      tags:
        - retrieveTransactions
      description: &gt;-
        This endpoint retrieves the list of transactions for the provided a=
ccount ID and query parameters
      operationId: retrieveTransactions
      parameters:
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userId'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userIdScheme'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-originatingBSB'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/brandSilo'
        - $ref: "#/components/parameters/pageKey"
        - $ref: "#/components/parameters/pageSize"
        - $ref: "#/components/parameters/transactionDateTime"

      requestBody:
        description: &gt;
          The account details for which transactions are searched.
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/RetrieveTransactionsRequest'
        required: true
      responses:
        '200':
          $ref: '#/components/responses/200RetrieveTransactionsResponse'
        '400':
          $ref: '#/components/responses/400RetrieveTransactionsResponse'
        # Server Errors
        '500':
          $ref: '#/components/responses/500ErrorResponse'

  /arrangements/arrangementId/transactions/transactionId:
    post:
      tags:
        - retrieveTransactionDetails
      description: &gt;-
        This endpoint retrieves the list of transactions for the provided a=
ccount ID and query parameters
      operationId: retrieveTransactionDetails
      parameters:
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userId'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-userIdScheme'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/x-originatingBSB'
        - $ref: 'https://schema.mesh.westpac.com.au/platform/contracts/0.12=
.0/openapi-base.yaml#/components/parameters/brandSilo'
      requestBody:
        description: &gt;
          The account ID and transaction ID of the provided arrangement.
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/RetrieveTransactionDetailsRequest=
"
        required: true
      responses:
        #Success
        '200':
          $ref: '#/components/responses/200RetrieveTransactionDetailsRespon=
se'
        '400':
          $ref: '#/components/responses/400RetrieveTransactionDetailsRespon=
se'
        '404':
          $ref: '#/components/responses/404RetrieveTransactionDetailsRespon=
se'
        '500':
          $ref: '#/components/responses/500ErrorResponse'

###########################################################################=
#####
#                           Components                                     =
    #
###########################################################################=
#####

components:
  securitySchemes:
    BasicAuth:
      $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.12.0/o=
penapi-base.yaml#/components/securitySchemes/BasicAuth"

  parameters:
    pageKey:
      name: pageKey
      in: query
      description: Specifies the page to return.
      schema:
        type: string
        pattern: ^\d+$
        default: '0'

    pageSize:
      name: pageSize
      in: query
      description: Specifies the max number of records to be returned in th=
e result.
      schema:
        type: integer
        default: 10

    transactionDateTime:
      name: transactionDateTime
      in: query
      description: 'The transaction datetime range to be searched for; exam=
ple-&gt; btn:2018-12-29T03:16:42.254Z,2019-01-29T03:16:42.254Z'
      schema:
        type: string
        pattern: '^(btn:(.*),(.*))$'
        maxLength: 55


  responses:
    #Success Response for healthcheck
    200healthCheckStatusResponse:
      description: healthcheck status
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/healthCheckStatus"

    #Success Responses
    200GetArrangementsResponse:
      description: |
        __OK__
       =20
        Possible Partial Errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1002&lt;/td&gt;
            &lt;td&gt;Invalid request body parameter&lt;/td&gt;
            &lt;td&gt;The given {parameterName} has missing/invalid value o=
f {parameterValue}.&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1003&lt;/td&gt;
            &lt;td&gt;Input validation error from provider&lt;/td&gt;
            &lt;td&gt;{error details}&lt;/td&gt;
          &lt;/tr&gt;
           &lt;tr&gt;
            &lt;td&gt;1004&lt;/td&gt;
            &lt;td&gt; No data found in GCM&lt;/td&gt;
            &lt;td&gt;Account with ID [{partially masked accountId}] was no=
t found in GCM&lt;/td&gt;
          &lt;/tr&gt;

      content:
        application/json:
          schema:
            $ref: '#/components/schemas/GetArrangementsResponse'


    400GetArrangementsErrorResponse:
      description: |
        __Bad Request__

        Possible errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1001&lt;/td&gt;
            &lt;td&gt;Missing request parameter&lt;/td&gt;
            &lt;td&gt;At least one account ID should be provided.&lt;/td&gt=
;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1002&lt;/td&gt;
            &lt;td&gt;Invalid request parameter&lt;/td&gt;
            &lt;td&gt;The given {parameterName} has missing/invalid value o=
f {parameterValue}.&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1003&lt;/td&gt;
            &lt;td&gt;Input validation error from provider&lt;/td&gt;
            &lt;td&gt;{error details}&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1004&lt;/td&gt;
            &lt;td&gt;No data received from GCM &lt;/td&gt;
            &lt;td&gt;No data received from GCM for BSB {BSB value} - accou=
nt number {account number} &lt;/td&gt;
          &lt;/tr&gt;

      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
          example:
            result:
              errors:
                - code: 1001
                  message: Missing request parameter
                  details: At least one account ID or arrangement ID should=
 be provided.

    200RetrieveTransactionsResponse:
      description: |
        __OK__

      content:
        application/json:
          schema:
            $ref: "#/components/schemas/RetrieveTransactionsResponse"

    200RetrieveTransactionDetailsResponse:
      description: |
        __OK__

      content:
        application/json:
          schema:
            $ref: "#/components/schemas/RetrieveTransactionDetailsResponse"

    400RetrieveTransactionsResponse:
      description: |
        __Bad Request__

        Possible errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1001&lt;/td&gt;
            &lt;td&gt;Missing request parameter&lt;/td&gt;
            &lt;td&gt;The [{parameterName}] is missing in the request.&lt;/=
td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1002&lt;/td&gt;
            &lt;td&gt;Invalid request parameter&lt;/td&gt;
            &lt;td&gt;The given [{parameterName}] has invalid value of [{pa=
rameterValue}].&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1003&lt;/td&gt;
            &lt;td&gt;Input validation error from provider&lt;/td&gt;
            &lt;td&gt;Request with ID [BSB &lt;{BSB valu}&gt; - account num=
ber &lt;{partially masked account number}&gt;]- [provider name] error\: [er=
rorMessage]&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;1004&lt;/td&gt;
            &lt;td&gt;No data received from GCM &lt;/td&gt;
            &lt;td&gt;No data received from GCM for BSB {BSB value} - accou=
nt number {account number} &lt;/td&gt;
          &lt;/tr&gt;

      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
          example:
            result:
              errors:
                - code: 1001
                  message: Missing request parameter
                  details: The brandSilo is missing in the request.

    400RetrieveTransactionDetailsResponse:
      description: |
        __Bad Request__
       =20
          Possible errors:
          &lt;table&gt;
            &lt;tr&gt;
              &lt;td&gt;Error Code&lt;/td&gt;
              &lt;td&gt;Error Message&lt;/td&gt;
              &lt;td&gt;Error Description&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1001&lt;/td&gt;
              &lt;td&gt;Missing request parameter&lt;/td&gt;
              &lt;td&gt;The [{parameterName}] is missing in the request.&lt=
;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1002&lt;/td&gt;
              &lt;td&gt;Invalid request parameter&lt;/td&gt;
              &lt;td&gt;The given [{parameterName}] has invalid value of [{=
parameterValue}].&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1003&lt;/td&gt;
              &lt;td&gt;Input validation error from provider&lt;/td&gt;
              &lt;td&gt;Request with ID [BSB &lt;{BSB value}&gt; - account =
number &lt;{partially masked account number}&gt; - transaction ID &lt;{tran=
sactionId}&gt;]- [provider name] error\: [errorMessage] .&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1004&lt;/td&gt;
              &lt;td&gt;No data received from GCM&lt;/td&gt;
              &lt;td&gt;No data received from GCM for [BSB &lt;{BSB value}&=
gt; - account number &lt;{partially masked account number}&gt;].&lt;/td&gt;
            &lt;/tr&gt;
          &lt;/table&gt;

      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
          example:
            result:
              errors:
                - code: 1001
                  message: Missing request parameter
                  details: The [arrangement Id] is missing in the request.

    404RetrieveTransactionDetailsResponse:
      description: |
        __Bad Request__
       =20
          Possible errors:
          &lt;table&gt;
            &lt;tr&gt;
              &lt;td&gt;Error Code&lt;/td&gt;
              &lt;td&gt;Error Message&lt;/td&gt;
              &lt;td&gt;Error Description&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
              &lt;td&gt;1101&lt;/td&gt;
              &lt;td&gt;No data found&lt;/td&gt;
              &lt;td&gt;No data found for request with ID [BSB &lt;{BSB val=
ue}&gt; - account number &lt;{partially masked account number}&gt; - transa=
ction ID &lt;{transactionId}&gt;].&lt;/td&gt;
            &lt;/tr&gt;
          &lt;/table&gt;

      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'

    500ErrorResponse:
      description: |
        __Internal Server Error__
        Possible errors:
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10001&lt;/td&gt;
            &lt;td&gt;Host Unavailable&lt;/td&gt;
            &lt;td&gt;The downstream system failed to accept the request&lt=
;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10002&lt;/td&gt;
            &lt;td&gt;Provider Timeout&lt;/td&gt;
            &lt;td&gt;The downstream system failed to respond within the ex=
pected time periods&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10003&lt;/td&gt;
            &lt;td&gt;Provider System Error&lt;/td&gt;
            &lt;td&gt;[{Provider name}] system error: {Error message}]&lt;/=
td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;10004&lt;/td&gt;
            &lt;td&gt;Technical Error&lt;/td&gt;
            &lt;td&gt;{error details}&lt;/td&gt;
          &lt;/tr&gt;
        &lt;/table&gt;
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
          example:
            result:
              errors:
                - code: 10004
                  message: Technical Error
                  details: Unknown/Runtime Exception occurred during the AP=
I execution


  schemas:
    healthCheckStatus:
      type: object
      properties:
        status:
          type: string
          enum:
            - success
      description: healthcheck status

    AccountId:
      description: Account
      type: object
      required:
        - BSB
        - accountNumber
      properties:
        BSB:
          type: string
          pattern: '^\d{6}$'
        accountNumber:
          type: string
          pattern: '^[a-zA-Z0-9.]{1,28}$'
      example:
        BSB: "035845"
        accountNumber: "10235674897"

    Arrangement:
      description: Enriched arrangement
      type: object
      required:
        - accountId
        - aliasName
        - productName
        - status
        - currencyCode
        - currentBalance
        - availableBalance
        - overdraftLimit
        - arrangementOwners
      properties:
        accountId:
          $ref: "#/components/schemas/AccountId"
        aliasName:
          description: Alternative name that customer chosed insead of the =
default value
          type: string
          example: "Payroll"
        productName:
          description: Source system's product name
          type: string
          example: "Corporate Investment Account"
        status:
          description: Account status -&gt; Active, Inactive
          type: string
          example: Active
        currencyCode:
          description: Account's currency code; example -&gt; AUD
          type: string
          pattern: '^\w{3}$'
          example: AUD
        currentBalance:
          $ref: "#/components/schemas/Balance"
        availableBalance:
          $ref: "#/components/schemas/Balance"
        overdraftLimit:
          description: Arrangement's available overdraft limit (credit limi=
t)
          type: string
          pattern: '^\d{1,13}\.\d{1,4}$'
          example: "100.00"
        arrangementOwners:
          description: List of owners of the arrangements
          type: array
          items:
            $ref: "#/components/schemas/ArrangementOwner"

    Balance:
      description: balance amount details.
      type: object
      properties:
        amount:
          type: string
          pattern: '^\d{1,13}\.\d{1,4}$'
          example: "100.9566"
        currencyCode:
          type: string
          example: "AUD"
          pattern: '^\w{3}$'
        position:
          type: string
          enum:
            - CR
            - DR
          example: "DR"

    ArrangementOwner:
      description: The owner (sole or joint) of the arrangement
      type: object
      properties:
        customerIds:
          type: array
          items:
            $ref: "#/components/schemas/CustomerId"
        legalEntityType:
          $ref: "#/components/schemas/ReferenceId"
        organisation:
          $ref: "#/components/schemas/Organisation"


    Organisation:
      type: object
      properties:
        fullName:
          description: Customer's full name
          type: string
          example: ABC Ltd
        ABN:
          description: VAT registration number e.g. 25303090246
          type: string
          example: "123456789"
        ACN:
          description: "Australian Company Number (for domestic companies).=
  e.g. 222456622#"
          type: string
          example: "123456789"
        ARBN:
          description: &gt;-
            Australian Registered Business Number (for foreign registered
            companies)
          type: string
          example: "123456789"

    CustomerId:
      description: Arrangement owner internal/external identifiers
      type: object
      properties:
        customerId:
          description: CustomerInternalId/CustomerNumber e.g. 12345678
          type: string
          example: "12346789"
        customerIdScheme:
          description: &gt;-
            Scheme of the Id eg:CustomerInternalId/CustomerNumber .
            CustomerInternalId is Customer Id from the Source System eg. GC=
ISKey
            or CISKey . CustomerNumber is Internet Bank Client id.
          type: string
          enum:
            - CustomerInternalId
            - PartyUID
            - CustomerNumber
            - ExternalSystemCustomerId
          example: CustomerInternalId

    ReferenceId:
      title: ReferenceId
      type: object
      description: &gt;-
        Reference Id Object . This object will be used when  field values a=
re
        referring to ERD reference Data.
      properties:
        code:
          description: Canonical Code
          type: string
          example: ORGN
        description:
          description: Canonical Code description
          type: string
          example: Organisation

    Correlation:
      description: Represent correlationKey; account should be masked.
      type: object
      properties:
        accountId:
          description: Account number should be partially masked 123456789 =
--[SHOULD BE MASKED PARTIALLY] --&gt; ******6789
          allOf:
            - $ref: "#/components/schemas/AccountId"

    Error:
      description: Represent an individual error.
      type: object
      required:
        - code
        - message
      properties:
        code:
          description: Error Code.
          type: integer
          format: int32
        message:
          description: Error Message
          type: string
        details:
          description: Detailed information about the error
          type: string

    ErrorPartialSuccess:
      description: Represent an individual error.
      type: object
      required:
        - code
        - message
      properties:
        code:
          description: Error Code.
          type: integer
          format: int32
        message:
          description: Error Message
          type: string
        details:
          description: Detailed information about the error
          type: string
        correlationKey:
          $ref: "#/components/schemas/Correlation"

    ErrorResponse:
      type: object
      properties:
        result:
          $ref: "#/components/schemas/ErrorResult"

    ErrorResult:
      type: object
      properties:
        errors:
          type: array
          items:
            $ref: "#/components/schemas/Error"

    GetArrangementsRequest:
      type: object
      required:
        - arrangements
      properties:
        accountIds:
          type: array
          items:
            $ref: "#/components/schemas/AccountId"

    GetArrangementsResponse:
      type: object
      properties:
        data:
          type: object
          properties:
            arrangements:
              type: array
              items:
                $ref: "#/components/schemas/Arrangement"
        result:
          type: object
          properties:
            errors:
              type: array
              items:
                $ref: "#/components/schemas/ErrorPartialSuccess"


    RetrieveTransactionsResponse:
      type: object
      properties:
        data:
          type: object
          properties:
            transactions:
              type: array
              items:
                $ref: "#/components/schemas/Transaction"
        paging:
          $ref: "#/components/schemas/Paging"



    Transaction:
      description: Account transaction incluiding, but not limited to, paym=
ents, interests, etc.
      type: object
      required:
        - accountId
        - transactionId
        - transactionDateTime
        - state
        - narrative
        - amount
        - balance
      properties:
        accountId:
          $ref: "#/components/schemas/AccountId"
        transactionId:
          description: transactionId
          type: string
          minLength: 1
          maxLength: 128
          example: "b922ebd6-9165-4a15-94ce-5973eb5d9f50"
        transactionDateTime:
          type: string
          description: The utc timestamp of the log record as per rfc-3339 =
(https://tools.ietf.org/html/rfc3339#section-5.6)
          format: date-time
          example: "2024-01-28T15:27:49.732Z"
        state:
          description: Status indicating progress of a transaction from the=
 point it is made to when it is settled and complete.
          type: string
          pattern: ^\w+$
          example: "POSTED"
        narrative:
          description: Transaction narrative
          type: string
          pattern: ^.+$
          example: "Deposit to 062000 11111111"
        amount:
          $ref: "#/components/schemas/Balance"
        balance:
          $ref: "#/components/schemas/Balance"
    Paging:
      description: Represent details of Pagination.
      required:
        - count
        - pageSize
        - nextPageKey
        - previousPageKey
      type: object
      properties:
        count:
          description: Total number of items available
          type: integer
          example: 150
        pageSize:
          description: Number of items per page
          type: integer
          example: 25
        nextPageKey:
          description: Key for start of next page
          type: string
          pattern: ^.+$
          example: '2'
        previousPageKey:
          description: Key for start of previous page
          type: string
          pattern: ^.+$
          example: '4'



    RetrieveTransactionDetailsRequest:
      type: object
      required:
        - accountId
        - transactionId
      properties:
        accountId:
          $ref: "#/components/schemas/AccountId"
        transactionId:
          description: transactionId
          type: string
          minLength: 1
          maxLength: 128
          pattern: ^.+$
          example: "ce85b618-34ad-36d0-81d4-f8ba96c7142d"

    RetrieveTransactionsRequest:
      type: object
      required:
        - accountId
      properties:
        accountId:
          $ref: "#/components/schemas/AccountId"

    RetrieveTransactionDetailsResponse:
      type: object
      properties:
        data:
          type: object
          required:
            - ledgerDetails
          properties:
            ledgerDetails:
              $ref: "#/components/schemas/LedgerDetails"
            paymentDetails:
              $ref: "#/components/schemas/PaymentDetails"

    LedgerDetails:
      description: Transaction ledger information.
      type: object
      required:
        - accountId
        - accountAliasName
        - transactionId
        - transactionDateTime
        - state
        - transactionCode
        - transactionType
        - schemeName
        - narrative
        - amount
        - balance

      properties:
        accountId:
          $ref: "#/components/schemas/AccountId"
        accountAliasName:
          description: Alternative name that customer chosed insead of the =
default value
          type: string
          maxLength: 255
          example: "Payroll"
        transactionId:
          description: transactionId
          type: string
          minLength: 1
          maxLength: 128
          example: "05123d9c-3225-447c-8405-3a705ff72328"
        transactionDateTime:
          type: string
          description: The utc timestamp of the log record as per rfc-3339 =
(https://tools.ietf.org/html/rfc3339#section-5.6)
          format: date-time
          example: "2024-01-28T15:27:49.732Z"
        state:
          description: Status indicating progress of a transaction from the=
 point it is made to when it is settled and complete.
          type: string
          pattern: ^\w+$
          example: "POSTED"
        transactionCode:
          description: Code that classifies the method of transaction being=
 made.
          type: string
          pattern: ^.+$
          example: "PMNT.IRCT.BOOK"
        transactionType:
          description: The type of transaction made.
          type: string
          pattern: ^.+$
          example: "BKTR"
        schemeName:
          description: Payment scheme the transaction was executed through.
          type: string
          pattern: ^.+$
          example: "FIS-Book"
        narrative:
          description: Transaction narrative
          type: string
          pattern: ^.+$
          example: "Deposit to 062000 11111111"
        amount:
          $ref: "#/components/schemas/Balance"
        balance:
          $ref: "#/components/schemas/Balance"


    PaymentDetails:
      type: object
      properties:
        referenceData:
          $ref: "#/components/schemas/ReferenceData"
        messageIdentification:
          type: string
          description: |-
            Point to point reference, as assigned by the instructing party,=
 and sent to the next party in the chain to unambiguously identify the mess=
age.
          minLength: 1
          maxLength: 35
          example: "WPACAU2SXXX20180711Y30000001218911"
        paymentInformation:
          $ref: '#/components/schemas/PaymentInformationObject'
        paymentTypeInformation:
          $ref: '#/components/schemas/PaymentTypeInformationObject'
        debtor:
          $ref: '#/components/schemas/Debtor'
        debtorAccount:
          $ref: '#/components/schemas/DebtorAccount'
        debtorAgent:
          $ref: '#/components/schemas/DebtorAgentObject'
        creditTransferTransactionInformation:
          type: array
          items:
            $ref: '#/components/schemas/CreditTransferInformationItems'
        supplementaryData:
          $ref: '#/components/schemas/PaymentSupplementaryDataObject'

    PaymentSupplementaryDataObject:
      type: object
      properties:
        debitDescription:
          type: string
          maxLength: 35
          example: "INV 12345"
          description: &gt;-
            The reference assigned by the sending party for the payment.&lt=
;br&gt;Usage- Caller to map debit description (statement narrative) to this=
 field.

    CreditTransferInformationItems:
      description: Provides information on the individual transaction(s) in=
cluded in the message.
      type: object
      properties:
        endToEndIdentification:
          type: string
          maxLength: 35
          example: "INV-123456790"
          description: &gt;-
            A reference assigned by the initiating party to unambiguously i=
dentify the payment. This identifier is passed on unchanged throughout the =
entire end-to-end payment flow. The end-to-end identification can be used f=
or reconciliation or to link tasks relating to the payment. It can be inclu=
ded in several messages related to the payment.&lt;br&gt;
            Example- INV-123456790&lt;br&gt;
             Usage- Caller to map customer's payment reference to this fiel=
d.  For NPP Osko payments.
             May only be provided if customerType in the header is set to '=
Organisation'.
             Must be set to 'NOTPROVIDED' if customerType in the header is =
set to 'Individual'.
        paymentTypeInformation:
          $ref: '#/components/schemas/PaymentTypeInformationObject'
        creditor:
          type: object
          properties:
            name:
              type: string
              maxLength: 140
              example: "BBC Corp PTY LTD"
              description: &gt;-
                Name by which a party is known, and which is usually used t=
o identify that party. (Creditor name or Alias Short Name).&lt;br&gt; Usage=
- Caller to map creditor's name to this field.
        creditorAccount:
          $ref: '#/components/schemas/DebtorAndCreditorAccount'
        creditorAgent:
          $ref: '#/components/schemas/DebtorAgentObject'
        remittanceInformation:
          $ref: '#/components/schemas/RemittanceInformationObject'
        instructionForDebtorAgent:
          $ref: '#/components/schemas/InstructionForDebtorAgentObject'
        transactionStatus:
          type: string
          example: "ACSC"
          description: Specifies the ISO status of the credit transaction w=
ithin the payment, in case of on-us payments.
            &lt;br&gt;
            Usage-  Possible values-
            ACSC - Accepted Settlement Completed (success)
            RJCT - Rejected (posting rejected)
            ACSP - Accepted Settlement In Process (auto retry in progress i=
n case of technical failure)

    InstructionForDebtorAgentObject:
      type: string
      maxLength: 140
      pattern: '^[a-zA-Z0-9\\s-]*$'
      example: "On-Me"
      description: &gt;-
        Further information related to the processing of the payment instru=
ction, that may need to be acted upon by the debtor agent, depending on agr=
eement between debtor and the debtor agent. When present, it applies to ALL=
 credit transfer transaction information occurrences, present in the paymen=
t information.

    RemittanceInformationObject:
      description: Remittance information to be supplied with the payment.
      type: object
      properties:
        unstructured:
          type: array
          maxItems: 2
          items:
            maxLength: 140
            description: Remittance information to be supplied with a payme=
nt to assist the recipient to determine the intended purpose of the payment=
. There are two lines of 140 characters.&lt;br&gt;Usage- Caller to map cred=
it description (statement narrative) to this field.
        creditorReference:
          type: string
          maxLength: 35
          example: "INV 12345"

    DebtorAgentObject:
      type: object
      properties:
        BICFI:
          $ref: '#/components/schemas/BICFI'

    BICFI:
      type: string
      maxLength: 11
      example: "WPACAU2FXXX"
      description: Code allocated to a financial institution by the ISO 936=
2 Registration Authority as described in ISO 9362 "Banking - Banking teleco=
mmunication messages - Business identifier code (BIC)".
      pattern: '[A-Z]{6,6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3,3}){0,1}'

    Debtor:
      type: object
      description: Set of elements used to identify a person or an organisa=
tion.
      properties:
        name:
          type: string
          description: Name by which a party is known, and which is usually=
 used to identify sending party.
          maxLength: 140
          example: "ABC Corp PTY LTD"

    DebtorAccount:
      allOf:
        - $ref: '#/components/schemas/DebtorAndCreditorAccount'

    DebtorAndCreditorAccount:
      type: object
      properties:
        identification:
          type: string
          description: Identification assigned by an institution. Full acco=
unt number including BSB (without any separators or spaces).
          minLength: 1
          maxLength: 34
          example: "03584510235674897"
        schemeName:
          type: string
          description: Sets of elements to identify a name of the identific=
ation scheme.
          minLength: 1
          maxLength: 4
          example: "BBAN"
        name:
          type: string
          description: Name of the account, as assigned by the account serv=
icing institution, in agreement with the account owner in order to provide =
an additional means of identification of the account.
          minLength: 1
          maxLength: 140
          example: "ABC Corp PTY LTD"
        #Mapped from postingDetails
        ledgerAccountId:
          type: string
          minLength: 1
          maxLength: 50
          example: "05123d9c-3225-447c-8405-3a705ff72328"
          description: 10x Subscription ID for the account.

    PaymentInformationObject:
      type: object
      description: &gt;-
        Set of characteristics that applies to the payment instruction.
      properties:
        paymentInformationStatus:
          type: string
          example: "ACSC"
          description: Specifies the ISO status of the payment. Usage- Poss=
ible values -&lt;br&gt; ACSC- Accepted Settlement Completed (success) &lt;b=
r&gt; ACSP- Accepted Settlement In Process (auto retry in progress in case =
of technical failure)&lt;br&gt; RJCT- Rejected

    PaymentTypeInformationObject:
      description: Set of elements used to further specify the type of tran=
saction.
      type: object
      properties:
        paymentMethodCode:
          maxLength: 35
          type: string
          example: "NORM"
          description: &gt;-
            Specifies a pre-agreed service or level of service between the =
parties.&lt;br&gt;
            NORM - For 'Attended' transaction. Attended payments are define=
d as Payments whereby the sending participant requires a real-time response=
 to their payment instruction
             &lt;br&gt;UNAT - For 'Unattended' transaction. Unattended paym=
ents are defined as Payments whereby the sending participant does not requi=
re a real-time response to their payment instruction.&lt;br&gt;
             Usage- Caller to set this field to 'NORM'.&lt;br&gt;
           =20
             For credit transfer transactions- Specifies a pre-agreed servi=
ce or level of service between the parties.&lt;br&gt;
           =20
            Usage- Caller to set this field to 'npp.clear.01-x2p1.01' for N=
PP Osko payments.

        paymentMethodDescription:
          maxLength: 35
          type: string
          example: "Funds Transfer"
          description: &gt;-
            Description for the paymentMethodCode&lt;br&gt;
            Funds Transfer' - When instructionForDebtorAgent =3D=3D 'On-Me'=
&lt;br&gt;
            Fast Payment - For paymentMethodCode 'npp.clear.01-catsct.*','n=
pp.clear.01-sct.*, and null (On-Platform).  &lt;br&gt;
            Osko - For paymentMethodCode 'npp.clear.01-x2p1.*'.&lt;br&gt;

        categoryPurpose:
          type: string
          maxLength: 35
          example: "SALA"
          description: &gt;-
            Specifies the high-level purpose of the instruction based on a =
set of pre-defined categories. This is used by the initiating party to prov=
ide information concerning the processing of the payment.

    ReferenceData:
      type: object
      properties:
        paymentId:
          type: string
          maxLength: 36
          example: "WP4167123456789"
          description: Payment ID, also known as Receipt Number, assigned b=
y W1C to uniquely identify a payment. In FIS terms, it is instructionReceip=
tIdentification.
        NPPTransactionId:
          type: string
          maxLength: 35
          example: "05123d9c3225447c84053a705ff72328"
          description: NPP Transaction ID, a unique reference assigned for =
an NPP payment as per NPP industry regulation.
        NPPMessageDefinitionId:
          type: string
          maxLength: 35
          example: "pacs.008.001.05"
          description: Message Definition Identifier (e.g. 'pacs.008.001.05=
') for NPP payments only.</pre>
</div>
</div>
</div>
</div>
<p></p>
</div></td>
</tr>
<tr>
<th style=3D"text-align: left;" class=3D"confluenceTh"><span style=3D"color=
: rgb(0,0,0);">Document Status</span></th>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<div class=3D"content-wrapper">
<p><span class=3D"status-macro aui-lozenge aui-lozenge-success">REVIEWED</s=
pan></p>
<ul>
<li>Retrieving the list of arrangements</li>
<li>Retrieving the list of transactions</li>
<li>Retrieving the transaction details</li>
</ul>
<ul style=3D"list-style-type: square;">
<li>Retrieve details of an arrangement</li>
</ul>
</div></td>
</tr>
</tbody>
</table>
</div>
