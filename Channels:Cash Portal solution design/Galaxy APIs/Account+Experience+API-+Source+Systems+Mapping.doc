<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: sql; gutter: false; theme: Confluence" data-theme=3D"Confluence">"tierBan=
ds": [
              {
                "startRange": 0,
                "endRange": 99.99,
                "interestRate": 0.0285
              },
              {
                "startRange": 100,
                "endRange": 999.99,
                "interestRate": 0.0285

              },
              {
                "startRange": 1000,
                "endRange": 99999999999.99,
                "interestRate": 0.0285

              }
            ]</pre>
</div>
</div>
<p><br></p>
<p><strong><span style=3D"color: rgb(85,85,85);"><span style=3D"color: rgb(=
85,85,85);">&nbsp;</span></span></strong></p>
