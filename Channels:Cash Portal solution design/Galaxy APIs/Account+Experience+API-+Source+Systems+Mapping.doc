<ol>
<li>Map paymentMethod.description:</li>
</ol>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: js; gutter: false; theme: Midnight" data-theme=3D"Midnight">// Maps to Pa=
yTo if mandateIdentification is present and non-empty
const hasMandate =3D
  referenceData?.mandateIdentification !=3D=3D undefined &amp;&amp;
  referenceData?.mandateIdentification !=3D=3D null &amp;&amp;
  String(referenceData.mandateIdentification).trim().length &gt; 0;

if (hasMandate) {
  paymentMethod.description =3D 'PayTo';
} else {
  switch (paymentTypeInformation?.paymentMethod?.description) {
    case 'On-Platform':
      paymentMethod.description =3D 'Fast Payment';
      break;
    case 'On-Me':
      paymentMethod.description =3D 'Funds Transfer';
      break;
    default:
      // Keep the original value if none of the cases match
      paymentMethod.description =3D paymentMethod.description;
  }
}</pre>
</div>
</div>
<div class=3D"content-wrapper">
<p><br></p>
