  /paymentLimits:
    get:
      tags:
        - Payment Limit
      description: This endpoint generates a payment identifier
      operationId: getPaymentLimits
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      responses:
        '200':
          description: Successful response containing payment limits
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    description: Entities containing payment limits
                    properties:
                      paymentLimits:
                        type: array
                        description: List of payment limit objects
                        items:
                          description: Payment limit details for a user, or=
ganisation, or scheme channel.
                          type: object
                          properties:
                            id:
                              description: A unique id generated for each r=
ecord which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            level:
                              type: string
                              description: The level at which the payment l=
imit applies
                              enum:
                                - User
                                - OrganisationChannel
                                - SchemeChannel
                            channelId:
                              description: Unique identifier for the channe=
l
                              type: string
                              pattern: ^A[0-9A-F]{5}$
                            scheme:
                              description: Type of scheme for the payment l=
imit
                              type: string
                              enum:
                                - NPP
                                - DE
                            recordedTs:
                              type: string
                              description: Timestamp when the payment limit=
 was recorded
                              format: date-time
                            transactionLimit:
                              description: Transaction limit details
                              type: object
                              properties:
                                amount:
                                  description: Transaction limit amount
                                  type: object
                                  deprecated: true
                                  properties:
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                    amount:
                                      description: A positive number string=
 of up to four decimal places (including zero). Must have at least one digi=
t after the decimal point.
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                    position:
                                      type: string
                                      enum:
                                        - CR
                                        - DR
                                      example: CR
                            dailyLimit:
                              description: Daily limit details
                              type: object
                              properties:
                                amount:
                                  description: Daily limit amount
                                  type: object
                                  deprecated: true
                                  properties:
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                    amount:
                                      description: A positive number string=
 of up to four decimal places (including zero). Must have at least one digi=
t after the decimal point.
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                    position:
                                      type: string
                                      enum:
                                        - CR
                                        - DR
                                      example: CR
                                remainingAmount:
                                  description: Remaining daily limit amount
                                  type: object
                                  deprecated: true
                                  properties:
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                    amount:
                                      description: A positive number string=
 of up to four decimal places (including zero). Must have at least one digi=
t after the decimal point.
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                    position:
                                      type: string
                                      enum:
                                        - CR
                                        - DR
                                      example: CR
                  result:
                    type: object
                    description: Result object containing payment limits en=
tity result
                    properties:
                      paymentLimits:
                        description: Entity result for payment limits
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      paymentLimits:
                        - 5ab2ba7e-8f5f-45dc-9bc6-0d18ffb53c2e
