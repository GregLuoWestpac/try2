                                  transactionStatus:
                                    type: string
                                    description: Specifies the ISO status o=
f the credit transaction within the payment, in case of on-us payments. &lt=
;br&gt; Usage-  Possible values- ACSC - Accepted Settlement Completed (succ=
ess) RJCT - Rejected (posting rejected) ACSP - Accepted Settlement In Proce=
ss (auto retry in progress in case of technical failure
                                    enum:
                                      - ACSC
