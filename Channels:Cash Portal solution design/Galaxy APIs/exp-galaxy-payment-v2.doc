    UUID:
      description: A unique identifier
      type: string
      format: uuid
      pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}=
-[0-9a-f]{12}$
    AmountObj:
      type: object
      properties:
        currencyCode:
          description: A code allocated to a currency by a Maintenance Agen=
cy under an international identification scheme, as described in the latest=
 edition of the international standard ISO 4217 =E2=80=9CCodes for the repr=
esentation of currencies and funds=E2=80=9D.&lt;br&gt; Usage- Caller to set=
 'AUD' to this field.
          type: string
          pattern: ^\w{3}$
          example: AUD
        amount:
          type: string
          pattern: ^\d{1,13}\.\d{1,4}$
          example: '1000.0000'
        position:
          type: string
          enum:
            - CR
            - DR
          example: CR
    AccountIdObj:
      type: object
      description: Account ID (BSB and Account Number)
      required:
        - BSB
        - accountNumber
      properties:
        BSB:
          description: Bank State Branch Number
          type: string
          pattern: ^\d{6}$
          example: '135845'
        accountNumber:
          description: Account Number
          type: string
          pattern: ^[a-zA-Z\d.]+$
          minLength: 1
          maxLength: 28
          example: '01235674897'
      example:
        BSB: '035845'
        accountNumber: '10235674897'
    DebtorOrCreditorObj:
      type: object
      description: Account Information for debtor or creditor
      properties:
        name:
          description: account name
          maxLength: 255
          example: John S
          type: string
          pattern: ^[\w\- \/\'\(\)\&amp;\+\@]+$
        nickName:
          description: account alias name (nickname)
          maxLength: 255
          example: Payroll account
          type: string
          pattern: ^[\w\- \/\'\(\)\&amp;\+\@]+$
        accountId:
          description: Full account number with format &lt;BSB  Account Num=
ber&gt; -&gt; "035845 123456789"
          type: string
          pattern: ^[a-zA-Z\d. ].+$
          maxLength: 35
          example: 035845 103784254
    AmountStr:
      type: string
      pattern: ^\d{1,13}\.\d{1,4}$
      example: '1000.0000'
    CurrencyCode:
      description: A code allocated to a currency by a Maintenance Agency u=
nder an international identification scheme, as described in the latest edi=
tion of the international standard ISO 4217 =E2=80=9CCodes for the represen=
tation of currencies and funds=E2=80=9D.&lt;br&gt; Usage- Caller to set 'AU=
D' to this field.
      type: string
      pattern: ^\w{3}$
      example: AUD
    AccountIdStr:
      description: Full account number with format &lt;BSB  Account Number&=
gt; -&gt; "035845 123456789"
      type: string
      pattern: ^[a-zA-Z\d. ].+$
      maxLength: 35
      example: 035845 103784254
    PaymentStatus:
      type: string
      enum:
        - Processing
        - Processed
        - Failed
      example: Processed
    ISG_APPROVED_STRING:
      description: Field allowing some special characters
      type: string
      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    NAME_STRING:
      description: Field allowing some special characters
      type: string
      pattern: ^[\w\- \/\'\(\)\&amp;\+\@]+$
    EMOJI_STRING:
      description: Field allowing emoji characters
      type: string
      pattern: ^(?!.*&lt;\/).*
    PaymentMethodDescription:
      type: string
      example: Fast Payment
      enum:
        - Funds transfer
        - Fast Payment
        - Osko
        - PayTo
        - Pay Anyone
    PaymentMethodCode:
      type: string
      maxLength: 35
      pattern: ^[a-z0-9.-]+$
      example: npp.clear.01-sct.01
    PaymentMethodObject:
      description: The description of the identification of the payment sch=
eme along with payment scheme code (only for staffs)
      type: object
      properties:
        code:
          type: string
          maxLength: 35
          pattern: ^[a-z0-9.-]+$
          example: npp.clear.01-sct.01
        description:
          type: string
          example: Fast Payment
          enum:
            - Funds transfer
            - Fast Payment
            - Osko
            - PayTo
            - Pay Anyone
    BICFI:
      description: Code allocated to a financial institution by the ISO 936=
2 Registration Authority as described in ISO 9362 "Banking - Banking teleco=
mmunication messages - Business identifier code (BIC)".&lt;br&gt; Usage- Ca=
ller to set this field to the new WIB BIC 'WPACAU2SONE'.
      type: string
      maxLength: 11
      pattern: ^\w+$
    currencyAndAmount:
      description: balance amount details.
      type: object
      properties:
        amount:
          description: The payment amount before deduction of charges, expr=
essed in the currency as ordered by the initiating party.&lt;br&gt; Usage- =
Caller to map payment amount to this field.
          type: string
          pattern: \d{1,13}\.?\d{0,3}$
        currency:
          description: A code allocated to a currency by a Maintenance Agen=
cy under an international identification scheme, as described in the latest=
 edition of the international standard ISO 4217 =E2=80=9CCodes for the repr=
esentation of currencies and funds=E2=80=9D.&lt;br&gt; Usage- Caller to set=
 'AUD' to this field.
          type: string
          pattern: ^\w{3}$
          example: AUD
      required:
        - amount
        - currency
    StatusReasonInformationItems:
      description: Status reason information
      type: object
      properties:
        reason:
          type: string
          pattern: /^[\w ]+$/
          maxLength: 50
          description: |-
            Status reason description.

              Group status reason can have values -
                AccountEligibilityFailure
                DuplicatePayment
                ExternalValidationEnrichmentFailed
                PostingFailed
                PostingSucceeded
                ValidationFailure

              Instruction status reason can have values -
                AccountEligibilityFailure
                InsufficientAccountBalance
                DebitPostingFailed
                DebitPostingSucceeded
                ExternalValidationEnrichmentFailed
                FraudCheckDeclined
                FraudCheckDelayed
                FraudCheckNotAvailable
                FraudCheckOnHold
                FraudCheckReferred
                FundsReservationFailed
                FundsReservationSucceeded
                InvalidExecutionDate
                ValidationFailure

              Transaction status reason can have values -
                ClearingAndSettlementRejected
                AccountEligibilityFailure
                CreditPostingAborted
                CreditPostingFailed
                SchemeDeterminationFailed
                ValidationFailure
        additionalInformation:
          type: string
          pattern: /^[\w ]+$/
          maxLength: 120
          description: Further information about the above status reason fr=
om downstream.
    unstructured:
      type: array
      maxItems: 2
      description: Information supplied to enable the matching/reconciliati=
on of an entry with the items that the payment is intended to settle, such =
as commercial invoices in an accounts'' receivable system.
      items:
        maxLength: 140
        description: Field allowing some special characters
        type: string
        pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    PartyDetailsObj:
      type: object
      description: Set of elements used to identify a person or an organisa=
tion.
      properties:
        identification:
          description: Unique and unambiguous identification of a person. F=
or example, CIS Key of the debtor account.&lt;br&gt; Usage- Caller to map d=
ebtor's identification to this field.
          maxLength: 35
          type: string
          pattern: /^[\w ]+$/
        issuer:
          description: Entity that assigns the identification.  Example- WP=
AC &lt;br&gt; Usage- Caller to set this field to 'WPAC'.
          maxLength: 35
          type: string
          pattern: /^[\w ]+$/
        name:
          description: Name by which a party is known, and which is usually=
 used to identify sending party.&lt;br&gt; Usage- Caller to map debtor's na=
me to this field.
          maxLength: 140
          type: string
          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    AccountDetailsObj:
      type: object
      description: Provides the details to identify an account.
      properties:
        identification:
          description: Full account number including BSB (without any separ=
ators or spaces).&lt;br&gt; Usage- Caller to map debit account number to th=
is field.
          maxLength: 34
          type: string
          pattern: ^[A-Za-z0-9\.]+$
        issuer:
          description: Entity that assigns the identification.&lt;br&gt; Us=
age- Caller to map this field to the 6-digit BSB number of the debit accoun=
t.
          type: string
          maxLength: 6
          pattern: ^\d{6}$
        name:
          description: Name by which a party is known, and which is usually=
 used to identify that party. For NPP payment, this is the Full Legal Accou=
nt Name (FLAN). &lt;br&gt; Usage- For NPP payments, this field is expected =
to be provided by the payment enrichment system.
          maxLength: 70
          type: string
          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
        schemeName:
          description: |-
            Name of the identification scheme, in a coded form as published=
 in an external list.&lt;br&gt;
             Usage- Caller to set this field to 'BBAN' to represent Austral=
ian Bank-State-Branch Code (BSB) identification.
          maxLength: 4
          type: string
          pattern: ^\w+$
        type:
          description: Debtor's account type represented as Canonical Produ=
ct Code (CPC).&lt;br&gt; Usage- For future use.
          maxLength: 35
          type: string
          pattern: ^\w+$
    AliasId:
      description: |-
        aka Payment Alias also known as PayID.  This field will be populate=
d if there was a payId type payment,
        &lt;br&gt;Usage format-
           &lt;br&gt;For type TELI-  The telephone number must consist of a=
 =E2=80=9C+=E2=80=9D followed by the country code (from 1 to 3 characters) =
then a =E2=80=9C-=E2=80=9C &amp; finally, any combination of numbers (up to=
 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1,1}[0-9]{1,29}$ Exampl=
e- +61-123456789
          &lt;br&gt; For type EMAL- Consists of a character string with a m=
aximum length of 256 characters. This must include the =E2=80=9C@=E2=80=9D =
symbol with leading and trailing characters and no white spaces. Only lower=
 case characters will be supported.
           Format pattern- Maximum of 256 characters ^(?:[a-z0-9!#$%&amp;'*=
+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+)*@(?:[a-z0-9](?:[a-=
z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)$ Example- 123@NPP.com
          &lt;br&gt; For type AUBN- This is assigned by the Australian Taxa=
tion Office to identify an individual Australian Business. Consists of a ni=
ne-to-eleven digit number. If the length is 9 digits than the last digit is=
 the check digit. If the length is 11 digits, then an algorithm is used to =
validate the entire value as there is no check digit as such. Format patter=
n- ^((\d{9})|(\d{11}))$ Example- 601428737
           &lt;br&gt; For type ORGN- The Identifier must be representative =
of the company name, organisation name, trading name, associated product, c=
ampaign or an identifier recognisable as associated with the specific busin=
ess or organisation, with no whitespace at the beginning or end. Maximum of=
 256 characters in lower case, to be drawn from Printable ASCII (decimal 32=
-126) and without leading or trailing whitespace. For avoidance of doubt, u=
pper case letters (A-Z, decimal 65-90) are excluded.
           Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!-@[-~]$ Example- ABC P=
ty. Ltd. Sydney NSW
      maxLength: 256
      type: string
      pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}~\.\x20-\x7E\+\-]+$
      example: tay.tay@westpac.com.au
    AliasType:
      description: |-
        For a PayID payment, the type of the PayID.
          &lt;br&gt;TELI- Telephone Number
          &lt;br&gt;EMAL- Email Address
          &lt;br&gt;AUBN- Australian Business Number
          &lt;br&gt;ORGN- Organisation ID
      maxLength: 4
      enum:
        - EMAL
        - TELI
        - AUBN
        - ORGN
      type: string
    AuthBIC8:
      type: string
      maxLength: 8
      default: WPACAU3S
      description: W1C to set this field to the BIC 'WPACAU3S'.
      enum:
        - WPACAU3S
    AliasObject:
      type: object
      description: Payment Alias also known as PayID.
      properties:
        id:
          description: |-
            aka Payment Alias also known as PayID.  This field will be popu=
lated if there was a payId type payment,
            &lt;br&gt;Usage format-
               &lt;br&gt;For type TELI-  The telephone number must consist =
of a =E2=80=9C+=E2=80=9D followed by the country code (from 1 to 3 characte=
rs) then a =E2=80=9C-=E2=80=9C &amp; finally, any combination of numbers (u=
p to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1,1}[0-9]{1,29}$ Ex=
ample- +61-123456789
              &lt;br&gt; For type EMAL- Consists of a character string with=
 a maximum length of 256 characters. This must include the =E2=80=9C@=E2=80=
=9D symbol with leading and trailing characters and no white spaces. Only l=
ower case characters will be supported.
               Format pattern- Maximum of 256 characters ^(?:[a-z0-9!#$%&am=
p;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+)*@(?:[a-z0-9](?=
:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)$ Example- 123@NPP=
.com
              &lt;br&gt; For type AUBN- This is assigned by the Australian =
Taxation Office to identify an individual Australian Business. Consists of =
a nine-to-eleven digit number. If the length is 9 digits than the last digi=
t is the check digit. If the length is 11 digits, then an algorithm is used=
 to validate the entire value as there is no check digit as such. Format pa=
ttern- ^((\d{9})|(\d{11}))$ Example- 601428737
               &lt;br&gt; For type ORGN- The Identifier must be representat=
ive of the company name, organisation name, trading name, associated produc=
t, campaign or an identifier recognisable as associated with the specific b=
usiness or organisation, with no whitespace at the beginning or end. Maximu=
m of 256 characters in lower case, to be drawn from Printable ASCII (decima=
l 32-126) and without leading or trailing whitespace. For avoidance of doub=
t, upper case letters (A-Z, decimal 65-90) are excluded.
               Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!-@[-~]$ Example- A=
BC Pty. Ltd. Sydney NSW
          maxLength: 256
          type: string
          pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}~\.\x20-\x7E\+\-]+=
$
          example: tay.tay@westpac.com.au
        type:
          description: |-
            For a PayID payment, the type of the PayID.
              &lt;br&gt;TELI- Telephone Number
              &lt;br&gt;EMAL- Email Address
              &lt;br&gt;AUBN- Australian Business Number
              &lt;br&gt;ORGN- Organisation ID
          maxLength: 4
          enum:
            - EMAL
            - TELI
            - AUBN
            - ORGN
          type: string
        authBIC8:
          type: string
          maxLength: 8
          default: WPACAU3S
          description: W1C to set this field to the BIC 'WPACAU3S'.
          enum:
            - WPACAU3S
    AccountIssuer:
      type: string
      maxLength: 6
      pattern: ^\d{6}$
      description: BSB for account.
    AccountSchemeName:
      description: Schema code for example BBAN.
      type: string
      enum:
        - BBAN
    paymentId:
      type: string
      pattern: ^\w+$
      maxLength: 36
      description: A unique id generated to reference a specific payment tr=
ansaction
    creationDateTime:
      description: Date and time at which the message was created.
      type: string
      format: date-time
      example: '2024-01-28T15:27:49.732Z'
    ChannelType:
      description: |-
        Channel sending the request. Can be empty or null.
          e.g.
        - W1C_O_B_D_CP - W1C_O_A_D_SP
      type: string
      maxLength: 100
      pattern: ^[A-Z0-9_-]+$
    BeneficiaryStatus:
      description: Beneficiary status; example-&gt; ACTIVE, ARCHIVED
      type: string
      enum:
        - ACTIVE
        - ARCHIVED
      example: ACTIVE
    BeneficiaryAccountType:
      description: Beneficiary account type either Pay id or BSB &amp; Acco=
unt number
      type: string
      enum:
        - PAYID
        - BSB_AND_ACC
      example: BSB_AND_ACC
    Account:
      type: object
      description: Represents Account detail object
      oneOf:
        - type: object
          description: Object representing an account identified by BSB, ba=
nk name, account name, and account number.
          required:
            - bsb
            - bankName
            - accountNumber
            - accountName
          properties:
            bsb:
              description: Bank State Branch Number
              type: string
              pattern: ^\d{6}$
              example: '135845'
            bankName:
              description: Name of Bank
              type: string
              pattern: ^[\w ]+$
              minLength: 1
              maxLength: 70
              example: Westpac Banking Corporation
            accountNumber:
              description: Account Number
              type: string
              pattern: ^[a-zA-Z\d.]+$
              minLength: 1
              maxLength: 28
              example: '01235674897'
            accountName:
              description: Account Name
              minLength: 1
              maxLength: 140
              example: Apple Tree
              type: string
              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
        - type: object
          description: Represents PayID object
          properties:
            payIDName:
              description: Beneficiary Nickname
              type: string
              example: John
              minLength: 1
              maxLength: 70
              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s\S]*$
          required:
            - payIDName
          oneOf:
            - type: object
              description: PAY ID with email
              required:
                - payIDType
                - payIDValue
              properties:
                payIDType:
                  description: PayID type representing an Email address.
                  enum:
                    - EMAL
                  type: string
                  example: EMAL
                payIDValue:
                  description: PAY ID value representing an Email address
                  minLength: 5
                  maxLength: 256
                  example: john.doe@example.com
                  type: string
                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
            - type: object
              description: PAY ID with telephone number
              required:
                - payIDType
                - payIDValue
              properties:
                payIDType:
                  description: PayID type representing a Telephone number.
                  enum:
                    - TELI
                  type: string
                  example: TELI
                payIDValue:
                  description: PAY ID value representing a Telephone number
                  type: string
                  pattern: ^\+([1-9]{1}[0-9]{1,2})[0-9]+$
                  minLength: 2
                  maxLength: 30
                  example: '+61412345678'
            - type: object
              description: PAY ID with Organisation number
              required:
                - payIDType
                - payIDValue
              properties:
                payIDType:
                  description: PayID type representing an Organisation ID.
                  enum:
                    - ORGN
                  type: string
                  example: ORGN
                payIDValue:
                  description: PAY ID value representing an Organisation nu=
mber
                  minLength: 2
                  maxLength: 256
                  example: ORG-12345
                  type: string
                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
            - type: object
              description: PAY ID with Australian Business number
              required:
                - payIDType
                - payIDValue
              properties:
                payIDType:
                  description: PayID type representing an Australian Busine=
ss Number (ABN).
                  enum:
                    - AUBN
                  type: string
                  example: AUBN
                payIDValue:
                  description: PAY ID value representing an Australian Busi=
ness Number (ABN)
                  type: string
                  pattern: ^\d+$
                  minLength: 9
                  maxLength: 11
                  example: '12345678910'
      example:
        bsb: 135845
        bankName: Westpac Banking Corporation
        accountNumber: 11235674897
        accountName: Apple Tree
        payIDName: John
        payIDType: EMAL
        payIDValue: john.doe@example.com
    BsbAccountObj:
      type: object
      description: Object representing an account identified by BSB, bank n=
ame, account name, and account number.
      required:
        - bsb
        - bankName
        - accountNumber
        - accountName
      properties:
        bsb:
          description: Bank State Branch Number
          type: string
          pattern: ^\d{6}$
          example: '135845'
        bankName:
          description: Name of Bank
          type: string
          pattern: ^[\w ]+$
          minLength: 1
          maxLength: 70
          example: Westpac Banking Corporation
        accountNumber:
          description: Account Number
          type: string
          pattern: ^[a-zA-Z\d.]+$
          minLength: 1
          maxLength: 28
          example: '01235674897'
        accountName:
          description: Account Name
          minLength: 1
          maxLength: 140
          example: Apple Tree
          type: string
          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    BSB:
      description: Bank State Branch Number
      type: string
      pattern: ^\d{6}$
      example: '135845'
    PayID:
      type: object
      description: Represents PayID object
      properties:
        payIDName:
          description: Beneficiary Nickname
          type: string
          example: John
          minLength: 1
          maxLength: 70
          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s\S]*$
      required:
        - payIDName
      oneOf:
        - type: object
          description: PAY ID with email
          required:
            - payIDType
            - payIDValue
          properties:
            payIDType:
              description: PayID type representing an Email address.
              enum:
                - EMAL
              type: string
              example: EMAL
            payIDValue:
              description: PAY ID value representing an Email address
              minLength: 5
              maxLength: 256
              example: john.doe@example.com
              type: string
              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
        - type: object
          description: PAY ID with telephone number
          required:
            - payIDType
            - payIDValue
          properties:
            payIDType:
              description: PayID type representing a Telephone number.
              enum:
                - TELI
              type: string
              example: TELI
            payIDValue:
              description: PAY ID value representing a Telephone number
              type: string
              pattern: ^\+([1-9]{1}[0-9]{1,2})[0-9]+$
              minLength: 2
              maxLength: 30
              example: '+61412345678'
        - type: object
          description: PAY ID with Organisation number
          required:
            - payIDType
            - payIDValue
          properties:
            payIDType:
              description: PayID type representing an Organisation ID.
              enum:
                - ORGN
              type: string
              example: ORGN
            payIDValue:
              description: PAY ID value representing an Organisation number
              minLength: 2
              maxLength: 256
              example: ORG-12345
              type: string
              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
        - type: object
          description: PAY ID with Australian Business number
          required:
            - payIDType
            - payIDValue
          properties:
            payIDType:
              description: PayID type representing an Australian Business N=
umber (ABN).
              enum:
                - AUBN
              type: string
              example: AUBN
            payIDValue:
              description: PAY ID value representing an Australian Business=
 Number (ABN)
              type: string
              pattern: ^\d+$
              minLength: 9
              maxLength: 11
              example: '12345678910'
    EmailPayID:
      type: object
      description: PAY ID with email
      required:
        - payIDType
        - payIDValue
      properties:
        payIDType:
          description: PayID type representing an Email address.
          enum:
            - EMAL
          type: string
          example: EMAL
        payIDValue:
          description: PAY ID value representing an Email address
          minLength: 5
          maxLength: 256
          example: john.doe@example.com
          type: string
          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    TeliPayID:
      type: object
      description: PAY ID with telephone number
      required:
        - payIDType
        - payIDValue
      properties:
        payIDType:
          description: PayID type representing a Telephone number.
          enum:
            - TELI
          type: string
          example: TELI
        payIDValue:
          description: PAY ID value representing a Telephone number
          type: string
          pattern: ^\+([1-9]{1}[0-9]{1,2})[0-9]+$
          minLength: 2
          maxLength: 30
          example: '+61412345678'
    OrgnPayID:
      type: object
      description: PAY ID with Organisation number
      required:
        - payIDType
        - payIDValue
      properties:
        payIDType:
          description: PayID type representing an Organisation ID.
          enum:
            - ORGN
          type: string
          example: ORGN
        payIDValue:
          description: PAY ID value representing an Organisation number
          minLength: 2
          maxLength: 256
          example: ORG-12345
          type: string
          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    AubnPayID:
      type: object
      description: PAY ID with Australian Business number
      required:
        - payIDType
        - payIDValue
      properties:
        payIDType:
          description: PayID type representing an Australian Business Numbe=
r (ABN).
          enum:
            - AUBN
          type: string
          example: AUBN
        payIDValue:
          description: PAY ID value representing an Australian Business Num=
ber (ABN)
          type: string
          pattern: ^\d+$
          minLength: 9
          maxLength: 11
          example: '12345678910'
    PayIDTypeEmail:
      description: PayID type representing an Email address.
      enum:
        - EMAL
      type: string
      example: EMAL
    PayIDTypeTeli:
      description: PayID type representing a Telephone number.
      enum:
        - TELI
      type: string
      example: TELI
    PayIDTypeOrgn:
      description: PayID type representing an Organisation ID.
      enum:
        - ORGN
      type: string
      example: ORGN
    PayIDTypeAubn:
      description: PayID type representing an Australian Business Number (A=
BN).
      enum:
        - AUBN
      type: string
      example: AUBN
    PayIDValueEmail:
      description: PAY ID value representing an Email address
      minLength: 5
      maxLength: 256
      example: john.doe@example.com
      type: string
      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    PayIDValueTeli:
      description: PAY ID value representing a Telephone number
      type: string
      pattern: ^\+([1-9]{1}[0-9]{1,2})[0-9]+$
      minLength: 2
      maxLength: 30
      example: '+61412345678'
    PayIDValueOrgn:
      description: PAY ID value representing an Organisation number
      minLength: 2
      maxLength: 256
      example: ORG-12345
      type: string
      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    PayIDValueAubn:
      description: PAY ID value representing an Australian Business Number =
(ABN)
      type: string
      pattern: ^\d+$
      minLength: 9
      maxLength: 11
      example: '12345678910'
    AccountName:
      description: Account Name
      minLength: 1
      maxLength: 140
      example: Apple Tree
      type: string
      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
    AccountNumber:
      description: Account Number
      type: string
      pattern: ^[a-zA-Z\d.]+$
      minLength: 1
      maxLength: 28
      example: '01235674897'
    BankName:
      description: Name of Bank
      type: string
      pattern: ^[\w ]+$
      minLength: 1
      maxLength: 70
      example: Westpac Banking Corporation
    ServiceLevelIdentification:
      description: Service level Identification Code
      type: string
      enum:
        - AUBSB
    PaymentLimitSchemeType:
      type: string
      description: Payment scheme.
      enum:
        - NPP
        - DE
    ClientContext:
      description: Client context information
      type: object
      properties:
        channelType:
          description: |-
            Channel sending the request. Can be empty or null.
              e.g.
            - W1C_O_B_D_CP - W1C_O_A_D_SP
          type: string
          maxLength: 100
          pattern: ^[A-Z0-9_-]+$
security:
  - BasicAuth: []
paths:
  /healthcheck:
    get:
      tags:
        - HealthCheck
      description: retrieves HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        '200':
          description: healthcheck status
          content:
            application/json:
              schema:
                description: healthcheck status
                properties:
                  status:
                    type: string
                    enum:
                      - success
  /arrangements:
    get:
      description: This endpoint retrieve an enrich list of arrangements fo=
r the accounts the logged in user is entitled to see
      operationId: getArrangements
      tags:
        - getArrangements
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
        - name: arrangementStatus
          description: Account status. "ACTIVE" will fetch arrangements whi=
ch are active only. "ACTIVE_AND_INACTIVE" will fetch arrangements which are=
 Active and Inactive both. If user is not passing this query parameter then=
 default option of ACTIVE_AND_INACTIVE will be used.
          in: query
          required: false
          example: ACTIVE_AND_INACTIVE
          schema:
            type: string
            pattern: ^(ACTIVE|ACTIVE_AND_INACTIVE){1}$
            enum:
              - ACTIVE
              - ACTIVE_AND_INACTIVE
        - name: pdpQueryAction
          description: PDP Query Action. This field allows the client to sp=
ecify actions for the PDP query.
          in: query
          required: false
          example: VIEW_PAYMENT
          schema:
            type: string
            pattern: ^(VIEW_PAYMENT|INITIATE_PAYMENT|INITIATE_TRANSFER){1}$
            enum:
              - VIEW_PAYMENT
              - INITIATE_PAYMENT
              - INITIATE_TRANSFER
        - name: pageSize
          in: query
          description: |
            Number of entries to be returned in a single page.
          schema:
            type: integer
            format: int32
            minimum: 10
            maximum: 1000
            default: 1000
          required: false
          example: 100
        - name: pageKey
          in: query
          description: The key identifying the page of data to be returned
          schema:
            type: integer
            format: int32
            maximum: 1000
            default: 0
          required: false
        - name: sortBy
          in: query
          description: |
            A pre-defined set of named values to sort the results by.
            Use `+` for ascending and `-` for descending sorting.
          schema:
            type: string
            enum:
              - +accountId
              - '-accountId'
              - +accountName
              - '-accountName'
          required: false
          example: +accountId
      responses:
        '200':
          description: The retrieved arrangements for the inquired accounts
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      arrangements:
                        type: array
                        items:
                          description: Customer arrangement (account)
                          type: object
                          required:
                            - id
                            - accountNumber
                            - entityName
                            - accountName
                            - accountType
                            - status
                            - currencyCode
                            - currentBalance
                            - availableBalance
                            - overdraftLimit
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountNumber:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            entityName:
                              description: Arrangement owners' legal name
                              type: string
                              maxLength: 1000
                              pattern: ^[\w\- \/\'\(\)\&amp;\+\@]+$
                            accountName:
                              description: Arrangement alias name
                              type: string
                              maxLength: 1000
                              pattern: ^[\w\- \/\'\(\)\&amp;\+\@]+$
                            accountType:
                              description: Arrangement type; it is product =
name in master product system
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 1000
                            status:
                              description: Arrangement status; example-&gt;=
 ACTIVE, INACTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                            currencyCode:
                              description: Arrangement currency code; examp=
le -&gt; AUD
                              type: string
                              pattern: ^\w{3}$
                            currentBalance:
                              description: The current balance held for the=
 arrangement
                              type: string
                              anyOf:
                                - description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            availableBalance:
                              description: The available balance held for t=
he arrangement
                              type: string
                              anyOf:
                                - description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            overdraftLimit:
                              description: Arrangement available overdraft =
limit (credit limit)
                              type: string
                              pattern: ^\d{1,13}\.\d{1,4}$
                              example: '1000.0000'
                          example:
                            id: d0868661-b955-4e76-9f15-d97626f7df6b
                            accountNumber: 035845 103784254
                            entityName: Bayer Miller and MacGyver
                            accountName: Payroll
                            accountType: Corporate Investment Account
                            status: ACTIVE
                            currencyCode: AUD
                            currentBalance: '100.9'
                            availableBalance: '-150.55'
                            overdraftLimit: '100.00'
                      paging:
                        type: array
                        items:
                          type: object
                          properties:
                            id:
                              description: Paging Unique Id
                              type: string
                              maxLength: 3
                              pattern: ^\d+$
                              example: '1'
                            pageSize:
                              description: Number of items per page
                              type: integer
                              format: int32
                              example: 50
                            count:
                              description: Total number of items available
                              type: integer
                              format: int32
                              example: 160
                            previousPageKey:
                              description: Key for start of previous page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '0'
                            nextPageKey:
                              description: Key for start of next page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '2'
                            moreItems:
                              description: Indicator to show if there are m=
ore items available. If true, more records are available (by narrowing sear=
ch parameters)
                              type: boolean
                              example: true
                  result:
                    type: object
                    properties:
                      arrangements:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      arrangements:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
  /paymentCreate:
    post:
      tags:
        - paymentCreate
      description: |
        This endpoint initiate a payment
      operationId: paymentCreate
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: x-idempotency-key
          in: header
          description: A unique identifier for a transaction to support ide=
mpotency checks
          schema:
            type: string
            description: A unique identifier
            format: uuid
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
          required: true
        - name: x-channelRequestId
          in: header
          description: |
            Unique identifier for the request authorisation. This is used t=
o correlate the request in the maker-checker.
            This is generated by the channels and should be unique across a=
ll requests.
          required: true
          schema:
            description: Pattern for the channel request ID
            type: string
            pattern: ^[\w-]{15,36}$
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        required: true
        description: Initiate the payment throught FIS POM API and return t=
he code for success or error
        content:
          application/json:
            schema:
              description: Payment details object for initiating a payment.
              type: object
              properties:
                clientContext:
                  type: object
                  properties:
                    channelType:
                      description: |-
                        Channel sending the request. Can be empty or null.
                          e.g.
                        - W1C_O_B_D_CP - W1C_O_A_D_SP
                      type: string
                      maxLength: 100
                      pattern: ^[A-Z0-9_-]+$
                creditTransferTransactionInformation:
                  type: array
                  items:
                    description: Provides information on the individual tra=
nsaction(s) included in the message.
                    type: object
                    properties:
                      creditor:
                        type: object
                        properties:
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. (Creditor name or Alias Sho=
rt Name).&lt;br&gt; Usage- Caller to map creditor's name to this field.
                            maxLength: 140
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                        required:
                          - name
                      creditorAccount:
                        type: object
                        description: Provides the details to identify an ac=
count.
                        properties:
                          identification:
                            description: Full account number including BSB =
(without any separators or spaces).&lt;br&gt; Usage- Caller to map debit ac=
count number to this field.
                            maxLength: 34
                            type: string
                            pattern: ^[A-Za-z0-9\.]+$
                          issuer:
                            description: Entity that assigns the identifica=
tion.&lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number o=
f the debit account.
                            type: string
                            maxLength: 6
                            pattern: ^\d{6}$
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. For NPP payment, this is th=
e Full Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this =
field is expected to be provided by the payment enrichment system.
                            maxLength: 70
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                          schemeName:
                            description: |-
                              Name of the identification scheme, in a coded=
 form as published in an external list.&lt;br&gt;
                               Usage- Caller to set this field to 'BBAN' to=
 represent Australian Bank-State-Branch Code (BSB) identification.
                            maxLength: 4
                            type: string
                            pattern: ^\w+$
                          type:
                            description: Debtor's account type represented =
as Canonical Product Code (CPC).&lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^\w+$
                      creditorAgent:
                        type: object
                        properties:
                          BICFI:
                            description: Code allocated to a financial inst=
itution by the ISO 9362 Registration Authority as described in ISO 9362 "Ba=
nking - Banking telecommunication messages - Business identifier code (BIC)=
".&lt;br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SON=
E'.
                            type: string
                            maxLength: 11
                            pattern: ^\w+$
                          financialInstitutionIdentification:
                            type: object
                            properties:
                              clearingSystemMemberIdentification:
                                description: Unique identification of a cle=
aring system member.
                                type: object
                                properties:
                                  clearingSystemIdentification:
                                    type: object
                                    properties:
                                      code:
                                        description: Service level Identifi=
cation Code
                                        type: string
                                        enum:
                                          - AUBSB
                        required:
                          - BICFI
                      endToEndIdentification:
                        description: A reference assigned by the initiating=
 party to unambiguously identify the payment. This identifier is passed on =
unchanged throughout the entire end-to-end payment flow. The end-to-end ide=
ntification can be used for reconciliation or to link tasks relating to the=
 payment. It can be included in several messages related to the payment.&lt=
;br&gt; Example- INV-123456790&lt;br&gt; Usage- Caller to map customer's pa=
yment reference to this field.  For NPP Osko payments. May only be provided=
 if customerType in the header is set to 'Organisation'. Must be set to 'NO=
TPROVIDED' if customerType in the header is set to 'Individual'.
                        maxLength: 35
                        example: INV-123456790
                        type: string
                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[=
\s\S]*$
                      instructedAmount:
                        description: This object will be deprecated from Ma=
y-2026-ERM release. Use CurrencyAmount definition instead.
                        type: object
                        deprecated: true
                        properties:
                          amount:
                            description: The payment amount before deductio=
n of charges, expressed in the currency as ordered by the initiating party.=
&lt;br&gt; Usage- Caller to map payment amount to this field.
                            type: string
                            pattern: \d{1,13}\.?\d{0,3}$
                          currency:
                            description: A code allocated to a currency by =
a Maintenance Agency under an international identification scheme, as descr=
ibed in the latest edition of the international standard ISO 4217 =E2=80=9C=
Codes for the representation of currencies and funds=E2=80=9D.&lt;br&gt; Us=
age- Caller to set 'AUD' to this field.
                            type: string
                            pattern: ^[A-Z]{3}$
                            example: AUD
                        required:
                          - amount
                          - currency
                      instructionForDebtorAgent:
                        description: Further information related to the pro=
cessing of the payment instruction, that may need to be acted upon by the d=
ebtor agent, depending on agreement between debtor and the debtor agent. Wh=
en present, it applies to ALL credit transfer transaction information occur=
rences, present in the payment information. &lt;br&gt; Usage- For future us=
e.
                        maxLength: 140
                        type: string
                        pattern: /^[\w\-]+$/
                      paymentTypeInformation:
                        description: Set of elements used to further specif=
y the type of transaction.
                        type: object
                        properties:
                          categoryPurpose:
                            description: Specifies the high-level purpose o=
f the instruction based on a set of pre-defined categories. This is used by=
 the initiating party to provide information concerning the processing of t=
he payment. &lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^[\w ]+$
                          instructionPriority:
                            description: |-
                              Indicator of the urgency or order of importan=
ce that the instructing party would like the instructed party to apply to t=
he processing of the instruction. The possible values are-&lt;br&gt;
                                HIGH: High. &lt;br&gt;
                                NORM: Normal.&lt;br&gt;
                                Usage- For future use.
                            enum:
                              - HIGH
                              - NORM
                            type: string
                          serviceLevel:
                            description: |-
                              Specifies a pre-agreed service or level of se=
rvice between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Att=
ended payments are defined as Payments whereby the sending participant requ=
ires a real-time response to their payment instruction&lt;br&gt; UNAT - For=
 'Unattended' transaction. Unattended payments are defined as Payments wher=
eby the sending participant does not require a real-time response to their =
payment instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&l=
t;br&gt;
                              creditTransferInformation Description - Speci=
fies a pre-agreed service or level of service between the parties.&lt;br&gt=
;
                              Usage- Caller to set this field to 'npp.clear=
.01-x2p1.01' for NPP Osko payments.
                            maxLength: 35
                            type: string
                            pattern: /^[\w\.\-]+$/
                      remittanceInformation:
                        description: Remittance information to be supplied =
with the payment.
                        type: object
                        properties:
                          unstructured:
                            type: array
                            maxItems: 2
                            description: Information supplied to enable the=
 matching/reconciliation of an entry with the items that the payment is int=
ended to settle, such as commercial invoices in an accounts'' receivable sy=
stem.
                            items:
                              maxLength: 140
                              description: Matches any string, including Un=
icode characters, and emoji, except semicolon (;), double hyphen (--), left=
 and right curly bracket ({ }), less than (&lt;),  greater than (&gt;), per=
centage sign (%), hash (#), quotation mark ("), and equal sign (=3D).  Use =
for fields that are protected by perfect express sanitizer library
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                      supplementaryData:
                        description: Additional Westpac Data Elements to su=
pport the PAYMENT transaction (Credit).
                        type: object
                        properties:
                          isNewPayee:
                            type: boolean
                            description: Indicates whether the payment is f=
or an existing beneficiary or a new/unsaved beneficiary.
                            example: false
                          aliasId:
                            description: |-
                              aka Payment Alias also known as PayID.  This =
field will be populated if there was a payId type payment,
                              &lt;br&gt;Usage format-
                                 &lt;br&gt;For type TELI-  The telephone nu=
mber must consist of a =E2=80=9C+=E2=80=9D followed by the country code (fr=
om 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any combina=
tion of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1=
,1}[0-9]{1,29}$ Example- +61-123456789
                                &lt;br&gt; For type EMAL- Consists of a cha=
racter string with a maximum length of 256 characters. This must include th=
e =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and no wh=
ite spaces. Only lower case characters will be supported.
                                 Format pattern- Maximum of 256 characters =
^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-=
]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)=
$ Example- 123@NPP.com
                                &lt;br&gt; For type AUBN- This is assigned =
by the Australian Taxation Office to identify an individual Australian Busi=
ness. Consists of a nine-to-eleven digit number. If the length is 9 digits =
than the last digit is the check digit. If the length is 11 digits, then an=
 algorithm is used to validate the entire value as there is no check digit =
as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                 &lt;br&gt; For type ORGN- The Identifier m=
ust be representative of the company name, organisation name, trading name,=
 associated product, campaign or an identifier recognisable as associated w=
ith the specific business or organisation, with no whitespace at the beginn=
ing or end. Maximum of 256 characters in lower case, to be drawn from Print=
able ASCII (decimal 32-126) and without leading or trailing whitespace. For=
 avoidance of doubt, upper case letters (A-Z, decimal 65-90) are excluded.
                                 Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!=
-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                            maxLength: 256
                            type: string
                            pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}=
~\.\x20-\x7E\+\-]+$
                            example: tay.tay@westpac.com.au
                          aliasType:
                            description: |-
                              For a PayID payment, the type of the PayID.
                                &lt;br&gt;TELI- Telephone Number
                                &lt;br&gt;EMAL- Email Address
                                &lt;br&gt;AUBN- Australian Business Number
                                &lt;br&gt;ORGN- Organisation ID
                            maxLength: 4
                            enum:
                              - EMAL
                              - TELI
                              - AUBN
                              - ORGN
                            type: string
                          beneficiaryId:
                            description: Usage- Caller to map this field wi=
th the Beneficiary Id of the recipient for the On-Platform payment
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    required:
                      - instructedAmount
                      - creditor
                      - creditorAgent
                debtor:
                  description: Party that owes an amount of money to the (u=
ltimate) creditor.
                  type: object
                  properties:
                    identification:
                      description: Unique and unambiguous identification of=
 a person. For example, CIS Key of the debtor account.&lt;br&gt; Usage- Cal=
ler to map debtor's identification to this field.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    issuer:
                      description: Entity that assigns the identification. =
 Example- WPAC &lt;br&gt; Usage- Caller to set this field to 'WPAC'.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify sending party.&lt;br&gt; Usage- Caller to map=
 debtor's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                debtorAccount:
                  required:
                    - identification
                    - schemeName
                    - issuer
                  type: object
                  description: Provides the details to identify an account.
                  properties:
                    identification:
                      description: Full account number including BSB (witho=
ut any separators or spaces).&lt;br&gt; Usage- Caller to map debit account =
number to this field.
                      maxLength: 34
                      type: string
                      pattern: ^[A-Za-z0-9\.]+$
                    issuer:
                      description: Entity that assigns the identification.&=
lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number of the =
debit account.
                      type: string
                      maxLength: 6
                      pattern: ^\d{6}$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify that party. For NPP payment, this is the Full=
 Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this field =
is expected to be provided by the payment enrichment system.
                      maxLength: 70
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                    schemeName:
                      description: |-
                        Name of the identification scheme, in a coded form =
as published in an external list.&lt;br&gt;
                         Usage- Caller to set this field to 'BBAN' to repre=
sent Australian Bank-State-Branch Code (BSB) identification.
                      maxLength: 4
                      type: string
                      pattern: ^\w+$
                    type:
                      description: Debtor's account type represented as Can=
onical Product Code (CPC).&lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^\w+$
                debtorAgent:
                  type: object
                  properties:
                    BICFI:
                      description: Code allocated to a financial institutio=
n by the ISO 9362 Registration Authority as described in ISO 9362 "Banking =
- Banking telecommunication messages - Business identifier code (BIC)".&lt;=
br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SONE'.
                      type: string
                      maxLength: 11
                      pattern: ^\w+$
                    financialInstitutionIdentification:
                      type: object
                      properties:
                        clearingSystemMemberIdentification:
                          description: Unique identification of a clearing =
system member.
                          type: object
                          properties:
                            clearingSystemIdentification:
                              type: object
                              properties:
                                code:
                                  description: Service level Identification=
 Code
                                  type: string
                                  enum:
                                    - AUBSB
                  required:
                    - BICFI
                initiatingParty:
                  description: Party that initiates the payment. This can e=
ither be the debtor or the party that initiates the credit transfer on beha=
lf of the debtor.
                  type: object
                  properties:
                    name:
                      description: Initiating party's full name.&lt;br&gt;U=
sage- Caller to map initiating party's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                instructionForDebtorAgent:
                  description: Further information related to the processin=
g of the payment instruction, that may need to be acted upon by the debtor =
agent, depending on agreement between debtor and the debtor agent. When pre=
sent, it applies to ALL credit transfer transaction information occurrences=
, present in the payment information. &lt;br&gt; Usage- For future use.
                  maxLength: 140
                  type: string
                  pattern: /^[\w\-]+$/
                paymentInformation:
                  description: Set of characteristics that applies to the p=
ayment instruction.
                  type: object
                  properties:
                    numberOfTransactions:
                      description: Number of individual transactions contai=
ned in the payment information group.&lt;br&gt; Usage- Caller to set this f=
ield to 1 to indicate there's only one transaction in the payment. For Bulk=
 payment in the future, this field will need to be set by the caller to the=
 actual number of transactions in the bulk instruction.
                      pattern: '[0-9]{1,15}$'
                      type: string
                paymentMethod:
                  description: Specifies the means of payment that will be =
used to move the amount of money.&lt;br&gt; Usage- Caller to set this field=
 to 'TRF'.
                  type: string
                  enum:
                    - TRF
                    - CHK
                    - TRA
                  example: TRF
                paymentTypeInformation:
                  description: Set of elements used to further specify the =
type of transaction.
                  type: object
                  properties:
                    categoryPurpose:
                      description: Specifies the high-level purpose of the =
instruction based on a set of pre-defined categories. This is used by the i=
nitiating party to provide information concerning the processing of the pay=
ment. &lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    instructionPriority:
                      description: |-
                        Indicator of the urgency or order of importance tha=
t the instructing party would like the instructed party to apply to the pro=
cessing of the instruction. The possible values are-&lt;br&gt;
                          HIGH: High. &lt;br&gt;
                          NORM: Normal.&lt;br&gt;
                          Usage- For future use.
                      enum:
                        - HIGH
                        - NORM
                      type: string
                    serviceLevel:
                      description: |-
                        Specifies a pre-agreed service or level of service =
between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Attended =
payments are defined as Payments whereby the sending participant requires a=
 real-time response to their payment instruction&lt;br&gt; UNAT - For 'Unat=
tended' transaction. Unattended payments are defined as Payments whereby th=
e sending participant does not require a real-time response to their paymen=
t instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&lt;br&g=
t;
                        creditTransferInformation Description - Specifies a=
 pre-agreed service or level of service between the parties.&lt;br&gt;
                        Usage- Caller to set this field to 'npp.clear.01-x2=
p1.01' for NPP Osko payments.
                      maxLength: 35
                      type: string
                      pattern: /^[\w\.\-]+$/
                supplementaryData:
                  description: Additional Westpac Data Elements to support =
the PAYMENT Instruction (Debit).
                  type: object
                  allOf:
                    - type: object
                      properties:
                        divisionName:
                          description: Division Name
                          example: AUD Group
                          maxLength: 70
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        divisionId:
                          description: Division id
                          type: string
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    - type: object
                      properties:
                        debitDescription:
                          description: The reference assigned by the sendin=
g party for the payment.&lt;br&gt;Usage- Caller to map debit description (s=
tatement narrative) to this field.
                          maxLength: 35
                          type: string
                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).=
*[\s\S]*$
                        instructionTraceIdentification:
                          type: string
                          description: UUId to uniquely identify the paymen=
t instruction.
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                        matchedCOPStatusCode:
                          description: ERDM encoded value
                          type: string
                          pattern: ^V[012AET]C[1-8]$
                          example: V0C1
                        matchedCOPAccountName:
                          description: Account Name
                          minLength: 1
                          maxLength: 140
                          example: Apple Tree
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        paymentProductId:
                          description: Product Id associated with the payme=
nt instruction.&lt;br&gt; Usage- Caller to map product id to this field.
                          type: string
                          enum:
                            - PP000020
                            - PP000004
                            - PP000016
                            - PP000012
                            - PP000005
                entitlementData:
                  type: object
                  description: Entitlement data for SAFI integration
                  properties:
                    supplementaryData:
                      type: array
                      description: |
                        Additional data required for SAFI. Each item is a n=
ame/value/datatype triple.
                        Required fields for all payments:
                        - NEWPAYEE (BOOLEAN, send as string 'TRUE'/'FALSE')
                        - W1C_CURRENCY (STRING)
                        - CURRENCY_FROM (STRING)
                        - CROSS_CURRENCY_PAYMENT (BOOLEAN, send as string '=
TRUE'/'FALSE')
                        - W1_2FADEVICETYPE (STRING)
                        - TENANT (STRING)
                        - PAYMENT_REFNO (STRING, use x-channelRequestId)
                        Conditional fields (add only if applicable):
                        - PAYEEPAYIDTYPE, PAYEEPAYIDVALUE, PAYEEPAYIDSHORTN=
AME (STRING, if beneficiary uses PayID)
                        - PAYEEDESTINATIONACCOUNT [BSB + account number], P=
AYEEPAYIDACCOUNTTYPE [BSB] (STRING, if beneficiary uses account type)
                        For boolean fields, use string values 'TRUE' or 'FA=
LSE'.
                      items:
                        oneOf:
                          - type: object
                            description: W1_2FADEVICETYPE field (must be 'S=
OFT TOKEN')
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1_2FADEVICETYPE
                              value:
                                type: string
                                enum:
                                  - SOFT TOKEN
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: TENANT field (must be 'TREASURY')
                            properties:
                              name:
                                type: string
                                enum:
                                  - TENANT
                              value:
                                type: string
                                enum:
                                  - TREASURY
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: W1C_CURRENCY field (currency code)
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1C_CURRENCY
                              value:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: CURRENCY_FROM field (currency code=
)
                            properties:
                              name:
                                type: string
                                enum:
                                  - CURRENCY_FROM
                              value:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEDESTINATIONACCOUNT field (BSB=
 + account number)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEDESTINATIONACCOUNT
                              value:
                                description: Full account number with forma=
t &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                type: string
                                pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                maxLength: 35
                                example: 035845 103784254
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYMENT_REFNO field
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYMENT_REFNO
                              value:
                                type: string
                                pattern: ^\w+$
                                maxLength: 36
                                description: A unique id generated to refer=
ence a specific payment transaction
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDTYPE field (PayID type)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDTYPE
                              value:
                                type: string
                                enum:
                                  - MOBILE
                                  - EMAIL
                                  - LANDLINE
                                  - ABN
                                  - FREEFORM
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDVALUE field (PayID value=
 - supports email, phone, ABN, orgn formats)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDVALUE
                              value:
                                description: |-
                                  aka Payment Alias also known as PayID.  T=
his field will be populated if there was a payId type payment,
                                  &lt;br&gt;Usage format-
                                     &lt;br&gt;For type TELI-  The telephon=
e number must consist of a =E2=80=9C+=E2=80=9D followed by the country code=
 (from 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any com=
bination of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-=
9]{1,1}[0-9]{1,29}$ Example- +61-123456789
                                    &lt;br&gt; For type EMAL- Consists of a=
 character string with a maximum length of 256 characters. This must includ=
e the =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and n=
o white spaces. Only lower case characters will be supported.
                                     Format pattern- Maximum of 256 charact=
ers ^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{=
|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9=
])?)$ Example- 123@NPP.com
                                    &lt;br&gt; For type AUBN- This is assig=
ned by the Australian Taxation Office to identify an individual Australian =
Business. Consists of a nine-to-eleven digit number. If the length is 9 dig=
its than the last digit is the check digit. If the length is 11 digits, the=
n an algorithm is used to validate the entire value as there is no check di=
git as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                     &lt;br&gt; For type ORGN- The Identifi=
er must be representative of the company name, organisation name, trading n=
ame, associated product, campaign or an identifier recognisable as associat=
ed with the specific business or organisation, with no whitespace at the be=
ginning or end. Maximum of 256 characters in lower case, to be drawn from P=
rintable ASCII (decimal 32-126) and without leading or trailing whitespace.=
 For avoidance of doubt, upper case letters (A-Z, decimal 65-90) are exclud=
ed.
                                     Format pattern- ^[!-@[-~][ -@[-~]{0,25=
4}[!-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                                maxLength: 256
                                type: string
                                pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_=
`{|}~\.\x20-\x7E\+\-]+$
                                example: tay.tay@westpac.com.au
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDSHORTNAME field (PayID s=
hort name)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDSHORTNAME
                              value:
                                description: Matches any string, including =
Unicode characters, and emoji, except semicolon (;), double hyphen (--), le=
ft and right curly bracket ({ }), less than (&lt;),  greater than (&gt;), p=
ercentage sign (%), hash (#), quotation mark ("), and equal sign (=3D).  Us=
e for fields that are protected by perfect express sanitizer library
                                type: string
                                pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                                maxLength: 50
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDACCOUNTTYPE field (BSB o=
nly)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDACCOUNTTYPE
                              value:
                                type: string
                                maxLength: 6
                                pattern: ^\d{6}$
                                description: BSB for account.
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: CROSS_CURRENCY_PAYMENT field (must=
 be 'FALSE' for now). Once supported, can be expanded to include 'TRUE'.
                            properties:
                              name:
                                type: string
                                enum:
                                  - CROSS_CURRENCY_PAYMENT
                              value:
                                type: string
                                enum:
                                  - 'FALSE'
                                description: Cross-currency payments not su=
pported, must be FALSE
                              datatype:
                                type: string
                                enum:
                                  - BOOLEAN
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: NEWPAYEE field (TRUE or FALSE)
                            properties:
                              name:
                                type: string
                                enum:
                                  - NEWPAYEE
                              value:
                                type: string
                                enum:
                                  - 'TRUE'
                                  - 'FALSE'
                                description: Indicates if beneficiary is ne=
w
                              datatype:
                                type: string
                                enum:
                                  - BOOLEAN
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEE_NAME_CHECK_COLOUR field
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEE_NAME_CHECK_COLOUR
                              value:
                                type: string
                                description: PAYEE_NAME_CHECK_COLOUR value
                                enum:
                                  - Blue
                                  - Amber
                                  - Red
                                example: Blue
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                      example:
                        - name: W1_2FADEVICETYPE
                          value: SOFT TOKEN
                          datatype: STRING
                        - name: TENANT
                          value: TREASURY
                          datatype: STRING
                        - name: W1C_CURRENCY
                          value: AUD
                          datatype: STRING
                        - name: CROSS_CURRENCY_PAYMENT
                          value: 'FALSE'
                          datatype: BOOLEAN
                        - name: CURRENCY_FROM
                          value: AUD
                          datatype: STRING
                        - name: NEWPAYEE
                          value: 'FALSE'
                          datatype: BOOLEAN
                        - name: PAYMENT_REFNO
                          value: WP12345678901234567
                          datatype: STRING
                        - name: PAYEE_NAME_CHECK_COLOUR
                          value: Blue
                          datatype: STRING
              required:
                - clientContext
                - paymentMethod
                - initiatingParty
                - debtorAccount
                - creditTransferTransactionInformation
                - supplementaryData
      responses:
        '201':
          description: |
            Scenarios where Payment Initation API sends a full response wit=
h an ISO status:
              ACSC - Debit posted successfully. On-us credits, if any, post=
ed successfully. Off-us credits, if any, sent to the appropriate execution =
systems for clearing and settlement.
              RJCT - Payment rejected.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      paymentCreate:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Details Request.
                          type: object
                          properties:
                            creationDateTime:
                              description: Date and time at which the messa=
ge was created.
                              format: date-time
                              type: string
                            groupInformation:
                              description: Provides details on the original=
 group, to which the message refers
                              type: object
                              properties:
                                groupStatus:
                                  description: Specifies the ISO status at =
the group level.Usage- For future use.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
