<h3 id=3D"expgalaxypaymentv2-4.1.2.Responses">4.1.2. Responses</h3>
<div class=3D"table-wrap">
<table class=3D"relative-table wrapped confluenceTable" style=3D"width: 845=
.0px;">
<thead class=3D"">
<tr class=3D"">
<th style=3D"text-align: left;" class=3D"confluenceTh"><p><strong>Response =
Code</strong></p></th>
<th style=3D"text-align: left;" class=3D"confluenceTh"><p>Example</p></th>
<td class=3D"confluenceTd"><strong>Description</strong></td>
</tr>
</thead>
<colgroup class=3D"">
<col class=3D"" style=3D"width: 173.0px;">
<col class=3D"" style=3D"width: 642.0px;">
<col class=3D"" style=3D"width: 29.0px;">
</colgroup>
<tbody class=3D"">
<tr class=3D"">
<td style=3D"text-align: left;" class=3D"confluenceTd"><p><span class=3D"st=
atus-lozenge-span css-0"><span class=3D"css-cztx6i"><span class=3D"css-1et8=
jlg">201</span></span></span></p></td>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<div class=3D"content-wrapper">
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
