                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
  /validatePaymentLimits:
    post:
      tags:
        - Payment Limit
      description: |
        This endpoint will validate the following payment limits applicable=
 as part of the payment workflow request approval.
        Also, this route will deduct the user's and organisation channel cu=
mulative limits if the limits are not reached yet.

        - Cumulative Limits for a User (checker) and Organisation Channel
        - Transactional limits for a User (checker)
        - Other limits: DE Market limit (transactional limit) &amp; NPP Mar=
ket limit (transactional limit)
      operationId: postValidatePaymentLimits
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
        - name: x-idempotency-key
          in: header
          description: A unique identifier for a transaction to support ide=
mpotency checks
          schema:
            type: string
            description: A unique identifier
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
          required: true
      requestBody:
        required: true
        description: The channel ID to be validated for generating Payment =
Identifier
        content:
          application/json:
            schema:
              description: Request object for validating payment limits.
              type: object
              required:
                - instructionIdentification
                - scheme
                - settlementAmount
              properties:
                instructionIdentification:
                  type: string
                  description: Unique instructionTraceIdentifier for tracki=
ng limits check.
                  pattern: ^[0-9A-Za-z\-_.]+$
                  minLength: 2
                  maxLength: 100
                scheme:
                  description: Scheme type for the payment.
                  type: string
                  enum:
                    - NPP
                    - DE
                settlementAmount:
                  description: Object containing settlement amount and curr=
ency code.
                  type: object
                  required:
                    - value
                    - currencyCode
                  deprecated: true
                  properties:
                    currencyCode:
                      description: A code allocated to a currency by a Main=
tenance Agency under an international identification scheme, as described i=
n the latest edition of the international standard ISO 4217 =E2=80=9CCodes =
for the representation of currencies and funds=E2=80=9D.&lt;br&gt; Usage- C=
aller to set 'AUD' to this field.
                      type: string
                      pattern: ^[A-Z]{3}$
                      example: AUD
                    amount:
                      description: A positive number string of up to four d=
ecimal places (including zero). Must have at least one digit after the deci=
mal point.
                      type: string
                      pattern: ^\d{1,13}\.\d{1,4}$
                      example: '1000.0000'
                    position:
                      type: string
                      enum:
                        - CR
                        - DR
                      example: CR
      responses:
        '200':
          description: Validate Payment Limits Response Success response
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      validatePaymentLimits:
                        type: array
                        description: List of validate payment limits entiti=
es
                        items:
                          description: List of payment limit validation res=
ults
                          type: object
                          required:
                            - id
                            - isSuccess
                          properties:
                            id:
                              description: Unique identifier for the valida=
tion result
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            isSuccess:
                              description: Indicates if the payment limit v=
alidation was successful
                              type: boolean
                            code:
                              description: Error code for the validation
                              type: integer
                            message:
                              description: Message describing the validatio=
n result
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 100
                            details:
                              description: Additional details about the val=
idation result
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 100
                          example:
                            id: d0868661-b955-4e76-9f15-d97626f7df6b
                            isSuccess: false
                            code: 2302
                            message: Limit breaches for user transaction am=
ount
                            details: Settlement amount must be lower than t=
he users maximum transaction limit 3000
                  result:
                    type: object
                    description: Result object containing validation result=
s
                    properties:
                      validatePaymentLimits:
                        description: Entity result for validate payment lim=
its
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      validatePaymentLimits:
                        - 5ab2ba7e-8f5f-45dc-9bc6-0d18ffb53c2e
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
  /arrangementDetails:
    post:
      description: This endpoint retrieves an details of an arrangement for=
 the given account ID
      operationId: postArrangementDetails
      tags:
        - postArrangementDetails
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        description: The payment ID (receipt number) to be searched for the=
 payment details.
        content:
          application/json:
            schema:
              description: The account IDs that user is searching for
              type: object
              required:
                - accountIds
              properties:
                accountIds:
                  type: array
                  items:
                    type: object
                    description: Account ID (BSB and Account Number)
                    required:
                      - BSB
                      - accountNumber
                    properties:
                      BSB:
                        description: Bank State Branch Number
                        type: string
                        pattern: ^\d{6}$
                        example: '035845'
                      accountNumber:
                        description: Account Number
                        type: string
                        pattern: ^[a-zA-Z\d.]+$
                        minLength: 6
                        maxLength: 28
                        example: '01235674897'
                    example:
                      BSB: '035845'
                      accountNumber: '10235674897'
      responses:
        '200':
          description: The retrieved enriched arrangement for the specified=
 accountId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      arrangementDetails:
                        type: array
                        items:
                          description: Detailed Customer arrangement (accou=
nt)
                          type: object
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            entityName:
                              description: Entity Name
                              minLength: 1
                              maxLength: 250
                              example: Bayer, Miller and MacGyver
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            accountName:
                              description: Arrangement alias name
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                              maxLength: 50
                            accountType:
                              description: Account type; it is product name=
 in master product system
                              minLength: 1
                              maxLength: 250
                              example: Corporate Investment Account
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            status:
                              description: Status; example-&gt; ACTIVE, INA=
CTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                              example: ACTIVE
                            currencyCode:
                              description: A code allocated to a currency b=
y a Maintenance Agency under an international identification scheme, as des=
cribed in the latest edition of the international standard ISO 4217 =E2=80=
=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&gt;=
 Usage- Caller to set 'AUD' to this field.
                              type: string
                              pattern: ^[A-Z]{3}$
                              example: AUD
                            currentBalance:
                              description: The current balance held for the=
 arrangement
                              type: string
                              anyOf:
                                - description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            availableBalance:
                              description: The available balance held for t=
he arrangement
                              type: string
                              anyOf:
                                - description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            overdraftLimit:
                              description: Arrangement available overdraft =
limit (credit limit)
                              type: string
                              pattern: ^\d{1,13}\.\d{1,4}$
                              example: '1000.0000'
                            startDateTime:
                              description: Start Date for the arrangement c=
onverted to ISO 8601 format
                              type: string
                              format: date-time
                              example: '2024-01-28T15:27:49.732Z'
                            closedDateTime:
                              description: Start Date for the arrangement c=
onverted to ISO 8601 format
                              type: string
                              format: date-time
                              example: '2024-05-12T11:56:42.124Z'
                            accountLinks:
                              description: Contains list of account link
                              type: array
                              items:
                                description: The account link
                                required:
                                  - type
                                  - sourceAccountId
                                  - id
                                  - targetAccountId
                                type: object
                                properties:
                                  id:
                                    description: A unique identifier
                                    type: string
                                    pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5]=
[0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                                  sourceAccountId:
                                    type: object
                                    description: Account ID (BSB and Accoun=
t Number)
                                    required:
                                      - BSB
                                      - accountNumber
                                    properties:
                                      BSB:
                                        description: Bank State Branch Numb=
er
                                        type: string
                                        pattern: ^\d{6}$
                                        example: '035845'
                                      accountNumber:
                                        description: Account Number
                                        type: string
                                        pattern: ^[a-zA-Z\d.]+$
                                        minLength: 6
                                        maxLength: 28
                                        example: '01235674897'
                                    example:
                                      BSB: '035845'
                                      accountNumber: '10235674897'
                                  targetAccountId:
                                    type: object
                                    description: Account ID (BSB and Accoun=
t Number)
                                    required:
                                      - BSB
                                      - accountNumber
                                    properties:
                                      BSB:
                                        description: Bank State Branch Numb=
er
                                        type: string
                                        pattern: ^\d{6}$
                                        example: '035845'
                                      accountNumber:
                                        description: Account Number
                                        type: string
                                        pattern: ^[a-zA-Z\d.]+$
                                        minLength: 6
                                        maxLength: 28
                                        example: '01235674897'
                                    example:
                                      BSB: '035845'
                                      accountNumber: '10235674897'
                                  type:
                                    type: string
                                    description: Link type
                                    enum:
                                      - INTEREST_APPLICATION
                                      - BALANCE_OFFSET
                                    example: INTEREST_APPLICATION
                            debitRateWithinLimit:
                              description: Authorised debit interest
                              type: object
                              required:
                                - fixedVariableType
                                - calculationMethod
                              properties:
                                interestRate:
                                  type: number
                                  example: 0.0285
                                  description: Interest Rate, this field wi=
ll only be populated if `calculationMethod` is `FLAT`.
                                fixedVariableType:
                                  type: string
                                  enum:
                                    - FIXED
                                    - VARIABLE
                                  example: VARIABLE
                                calculationMethod:
                                  type: string
                                  enum:
                                    - TIER
                                    - BAND
                                    - FLAT
                                  example: BAND
                                  description: If value is `TIER` or `BAND`=
, the respective `...TierBands` field will be populated with the respective=
 rates.
                            debitRateWithinLimitTierBands:
                              description: Authorised debit interest Tiers =
/ Bands. This is populated if `debitRateWithinLimit.calculationMethod` is `=
TIER` or `BAND`.
                              type: array
                              items:
                                type: object
                                description: The different interest rates t=
hat are applicable based on range.
                                required:
                                  - startRange
                                  - endRange
                                  - interestRate
                                properties:
                                  startRange:
                                    type: number
                                    example: 0
                                  endRange:
                                    type: number
                                    example: 1000
                                  interestRate:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  spread:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  operator:
                                    type: string
                                    enum:
                                      - ADD
                                      - SUBTRACT
                                    example: ADD
                            debitRateAboveLimit:
                              description: Beyond authorised limit
                              type: object
                              required:
                                - fixedVariableType
                                - calculationMethod
                              properties:
                                interestRate:
                                  type: number
                                  example: 0.0285
                                  description: Interest Rate, this field wi=
ll only be populated if `calculationMethod` is `FLAT`.
                                fixedVariableType:
                                  type: string
                                  enum:
                                    - FIXED
                                    - VARIABLE
                                  example: VARIABLE
                                calculationMethod:
                                  type: string
                                  enum:
                                    - TIER
                                    - BAND
                                    - FLAT
                                  example: BAND
                                  description: If value is `TIER` or `BAND`=
, the respective `...TierBands` field will be populated with the respective=
 rates.
                            debitRateAboveLimitTierBands:
                              description: Beyond authorised limit Tiers / =
Bands. This is populated if `debitRateAboveLimit.calculationMethod` is `TIE=
R` or `BAND`.
                              type: array
                              items:
                                type: object
                                description: The different interest rates t=
hat are applicable based on range.
                                required:
                                  - startRange
                                  - endRange
                                  - interestRate
                                properties:
                                  startRange:
                                    type: number
                                    example: 0
                                  endRange:
                                    type: number
                                    example: 1000
                                  interestRate:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  spread:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  operator:
                                    type: string
                                    enum:
                                      - ADD
                                      - SUBTRACT
                                    example: ADD
                            debitRateAboveLimitOverride:
                              description: Unauthorised debit interest.
                              type: object
                              required:
                                - fixedVariableType
                                - calculationMethod
                              properties:
                                interestRate:
                                  type: number
                                  example: 0.0285
                                  description: Interest Rate, this field wi=
ll only be populated if `calculationMethod` is `FLAT`.
                                fixedVariableType:
                                  type: string
                                  enum:
                                    - FIXED
                                    - VARIABLE
                                  example: VARIABLE
                                calculationMethod:
                                  type: string
                                  enum:
                                    - TIER
                                    - BAND
                                    - FLAT
                                  example: BAND
                                  description: If value is `TIER` or `BAND`=
, the respective `...TierBands` field will be populated with the respective=
 rates.
                            debitRateAboveLimitOverrideTierBands:
                              description: Unauthorised debit interest Tier=
s / Bands. This is populated if `debitRateAboveLimitOverride.calculationMet=
hod` is `TIER` or `BAND`.
                              type: array
                              items:
                                type: object
                                description: The different interest rates t=
hat are applicable based on range.
                                required:
                                  - startRange
                                  - endRange
                                  - interestRate
                                properties:
                                  startRange:
                                    type: number
                                    example: 0
                                  endRange:
                                    type: number
                                    example: 1000
                                  interestRate:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  spread:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  operator:
                                    type: string
                                    enum:
                                      - ADD
                                      - SUBTRACT
                                    example: ADD
                            creditRate:
                              description: Credit interest
                              type: object
                              required:
                                - fixedVariableType
                                - calculationMethod
                              properties:
                                interestRate:
                                  type: number
                                  example: 0.0285
                                  description: Interest Rate, this field wi=
ll only be populated if `calculationMethod` is `FLAT`.
                                fixedVariableType:
                                  type: string
                                  enum:
                                    - FIXED
                                    - VARIABLE
                                  example: VARIABLE
                                calculationMethod:
                                  type: string
                                  enum:
                                    - TIER
                                    - BAND
                                    - FLAT
                                  example: BAND
                                  description: If value is `TIER` or `BAND`=
, the respective `...TierBands` field will be populated with the respective=
 rates.
                            creditRateTierBands:
                              description: Credit interest Tiers / Bands. T=
his is populated if `creditRate.calculationMethod` is `TIER` or `BAND`. If =
`creditRate.calculationMethod` is `FLAT`, this will be undefined.
                              type: array
                              items:
                                type: object
                                description: The different interest rates t=
hat are applicable based on range.
                                required:
                                  - startRange
                                  - endRange
                                  - interestRate
                                properties:
                                  startRange:
                                    type: number
                                    example: 0
                                  endRange:
                                    type: number
                                    example: 1000
                                  interestRate:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  spread:
                                    description: Percentage value with 1-2 =
digits before the decimal point and 1-4 digits after
                                    type: string
                                    pattern: ^\d{1,2}\.\d{1,4}$
                                    example: '12.3456'
                                  operator:
                                    type: string
                                    enum:
                                      - ADD
                                      - SUBTRACT
                                    example: ADD
                            creditRateCompoundingFrequency:
                              type: object
                              description: Interest Compounding Frequency (=
Set on product level in Bank Manager). This is the value displayed as 'Inte=
rest Accrual Cycle'
                              required:
                                - frequencyType
                              properties:
                                day:
                                  description: Day of the month in numeric =
string format
                                  type: string
                                  pattern: ^([1-9]|[12][0-9]|3[01])$
                                  example: '6'
                                dayOfWeek:
                                  description: Day of the week in three-let=
ter uppercase abbreviation format
                                  type: string
                                  enum:
                                    - MON
                                    - TUE
                                    - WED
                                    - THU
                                    - FRI
                                    - SAT
                                    - SUN
                                frequencyType:
                                  type: string
                                  description: Indicates the frequency type=
 - DAILY (every day), WEEKLY_DAY (on the specified day each week), ANNIVERS=
ARY_OF_ACCOUNT (monthly or annual), MONTH (on the specified day of the mont=
h)
                                  enum:
                                    - TRIGGERED_DAILY
                                    - MONTHLY_ANNIVERSARY
                                    - ON_ACCOUNT_CLOSING
                                    - WEEKLY_DAY
                                    - DAILY
                                    - PER_OCCURRENCE
                                    - MONTH_BEGINNING
                                    - MONTH_END
                                    - MONTH_ANNIVERSARY_OF_ACCOUNT
                                    - ANNUAL_ANNIVERSARY_OF_ACCOUNT
                                    - WEEKLY
                                    - MONTH
                                    - ANNUAL
                                    - DAYS_FROM_CALCULATION
                                month:
                                  description: Month in three-letter upperc=
ase abbreviation format
                                  type: string
                                  enum:
                                    - JAN
                                    - FEB
                                    - MAR
                                    - APR
                                    - MAY
                                    - JUN
                                    - JUL
                                    - AUG
                                    - SEP
                                    - OCT
                                    - NOV
                                    - DEC
                                year:
                                  description: The relevant financial year
                                  type: string
                                  pattern: ^\d{4}$
                                  example: '2025'
                  result:
                    type: object
                    properties:
                      arrangementDetails:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      arrangementDetails:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /accountList:
    get:
      description: This endpoint retrieves all accounts from PDP(Entitlemen=
ts) that the user is entitled to view. And if an account group id is suppli=
ed, the endpoint will retrieve all accounts from PDP(Entitlements) the user=
 is entitled to view for the supplied account ID.
      operationId: getAccountList
      tags:
        - getAccountList
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: groupId
          in: query
          required: false
          description: Group ID used for filtering results
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: pdpQueryAction
          description: PDP Query Action. This field allows the client to sp=
ecify actions for the PDP query.
          in: query
          required: false
          example: VIEW_PAYMENT
          schema:
            type: string
            pattern: ^(VIEW_PAYMENT|INITIATE_PAYMENT|INITIATE_TRANSFER){1}$
            enum:
              - VIEW_PAYMENT
              - INITIATE_PAYMENT
              - INITIATE_TRANSFER
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
        - name: accountStatus
          description: Account status. "ACTIVE" will fetch arrangements whi=
ch are active only. "ACTIVE_AND_INACTIVE" will fetch accounts which are bot=
h Active and Inactive. If no parameter is passed, the default option of ACT=
IVE_AND_INACTIVE will be used.
          in: query
          required: false
          example: ACTIVE_AND_INACTIVE
          schema:
            type: string
            default: ACTIVE_AND_INACTIVE
            enum:
              - ACTIVE
              - ACTIVE_AND_INACTIVE
        - name: divisionId
          in: query
          required: false
          description: Division ID used for returning account associated wi=
th that division
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
      responses:
        '200':
          description: The retrieved accountList for the user / groupId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      accountList:
                        type: array
                        items:
                          type: object
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            accountName:
                              description: Account Name
                              minLength: 1
                              maxLength: 140
                              example: Apple Tree
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            accountType:
                              description: Account type; it is product name=
 in master product system
                              minLength: 1
                              maxLength: 250
                              example: Corporate Investment Account
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            status:
                              description: Status; example-&gt; ACTIVE, INA=
CTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                              example: ACTIVE
                            currencyCode:
                              description: A code allocated to a currency b=
y a Maintenance Agency under an international identification scheme, as des=
cribed in the latest edition of the international standard ISO 4217 =E2=80=
=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&gt;=
 Usage- Caller to set 'AUD' to this field.
                              type: string
                              pattern: ^[A-Z]{3}$
                              example: AUD
                  result:
                    type: object
                    properties:
                      accountList:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      accountList:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /beneficiaryCreate:
    post:
      summary: create beneficiaries
      description: Create beneficiaries request
      operationId: createBeneficiaries
      tags:
        - Beneficiaries
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: x-channelRequestId
          in: header
          description: |
            Unique identifier for the request authorisation. This is used t=
o correlate the request in the maker-checker.
            This is generated by the channels and should be unique across a=
ll requests.
          required: true
          schema:
            description: Pattern for the channel request ID
            type: string
            pattern: ^[\w-]{15,36}$
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        description: Create beneficiaries request payload
        required: true
        content:
          application/json:
            schema:
              description: Represents Beneficiary Create Request Object
              type: object
              required:
                - beneficiaries
              properties:
                beneficiaries:
                  type: array
                  items:
                    description: Represents the request object for a benefi=
ciary.
                    allOf:
                      - type: object
                        properties:
                          divisionName:
                            description: Division Name
                            example: AUD Group
                            maxLength: 70
                            type: string
                            pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                          divisionId:
                            description: Division id
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                      - description: Represents the details object for a be=
neficiary.
                        type: object
                        properties:
                          id:
                            description: Unique id for the beneficiary.
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                          externalId:
                            description: External id for the beneficiary, u=
sed for cross-system references.
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                          nickname:
                            description: Beneficiary Nickname
                            type: string
                            example: John
                            minLength: 1
                            maxLength: 70
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                          status:
                            description: Status; example-&gt; ACTIVE, INACT=
IVE
                            type: string
                            enum:
                              - ACTIVE
                              - INACTIVE
                            example: ACTIVE
                          currencyAmount:
                            description: A qualified amount and denominatio=
n of a monetary value.
                            type: object
                            properties:
                              amount:
                                description: A positive or negative number =
string of up to four decimal places (including zero). Must have at least on=
e digit after the decimal point.
                                type: string
                                anyOf:
                                  - description: A positive number string o=
f up to four decimal places (including zero). Must have at least one digit =
after the decimal point.
                                    type: string
                                    pattern: ^\d{1,13}\.\d{1,4}$
                                    example: '1000.0000'
                                  - description: A negative number string o=
f up to four decimal places (including zero). Must have at least one digit =
after the decimal point.
                                    type: string
                                    pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                    example: '-1000.0000'
                              currencyCode:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                            required:
                              - currencyCode
                          org:
                            description: CIS Key of the organisation
                            type: string
                            example: '06089457589'
                            pattern: ^\d{11}$
                          type:
                            description: Beneficiary account type either Pa=
y id or BSB &amp; Account number
                            type: string
                            enum:
                              - PAYID
                              - BSB_ACCOUNT_NUMBER
                            example: BSB_ACCOUNT_NUMBER
                          reference:
                            description: Unique payment identifier for end-=
to-end transaction tracking and reconciliation.
                            maxLength: 35
                            example: INV-123456790
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                          account:
                            type: object
                            description: Represents Account detail object
                            oneOf:
                              - type: object
                                description: Object representing an account=
 identified by BSB, bank name, account name, and account number.
                                required:
                                  - accountId
                                  - bankName
                                  - accountName
                                properties:
                                  accountId:
                                    type: object
                                    description: Account ID (BSB and Accoun=
t Number)
                                    required:
                                      - BSB
                                      - accountNumber
                                    properties:
                                      BSB:
                                        description: Bank State Branch Numb=
er
                                        type: string
                                        pattern: ^\d{6}$
                                        example: '035845'
                                      accountNumber:
                                        description: Account Number
                                        type: string
                                        pattern: ^[a-zA-Z\d.]+$
                                        minLength: 6
                                        maxLength: 28
                                        example: '01235674897'
                                    example:
                                      BSB: '035845'
                                      accountNumber: '10235674897'
                                  accountName:
                                    description: Account Name
                                    minLength: 1
                                    maxLength: 140
                                    example: Apple Tree
                                    type: string
                                    pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                  bankName:
                                    description: Name of Bank
                                    minLength: 1
                                    maxLength: 70
                                    example: Westpac Banking Corporation
                                    type: string
                                    pattern: ^[\w ]+$
                              - type: object
                                description: Represents PayID object
                                oneOf:
                                  - type: object
                                    description: PAY ID with email
                                    required:
                                      - payIDName
                                      - payIDType
                                      - payIDValue
                                    properties:
                                      payIDName:
                                        description: Beneficiary Nickname
                                        type: string
                                        example: John
                                        minLength: 1
                                        maxLength: 70
                                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt=
;|%|#|"|=3D)).*[\s\S]*$
                                      payIDType:
                                        description: PayID type representin=
g an Email address.
                                        enum:
                                          - EMAL
                                        type: string
                                        example: EMAL
                                      payIDValue:
                                        description: PAY ID value represent=
ing an Email address
                                        minLength: 5
                                        maxLength: 256
                                        example: john.doe@example.com
                                        type: string
                                        pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                  - type: object
                                    description: PAY ID with telephone numb=
er
                                    required:
                                      - payIDName
                                      - payIDType
                                      - payIDValue
                                    properties:
                                      payIDName:
                                        description: Beneficiary Nickname
                                        type: string
                                        example: John
                                        minLength: 1
                                        maxLength: 70
                                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt=
;|%|#|"|=3D)).*[\s\S]*$
                                      payIDType:
                                        description: PayID type representin=
g a Telephone number.
                                        enum:
                                          - TELI
                                        type: string
                                        example: TELI
                                      payIDValue:
                                        description: PAY ID value represent=
ing a Telephone number
                                        type: string
                                        pattern: ^\+([1-9]{1}[0-9]{1,2})[-]=
{0,1}[0-9]+$
                                        minLength: 2
                                        maxLength: 30
                                        example: '+61412345678'
                                  - type: object
                                    description: PAY ID with Organisation n=
umber
                                    required:
                                      - payIDName
                                      - payIDType
                                      - payIDValue
                                    properties:
                                      payIDName:
                                        description: Beneficiary Nickname
                                        type: string
                                        example: John
                                        minLength: 1
                                        maxLength: 70
                                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt=
;|%|#|"|=3D)).*[\s\S]*$
                                      payIDType:
                                        description: PayID type representin=
g an Organisation ID.
                                        enum:
                                          - ORGN
                                        type: string
                                        example: ORGN
                                      payIDValue:
                                        description: PAY ID value represent=
ing an Organisation number
                                        minLength: 2
                                        maxLength: 256
                                        example: ORG-12345
                                        type: string
                                        pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                  - type: object
                                    description: PAY ID with Australian Bus=
iness number
                                    required:
                                      - payIDName
                                      - payIDType
                                      - payIDValue
                                    properties:
                                      payIDName:
                                        description: Beneficiary Nickname
                                        type: string
                                        example: John
                                        minLength: 1
                                        maxLength: 70
                                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt=
;|%|#|"|=3D)).*[\s\S]*$
                                      payIDType:
                                        description: PayID type representin=
g an Australian Business Number (ABN).
                                        enum:
                                          - AUBN
                                        type: string
                                        example: AUBN
                                      payIDValue:
                                        description: PAY ID value represent=
ing an Australian Business Number (ABN)
                                        type: string
                                        pattern: ^\d+$
                                        minLength: 9
                                        maxLength: 11
                                        example: '12345678910'
                            example:
                              accountId:
                                accountNumber: '01235674897'
                                BSB: '035845'
                              accountName: Apple Tree
                              bankName: Westpac Banking Corporation
                      - type: object
                        properties:
                          matchedCOPStatusCode:
                            description: ERDM encoded value
                            type: string
                            pattern: ^V[012AET]C[1-8]$
                            example: V0C1
                          matchedCOPAccountName:
                            description: Account Name
                            minLength: 1
                            maxLength: 140
                            example: Apple Tree
                            type: string
                            pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                    required:
                      - id
                      - nickname
                      - type
                      - account
      responses:
        '201':
          description: beneficiary creation response
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      beneficiaryCreate:
                        type: array
                        items:
                          description: Represents the response object for a=
 beneficiary.
                          allOf:
                            - description: Represents the details object fo=
r a beneficiary.
                              type: object
                              properties:
                                id:
                                  description: Unique id for the beneficiar=
y.
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                                externalId:
                                  description: External id for the benefici=
ary, used for cross-system references.
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                                nickname:
                                  description: Beneficiary Nickname
                                  type: string
                                  example: John
                                  minLength: 1
                                  maxLength: 70
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                status:
                                  description: Status; example-&gt; ACTIVE,=
 INACTIVE
                                  type: string
                                  enum:
                                    - ACTIVE
                                    - INACTIVE
                                  example: ACTIVE
                                currencyAmount:
                                  description: A qualified amount and denom=
ination of a monetary value.
                                  type: object
                                  properties:
                                    amount:
                                      description: A positive or negative n=
umber string of up to four decimal places (including zero). Must have at le=
ast one digit after the decimal point.
                                      type: string
                                      anyOf:
                                        - description: A positive number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^\d{1,13}\.\d{1,4}$
                                          example: '1000.0000'
                                        - description: A negative number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^(?:-\d{1,13}|0)\.\d{1,4=
}$
                                          example: '-1000.0000'
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                  required:
                                    - currencyCode
                                org:
                                  description: CIS Key of the organisation
                                  type: string
                                  example: '06089457589'
                                  pattern: ^\d{11}$
                                type:
                                  description: Beneficiary account type eit=
her Pay id or BSB &amp; Account number
                                  type: string
                                  enum:
                                    - PAYID
                                    - BSB_ACCOUNT_NUMBER
                                  example: BSB_ACCOUNT_NUMBER
                                reference:
                                  description: Unique payment identifier fo=
r end-to-end transaction tracking and reconciliation.
                                  maxLength: 35
                                  example: INV-123456790
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                account:
                                  type: object
                                  description: Represents Account detail ob=
ject
                                  oneOf:
                                    - type: object
                                      description: Object representing an a=
ccount identified by BSB, bank name, account name, and account number.
                                      required:
                                        - accountId
                                        - bankName
                                        - accountName
                                      properties:
                                        accountId:
                                          type: object
                                          description: Account ID (BSB and =
Account Number)
                                          required:
                                            - BSB
                                            - accountNumber
                                          properties:
                                            BSB:
                                              description: Bank State Branc=
h Number
                                              type: string
                                              pattern: ^\d{6}$
                                              example: '035845'
                                            accountNumber:
                                              description: Account Number
                                              type: string
                                              pattern: ^[a-zA-Z\d.]+$
                                              minLength: 6
                                              maxLength: 28
                                              example: '01235674897'
                                          example:
                                            BSB: '035845'
                                            accountNumber: '10235674897'
                                        accountName:
                                          description: Account Name
                                          minLength: 1
                                          maxLength: 140
                                          example: Apple Tree
                                          type: string
                                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]=
*$
                                        bankName:
                                          description: Name of Bank
                                          minLength: 1
                                          maxLength: 70
                                          example: Westpac Banking Corporat=
ion
                                          type: string
                                          pattern: ^[\w ]+$
                                    - type: object
                                      description: Represents PayID object
                                      oneOf:
                                        - type: object
                                          description: PAY ID with email
                                          required:
                                            - payIDName
                                            - payIDType
                                            - payIDValue
                                          properties:
                                            payIDName:
                                              description: Beneficiary Nick=
name
                                              type: string
                                              example: John
                                              minLength: 1
                                              maxLength: 70
                                              pattern: ^(?!.*(;|--|\{|\}|&l=
t;|&gt;|%|#|"|=3D)).*[\s\S]*$
                                            payIDType:
                                              description: PayID type repre=
senting an Email address.
                                              enum:
                                                - EMAL
                                              type: string
                                              example: EMAL
                                            payIDValue:
                                              description: PAY ID value rep=
resenting an Email address
                                              minLength: 5
                                              maxLength: 256
                                              example: john.doe@example.com
                                              type: string
                                              pattern: ^[a-zA-Z0-9\- !,.:\;=
?_@]*$
                                        - type: object
                                          description: PAY ID with telephon=
e number
                                          required:
                                            - payIDName
                                            - payIDType
                                            - payIDValue
                                          properties:
                                            payIDName:
                                              description: Beneficiary Nick=
name
                                              type: string
                                              example: John
                                              minLength: 1
                                              maxLength: 70
                                              pattern: ^(?!.*(;|--|\{|\}|&l=
t;|&gt;|%|#|"|=3D)).*[\s\S]*$
                                            payIDType:
                                              description: PayID type repre=
senting a Telephone number.
                                              enum:
                                                - TELI
                                              type: string
                                              example: TELI
                                            payIDValue:
                                              description: PAY ID value rep=
resenting a Telephone number
                                              type: string
                                              pattern: ^\+([1-9]{1}[0-9]{1,=
2})[-]{0,1}[0-9]+$
                                              minLength: 2
                                              maxLength: 30
                                              example: '+61412345678'
                                        - type: object
                                          description: PAY ID with Organisa=
tion number
                                          required:
                                            - payIDName
                                            - payIDType
                                            - payIDValue
                                          properties:
                                            payIDName:
                                              description: Beneficiary Nick=
name
                                              type: string
                                              example: John
                                              minLength: 1
                                              maxLength: 70
                                              pattern: ^(?!.*(;|--|\{|\}|&l=
t;|&gt;|%|#|"|=3D)).*[\s\S]*$
                                            payIDType:
                                              description: PayID type repre=
senting an Organisation ID.
                                              enum:
                                                - ORGN
                                              type: string
                                              example: ORGN
                                            payIDValue:
                                              description: PAY ID value rep=
resenting an Organisation number
                                              minLength: 2
                                              maxLength: 256
                                              example: ORG-12345
                                              type: string
                                              pattern: ^[a-zA-Z0-9\- !,.:\;=
?_@]*$
                                        - type: object
                                          description: PAY ID with Australi=
an Business number
                                          required:
                                            - payIDName
                                            - payIDType
                                            - payIDValue
                                          properties:
                                            payIDName:
                                              description: Beneficiary Nick=
name
                                              type: string
                                              example: John
                                              minLength: 1
                                              maxLength: 70
                                              pattern: ^(?!.*(;|--|\{|\}|&l=
t;|&gt;|%|#|"|=3D)).*[\s\S]*$
                                            payIDType:
                                              description: PayID type repre=
senting an Australian Business Number (ABN).
                                              enum:
                                                - AUBN
                                              type: string
                                              example: AUBN
                                            payIDValue:
                                              description: PAY ID value rep=
resenting an Australian Business Number (ABN)
                                              type: string
                                              pattern: ^\d+$
                                              minLength: 9
                                              maxLength: 11
                                              example: '12345678910'
                                  example:
                                    accountId:
                                      accountNumber: '01235674897'
                                      BSB: '035845'
                                    accountName: Apple Tree
                                    bankName: Westpac Banking Corporation
                            - type: object
                              properties:
                                org:
                                  description: CIS Key of the organisation
                                  type: string
                                  example: '06089457589'
                                  pattern: ^\d{11}$
                                status:
                                  description: Beneficiary status; example-=
&gt; ACTIVE, ARCHIVED, ON-HOLD
                                  type: string
                                  enum:
                                    - ACTIVE
                                    - ARCHIVED
                                    - ON-HOLD
                                  example: ACTIVE
                  result:
                    type: object
                    properties:
                      beneficiaryCreate:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      beneficiaryCreate:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /paymentCreateForNewBeneficiary:
    post:
      tags:
        - postPaymentCreateForNewBeneficiary
      description: |
        This endpoint initiate a payment to new beneficiary
      operationId: postPaymentCreateForNewBeneficiary
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: x-idempotency-key
          in: header
          description: A unique identifier for a transaction to support ide=
mpotency checks
          schema:
            type: string
            description: A unique identifier
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
          required: true
        - name: x-channelRequestId
          in: header
          description: |
            Unique identifier for the request authorisation. This is used t=
o correlate the request in the maker-checker.
            This is generated by the channels and should be unique across a=
ll requests.
          required: true
          schema:
            description: Pattern for the channel request ID
            type: string
            pattern: ^[\w-]{15,36}$
      requestBody:
        required: true
        description: Initiate the payment through FIS POM API and return th=
e code for success or error
        content:
          application/json:
            schema:
              description: Payment details object for initiating a payment.
              type: object
              properties:
                clientContext:
                  type: object
                  properties:
                    channelType:
                      description: |-
                        Channel sending the request. Can be empty or null.
                          e.g.
                        - W1C_O_B_D_CP - W1C_O_A_D_SP
                      type: string
                      maxLength: 100
                      pattern: ^[A-Z0-9_-]+$
                creditTransferTransactionInformation:
                  type: array
                  items:
                    description: Provides information on the individual tra=
nsaction(s) included in the message.
                    type: object
                    properties:
                      creditor:
                        type: object
                        properties:
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. (Creditor name or Alias Sho=
rt Name).&lt;br&gt; Usage- Caller to map creditor's name to this field.
                            maxLength: 140
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                        required:
                          - name
                      creditorAccount:
                        type: object
                        description: Provides the details to identify an ac=
count.
                        properties:
                          identification:
                            description: Full account number including BSB =
(without any separators or spaces).&lt;br&gt; Usage- Caller to map debit ac=
count number to this field.
                            maxLength: 34
                            type: string
                            pattern: ^[A-Za-z0-9\.]+$
                          issuer:
                            description: Entity that assigns the identifica=
tion.&lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number o=
f the debit account.
                            type: string
                            maxLength: 6
                            pattern: ^\d{6}$
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. For NPP payment, this is th=
e Full Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this =
field is expected to be provided by the payment enrichment system.
                            maxLength: 70
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                          schemeName:
                            description: |-
                              Name of the identification scheme, in a coded=
 form as published in an external list.&lt;br&gt;
                               Usage- Caller to set this field to 'BBAN' to=
 represent Australian Bank-State-Branch Code (BSB) identification.
                            maxLength: 4
                            type: string
                            pattern: ^\w+$
                          type:
                            description: Debtor's account type represented =
as Canonical Product Code (CPC).&lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^\w+$
                      creditorAgent:
                        type: object
                        properties:
                          BICFI:
                            description: Code allocated to a financial inst=
itution by the ISO 9362 Registration Authority as described in ISO 9362 "Ba=
nking - Banking telecommunication messages - Business identifier code (BIC)=
".&lt;br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SON=
E'.
                            type: string
                            maxLength: 11
                            pattern: ^\w+$
                          financialInstitutionIdentification:
                            type: object
                            properties:
                              clearingSystemMemberIdentification:
                                description: Unique identification of a cle=
aring system member.
                                type: object
                                properties:
                                  clearingSystemIdentification:
                                    type: object
                                    properties:
                                      code:
                                        description: Service level Identifi=
cation Code
                                        type: string
                                        enum:
                                          - AUBSB
                        required:
                          - BICFI
                      endToEndIdentification:
                        description: A reference assigned by the initiating=
 party to unambiguously identify the payment. This identifier is passed on =
unchanged throughout the entire end-to-end payment flow. The end-to-end ide=
ntification can be used for reconciliation or to link tasks relating to the=
 payment. It can be included in several messages related to the payment.&lt=
;br&gt; Example- INV-123456790&lt;br&gt; Usage- Caller to map customer's pa=
yment reference to this field.  For NPP Osko payments. May only be provided=
 if customerType in the header is set to 'Organisation'. Must be set to 'NO=
TPROVIDED' if customerType in the header is set to 'Individual'.
                        maxLength: 35
                        example: INV-123456790
                        type: string
                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[=
\s\S]*$
                      instructedAmount:
                        description: This object will be deprecated from Ma=
y-2026-ERM release. Use CurrencyAmount definition instead.
                        type: object
                        deprecated: true
                        properties:
                          amount:
                            description: The payment amount before deductio=
n of charges, expressed in the currency as ordered by the initiating party.=
&lt;br&gt; Usage- Caller to map payment amount to this field.
                            type: string
                            pattern: \d{1,13}\.?\d{0,3}$
                          currency:
                            description: A code allocated to a currency by =
a Maintenance Agency under an international identification scheme, as descr=
ibed in the latest edition of the international standard ISO 4217 =E2=80=9C=
Codes for the representation of currencies and funds=E2=80=9D.&lt;br&gt; Us=
age- Caller to set 'AUD' to this field.
                            type: string
                            pattern: ^[A-Z]{3}$
                            example: AUD
                        required:
                          - amount
                          - currency
                      instructionForDebtorAgent:
                        description: Further information related to the pro=
cessing of the payment instruction, that may need to be acted upon by the d=
ebtor agent, depending on agreement between debtor and the debtor agent. Wh=
en present, it applies to ALL credit transfer transaction information occur=
rences, present in the payment information. &lt;br&gt; Usage- For future us=
e.
                        maxLength: 140
                        type: string
                        pattern: /^[\w\-]+$/
                      paymentTypeInformation:
                        description: Set of elements used to further specif=
y the type of transaction.
                        type: object
                        properties:
                          categoryPurpose:
                            description: Specifies the high-level purpose o=
f the instruction based on a set of pre-defined categories. This is used by=
 the initiating party to provide information concerning the processing of t=
he payment. &lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^[\w ]+$
                          instructionPriority:
                            description: |-
                              Indicator of the urgency or order of importan=
ce that the instructing party would like the instructed party to apply to t=
he processing of the instruction. The possible values are-&lt;br&gt;
                                HIGH: High. &lt;br&gt;
                                NORM: Normal.&lt;br&gt;
                                Usage- For future use.
                            enum:
                              - HIGH
                              - NORM
                            type: string
                          serviceLevel:
                            description: |-
                              Specifies a pre-agreed service or level of se=
rvice between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Att=
ended payments are defined as Payments whereby the sending participant requ=
ires a real-time response to their payment instruction&lt;br&gt; UNAT - For=
 'Unattended' transaction. Unattended payments are defined as Payments wher=
eby the sending participant does not require a real-time response to their =
payment instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&l=
t;br&gt;
                              creditTransferInformation Description - Speci=
fies a pre-agreed service or level of service between the parties.&lt;br&gt=
;
                              Usage- Caller to set this field to 'npp.clear=
.01-x2p1.01' for NPP Osko payments.
                            maxLength: 35
                            type: string
                            pattern: /^[\w\.\-]+$/
                      remittanceInformation:
                        description: Remittance information to be supplied =
with the payment.
                        type: object
                        properties:
                          unstructured:
                            type: array
                            maxItems: 2
                            description: Information supplied to enable the=
 matching/reconciliation of an entry with the items that the payment is int=
ended to settle, such as commercial invoices in an accounts'' receivable sy=
stem.
                            items:
                              maxLength: 140
                              description: Matches any string, including Un=
icode characters, and emoji, except semicolon (;), double hyphen (--), left=
 and right curly bracket ({ }), less than (&lt;),  greater than (&gt;), per=
centage sign (%), hash (#), quotation mark ("), and equal sign (=3D).  Use =
for fields that are protected by perfect express sanitizer library
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                      supplementaryData:
                        description: Additional Westpac Data Elements to su=
pport the PAYMENT transaction (Credit).
                        type: object
                        properties:
                          isNewPayee:
                            type: boolean
                            description: Indicates whether the payment is f=
or an existing beneficiary or a new/unsaved beneficiary.
                            example: false
                          aliasId:
                            description: |-
                              aka Payment Alias also known as PayID.  This =
field will be populated if there was a payId type payment,
                              &lt;br&gt;Usage format-
                                 &lt;br&gt;For type TELI-  The telephone nu=
mber must consist of a =E2=80=9C+=E2=80=9D followed by the country code (fr=
om 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any combina=
tion of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1=
,1}[0-9]{1,29}$ Example- +61-123456789
                                &lt;br&gt; For type EMAL- Consists of a cha=
racter string with a maximum length of 256 characters. This must include th=
e =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and no wh=
ite spaces. Only lower case characters will be supported.
                                 Format pattern- Maximum of 256 characters =
^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-=
]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)=
$ Example- 123@NPP.com
                                &lt;br&gt; For type AUBN- This is assigned =
by the Australian Taxation Office to identify an individual Australian Busi=
ness. Consists of a nine-to-eleven digit number. If the length is 9 digits =
than the last digit is the check digit. If the length is 11 digits, then an=
 algorithm is used to validate the entire value as there is no check digit =
as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                 &lt;br&gt; For type ORGN- The Identifier m=
ust be representative of the company name, organisation name, trading name,=
 associated product, campaign or an identifier recognisable as associated w=
ith the specific business or organisation, with no whitespace at the beginn=
ing or end. Maximum of 256 characters in lower case, to be drawn from Print=
able ASCII (decimal 32-126) and without leading or trailing whitespace. For=
 avoidance of doubt, upper case letters (A-Z, decimal 65-90) are excluded.
                                 Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!=
-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                            maxLength: 256
                            type: string
                            pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}=
~\.\x20-\x7E\+\-]+$
                            example: tay.tay@westpac.com.au
                          aliasType:
                            description: |-
                              For a PayID payment, the type of the PayID.
                                &lt;br&gt;TELI- Telephone Number
                                &lt;br&gt;EMAL- Email Address
                                &lt;br&gt;AUBN- Australian Business Number
                                &lt;br&gt;ORGN- Organisation ID
                            maxLength: 4
                            enum:
                              - EMAL
                              - TELI
                              - AUBN
                              - ORGN
                            type: string
                          beneficiaryId:
                            description: Usage- Caller to map this field wi=
th the Beneficiary Id of the recipient for the On-Platform payment
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    required:
                      - instructedAmount
                      - creditor
                      - creditorAgent
                debtor:
                  description: Party that owes an amount of money to the (u=
ltimate) creditor.
                  type: object
                  properties:
                    identification:
                      description: Unique and unambiguous identification of=
 a person. For example, CIS Key of the debtor account.&lt;br&gt; Usage- Cal=
ler to map debtor's identification to this field.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    issuer:
                      description: Entity that assigns the identification. =
 Example- WPAC &lt;br&gt; Usage- Caller to set this field to 'WPAC'.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify sending party.&lt;br&gt; Usage- Caller to map=
 debtor's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                debtorAccount:
                  required:
                    - identification
                    - schemeName
                    - issuer
                  type: object
                  description: Provides the details to identify an account.
                  properties:
                    identification:
                      description: Full account number including BSB (witho=
ut any separators or spaces).&lt;br&gt; Usage- Caller to map debit account =
number to this field.
                      maxLength: 34
                      type: string
                      pattern: ^[A-Za-z0-9\.]+$
                    issuer:
                      description: Entity that assigns the identification.&=
lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number of the =
debit account.
                      type: string
                      maxLength: 6
                      pattern: ^\d{6}$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify that party. For NPP payment, this is the Full=
 Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this field =
is expected to be provided by the payment enrichment system.
                      maxLength: 70
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                    schemeName:
                      description: |-
                        Name of the identification scheme, in a coded form =
as published in an external list.&lt;br&gt;
                         Usage- Caller to set this field to 'BBAN' to repre=
sent Australian Bank-State-Branch Code (BSB) identification.
                      maxLength: 4
                      type: string
                      pattern: ^\w+$
                    type:
                      description: Debtor's account type represented as Can=
onical Product Code (CPC).&lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^\w+$
                debtorAgent:
                  type: object
                  properties:
                    BICFI:
                      description: Code allocated to a financial institutio=
n by the ISO 9362 Registration Authority as described in ISO 9362 "Banking =
- Banking telecommunication messages - Business identifier code (BIC)".&lt;=
br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SONE'.
                      type: string
                      maxLength: 11
                      pattern: ^\w+$
                    financialInstitutionIdentification:
                      type: object
                      properties:
                        clearingSystemMemberIdentification:
                          description: Unique identification of a clearing =
system member.
                          type: object
                          properties:
                            clearingSystemIdentification:
                              type: object
                              properties:
                                code:
                                  description: Service level Identification=
 Code
                                  type: string
                                  enum:
                                    - AUBSB
                  required:
                    - BICFI
                initiatingParty:
                  description: Party that initiates the payment. This can e=
ither be the debtor or the party that initiates the credit transfer on beha=
lf of the debtor.
                  type: object
                  properties:
                    name:
                      description: Initiating party's full name.&lt;br&gt;U=
sage- Caller to map initiating party's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                instructionForDebtorAgent:
                  description: Further information related to the processin=
g of the payment instruction, that may need to be acted upon by the debtor =
agent, depending on agreement between debtor and the debtor agent. When pre=
sent, it applies to ALL credit transfer transaction information occurrences=
, present in the payment information. &lt;br&gt; Usage- For future use.
                  maxLength: 140
                  type: string
                  pattern: /^[\w\-]+$/
                paymentInformation:
                  description: Set of characteristics that applies to the p=
ayment instruction.
                  type: object
                  properties:
                    numberOfTransactions:
                      description: Number of individual transactions contai=
ned in the payment information group.&lt;br&gt; Usage- Caller to set this f=
ield to 1 to indicate there's only one transaction in the payment. For Bulk=
 payment in the future, this field will need to be set by the caller to the=
 actual number of transactions in the bulk instruction.
                      pattern: '[0-9]{1,15}$'
                      type: string
                paymentMethod:
                  description: Specifies the means of payment that will be =
used to move the amount of money.&lt;br&gt; Usage- Caller to set this field=
 to 'TRF'.
                  type: string
                  enum:
                    - TRF
                    - CHK
                    - TRA
                  example: TRF
                paymentTypeInformation:
                  description: Set of elements used to further specify the =
type of transaction.
                  type: object
                  properties:
                    categoryPurpose:
                      description: Specifies the high-level purpose of the =
instruction based on a set of pre-defined categories. This is used by the i=
nitiating party to provide information concerning the processing of the pay=
ment. &lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    instructionPriority:
                      description: |-
                        Indicator of the urgency or order of importance tha=
t the instructing party would like the instructed party to apply to the pro=
cessing of the instruction. The possible values are-&lt;br&gt;
                          HIGH: High. &lt;br&gt;
                          NORM: Normal.&lt;br&gt;
                          Usage- For future use.
                      enum:
                        - HIGH
                        - NORM
                      type: string
                    serviceLevel:
                      description: |-
                        Specifies a pre-agreed service or level of service =
between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Attended =
payments are defined as Payments whereby the sending participant requires a=
 real-time response to their payment instruction&lt;br&gt; UNAT - For 'Unat=
tended' transaction. Unattended payments are defined as Payments whereby th=
e sending participant does not require a real-time response to their paymen=
t instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&lt;br&g=
t;
                        creditTransferInformation Description - Specifies a=
 pre-agreed service or level of service between the parties.&lt;br&gt;
                        Usage- Caller to set this field to 'npp.clear.01-x2=
p1.01' for NPP Osko payments.
                      maxLength: 35
                      type: string
                      pattern: /^[\w\.\-]+$/
                supplementaryData:
                  description: Additional Westpac Data Elements to support =
the PAYMENT Instruction (Debit).
                  type: object
                  allOf:
                    - type: object
                      properties:
                        divisionName:
                          description: Division Name
                          example: AUD Group
                          maxLength: 70
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        divisionId:
                          description: Division id
                          type: string
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    - type: object
                      properties:
                        debitDescription:
                          description: The reference assigned by the sendin=
g party for the payment.&lt;br&gt;Usage- Caller to map debit description (s=
tatement narrative) to this field.
                          maxLength: 35
                          type: string
                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).=
*[\s\S]*$
                        instructionTraceIdentification:
                          type: string
                          description: UUId to uniquely identify the paymen=
t instruction.
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                        matchedCOPStatusCode:
                          description: ERDM encoded value
                          type: string
                          pattern: ^V[012AET]C[1-8]$
                          example: V0C1
                        matchedCOPAccountName:
                          description: Account Name
                          minLength: 1
                          maxLength: 140
                          example: Apple Tree
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        paymentProductId:
                          description: Product Id associated with the payme=
nt instruction.&lt;br&gt; Usage- Caller to map product id to this field.
                          type: string
                          enum:
                            - PP000020
                            - PP000004
                            - PP000016
                            - PP000012
                            - PP000005
                entitlementData:
                  type: object
                  description: Entitlement data for SAFI integration
                  properties:
                    supplementaryData:
                      type: array
                      description: |
                        Additional data required for SAFI. Each item is a n=
ame/value/datatype triple.
                        Required fields for all payments:
                        - NEWPAYEE (BOOLEAN, send as string 'TRUE'/'FALSE')
                        - W1C_CURRENCY (STRING)
                        - CURRENCY_FROM (STRING)
                        - CROSS_CURRENCY_PAYMENT (BOOLEAN, send as string '=
TRUE'/'FALSE')
                        - W1_2FADEVICETYPE (STRING)
                        - TENANT (STRING)
                        - PAYMENT_REFNO (STRING, use x-channelRequestId)
                        Conditional fields (add only if applicable):
                        - PAYEEPAYIDTYPE, PAYEEPAYIDVALUE, PAYEEPAYIDSHORTN=
AME (STRING, if beneficiary uses PayID)
                        - PAYEEDESTINATIONACCOUNT [BSB + account number], P=
AYEEPAYIDACCOUNTTYPE [BSB] (STRING, if beneficiary uses account type)
                        For boolean fields, use string values 'TRUE' or 'FA=
LSE'.
                      items:
                        oneOf:
                          - type: object
                            description: W1_2FADEVICETYPE field (must be 'S=
OFT TOKEN')
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1_2FADEVICETYPE
                              value:
                                type: string
                                enum:
                                  - SOFT TOKEN
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: TENANT field (must be 'TREASURY')
                            properties:
                              name:
                                type: string
                                enum:
                                  - TENANT
                              value:
                                type: string
                                enum:
                                  - TREASURY
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: W1C_CURRENCY field (currency code)
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1C_CURRENCY
                              value:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: CURRENCY_FROM field (currency code=
)
                            properties:
                              name:
                                type: string
                                enum:
                                  - CURRENCY_FROM
                              value:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEDESTINATIONACCOUNT field (BSB=
 + account number)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEDESTINATIONACCOUNT
                              value:
                                description: Full account number with forma=
t &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                type: string
                                pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                maxLength: 35
                                example: 035845 103784254
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYMENT_REFNO field
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYMENT_REFNO
                              value:
                                type: string
                                pattern: ^\w+$
                                maxLength: 36
                                description: A unique id generated to refer=
ence a specific payment transaction
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDTYPE field (PayID type)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDTYPE
                              value:
                                type: string
                                enum:
                                  - MOBILE
                                  - EMAIL
                                  - LANDLINE
                                  - ABN
                                  - FREEFORM
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDVALUE field (PayID value=
 - supports email, phone, ABN, orgn formats)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDVALUE
                              value:
                                description: |-
                                  aka Payment Alias also known as PayID.  T=
his field will be populated if there was a payId type payment,
                                  &lt;br&gt;Usage format-
                                     &lt;br&gt;For type TELI-  The telephon=
e number must consist of a =E2=80=9C+=E2=80=9D followed by the country code=
 (from 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any com=
bination of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-=
9]{1,1}[0-9]{1,29}$ Example- +61-123456789
                                    &lt;br&gt; For type EMAL- Consists of a=
 character string with a maximum length of 256 characters. This must includ=
e the =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and n=
o white spaces. Only lower case characters will be supported.
                                     Format pattern- Maximum of 256 charact=
ers ^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{=
|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9=
])?)$ Example- 123@NPP.com
                                    &lt;br&gt; For type AUBN- This is assig=
ned by the Australian Taxation Office to identify an individual Australian =
Business. Consists of a nine-to-eleven digit number. If the length is 9 dig=
its than the last digit is the check digit. If the length is 11 digits, the=
n an algorithm is used to validate the entire value as there is no check di=
git as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                     &lt;br&gt; For type ORGN- The Identifi=
er must be representative of the company name, organisation name, trading n=
ame, associated product, campaign or an identifier recognisable as associat=
ed with the specific business or organisation, with no whitespace at the be=
ginning or end. Maximum of 256 characters in lower case, to be drawn from P=
rintable ASCII (decimal 32-126) and without leading or trailing whitespace.=
 For avoidance of doubt, upper case letters (A-Z, decimal 65-90) are exclud=
ed.
                                     Format pattern- ^[!-@[-~][ -@[-~]{0,25=
4}[!-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                                maxLength: 256
                                type: string
                                pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_=
`{|}~\.\x20-\x7E\+\-]+$
                                example: tay.tay@westpac.com.au
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDSHORTNAME field (PayID s=
hort name)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDSHORTNAME
                              value:
                                description: Matches any string, including =
Unicode characters, and emoji, except semicolon (;), double hyphen (--), le=
ft and right curly bracket ({ }), less than (&lt;),  greater than (&gt;), p=
ercentage sign (%), hash (#), quotation mark ("), and equal sign (=3D).  Us=
e for fields that are protected by perfect express sanitizer library
                                type: string
                                pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                                maxLength: 50
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEPAYIDACCOUNTTYPE field (BSB o=
nly)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEPAYIDACCOUNTTYPE
                              value:
                                type: string
                                maxLength: 6
                                pattern: ^\d{6}$
                                description: BSB for account.
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: CROSS_CURRENCY_PAYMENT field (must=
 be 'FALSE' for now). Once supported, can be expanded to include 'TRUE'.
                            properties:
                              name:
                                type: string
                                enum:
                                  - CROSS_CURRENCY_PAYMENT
                              value:
                                type: string
                                enum:
                                  - 'FALSE'
                                description: Cross-currency payments not su=
pported, must be FALSE
                              datatype:
                                type: string
                                enum:
                                  - BOOLEAN
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: NEWPAYEE field (TRUE or FALSE)
                            properties:
                              name:
                                type: string
                                enum:
                                  - NEWPAYEE
                              value:
                                type: string
                                enum:
                                  - 'TRUE'
                                  - 'FALSE'
                                description: Indicates if beneficiary is ne=
w
                              datatype:
                                type: string
                                enum:
                                  - BOOLEAN
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEE_NAME_CHECK_COLOUR field
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEE_NAME_CHECK_COLOUR
                              value:
                                type: string
                                description: PAYEE_NAME_CHECK_COLOUR value
                                enum:
                                  - Blue
                                  - Amber
                                  - Red
                                example: Blue
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                      example:
                        - name: W1_2FADEVICETYPE
                          value: SOFT TOKEN
                          datatype: STRING
                        - name: TENANT
                          value: TREASURY
                          datatype: STRING
                        - name: W1C_CURRENCY
                          value: AUD
                          datatype: STRING
                        - name: CROSS_CURRENCY_PAYMENT
                          value: 'FALSE'
                          datatype: BOOLEAN
                        - name: CURRENCY_FROM
                          value: AUD
                          datatype: STRING
                        - name: NEWPAYEE
                          value: 'FALSE'
                          datatype: BOOLEAN
                        - name: PAYMENT_REFNO
                          value: WP12345678901234567
                          datatype: STRING
                        - name: PAYEE_NAME_CHECK_COLOUR
                          value: Blue
                          datatype: STRING
              required:
                - clientContext
                - paymentMethod
                - initiatingParty
                - debtorAccount
                - creditTransferTransactionInformation
                - supplementaryData
      responses:
        '201':
          description: |
            Scenarios where Payment Initation API sends a full response wit=
h an ISO status:
              ACSC - Debit posted successfully. On-us credits, if any, post=
ed successfully. Off-us credits, if any, sent to the appropriate execution =
systems for clearing and settlement.
              RJCT - Payment rejected.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      paymentCreateForNewBeneficiary:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Details Request.
                          type: object
                          properties:
                            creationDateTime:
                              description: Date and time at which the messa=
ge was created.
                              format: date-time
                              type: string
                            groupInformation:
                              description: Provides details on the original=
 group, to which the message refers
                              type: object
                              properties:
                                groupStatus:
                                  description: Specifies the ISO status at =
the group level.Usage- For future use.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                                originalControlSum:
                                  description: Total of all individual amou=
nts included in the original message, irrespective of currencies.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                                originalCreationDateTime:
                                  description: Date and time at which the o=
riginal message was created.
                                  format: date-time
                                  type: string
                                originalNumberOfTransactions:
                                  description: Number of individual transac=
tions contained in the original message.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                              required:
                                - originalCreationDateTime
                                - originalNumberOfTransactions
                                - groupStatus
                            groupStatusReasonInformation:
                              type: array
                              items:
                                description: Status reason information
                                type: object
                                properties:
                                  reason:
                                    maxLength: 50
                                    description: |-
                                      Status reason description.

                                        Group status reason can have values=
 -
                                          AccountEligibilityFailure
                                          DuplicatePayment
                                          ExternalValidationEnrichmentFaile=
d
                                          PostingFailed
                                          PostingSucceeded
                                          ValidationFailure

                                        Instruction status reason can have =
values -
                                          AccountEligibilityFailure
                                          InsufficientAccountBalance
                                          DebitPostingFailed
                                          DebitPostingSucceeded
                                          ExternalValidationEnrichmentFaile=
d
                                          FraudCheckDeclined
                                          FraudCheckDelayed
                                          FraudCheckNotAvailable
                                          FraudCheckOnHold
                                          FraudCheckReferred
                                          FundsReservationFailed
                                          FundsReservationSucceeded
                                          InvalidExecutionDate
                                          ValidationFailure

                                        Transaction status reason can have =
values -
                                          ClearingAndSettlementRejected
                                          AccountEligibilityFailure
                                          CreditPostingAborted
                                          CreditPostingFailed
                                          SchemeDeterminationFailed
                                          ValidationFailure
                                    type: string
                                    pattern: ^[\w ]+$
                                  additionalInformation:
                                    maxLength: 120
                                    description: Further information about =
the above status reason from downstream.
                                    type: string
                                    pattern: ^[\w ]+$
                            id:
                              description: Point to point reference, as ass=
igned by the instructing party, and sent to the next party in the chain to =
identify the message. This field is mapped from the messageId in the CAP re=
sponse.
                              maxLength: 35
                              type: string
                              pattern: ^[\w ]+$
                            paymentInformation:
                              description: Information concerning the origi=
nal payment information, to which the status report message refers.
                              type: object
                              properties:
                                paymentInformationStatus:
                                  description: Specifies the ISO status of =
the payment. Usage- Possible values -&lt;br&gt; ACSC- Accepted Settlement C=
ompleted (success) &lt;br&gt; ACSP- Accepted Settlement In Process (auto re=
try in progress in case of technical failure)&lt;br&gt; RJCT- Rejected
                                  maxLength: 32
