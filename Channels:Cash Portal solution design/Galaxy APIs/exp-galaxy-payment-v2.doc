        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '401':
          description: |
            &lt;br&gt;__UNAUTHORIZED__
            &lt;br&gt; Possible errors
            &lt;table&gt;
              &lt;tr&gt;
                &lt;td&gt;Error Code&lt;/td&gt;
                &lt;td&gt;Error Message&lt;/td&gt;
                &lt;td&gt;Error Description&lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;8125&lt;/td&gt;
                &lt;td&gt;Authoriser Approval Required&lt;/td&gt;
                &lt;td&gt;The request is pending approval {workflowId}&lt;/=
td&gt;
              &lt;/tr&gt;
            &lt;/table&gt;
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
