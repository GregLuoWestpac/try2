                            paymentId:
                              description: A unique id generated to referen=
ce a specific payment transaction
                              type: string
                              pattern: ^\w+$
                              maxLength: 36
                            creationDateTime:
                              description: A date in which the payment tran=
saction record was created
                              type: string
                              format: date-time
                              example: '2024-01-28T15:27:49.732Z'
                          example:
                            paymentId: WP5070875338715
                            creationDateTime: '2025-03-11T02:25:53.387Z'
                  result:
                    type: object
                    properties:
                      paymentIdentifier:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      paymentIdentifier:
                        - 6550a5e9-0b08-47a2-8dc8-91b9e4207802
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /beneficiaryList:
    post:
      summary: retrieve beneficiary list
      description: Retrieve beneficiary list with optional filtering and so=
rting
      operationId: retrieveBeneficiaries
      tags:
        - Beneficiaries
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: pageKey
          in: query
          description: The key identifying the page of data to be returned
          schema:
            type: integer
            format: int32
            maximum: 1000
            default: 0
          required: false
        - name: pageSize
          in: query
          description: |
            Number of entries to be returned in a single page.
          schema:
            type: integer
            format: int32
            minimum: 10
            maximum: 1000
            default: 1000
          required: false
          example: 100
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        description: Retrieve all beneficiaries request payload
        required: false
        content:
          application/json:
            schema:
              description: Represents All Beneficiaries Retrieve Request Ob=
ject
              type: object
              required:
                - statuses
              properties:
                statuses:
                  type: array
                  items:
                    description: Beneficiary status; example-&gt; ACTIVE, A=
RCHIVED, ON-HOLD
                    type: string
                    enum:
                      - ACTIVE
                      - ARCHIVED
                      - ON-HOLD
                    example: ACTIVE
                  description: List of beneficiary statuses to filter the b=
eneficiaries
                divisionId:
                  description: Division id
                  type: string
                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab=
][0-9a-f]{3}-[0-9a-f]{12}$
      responses:
        '200':
          description: The retrieved beneficiaries
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      beneficiaryList:
                        type: array
                        items:
                          description: Represents the details object for a =
beneficiary.
                          type: object
                          properties:
                            id:
                              description: Unique id for the beneficiary.
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            externalId:
                              description: External id for the beneficiary,=
 used for cross-system references.
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            nickname:
                              description: Beneficiary Nickname
                              type: string
                              example: John
                              minLength: 1
                              maxLength: 70
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                            status:
                              description: Status; example-&gt; ACTIVE, INA=
CTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                              example: ACTIVE
                            currencyAmount:
                              description: A qualified amount and denominat=
ion of a monetary value.
                              type: object
                              properties:
                                amount:
                                  description: A positive or negative numbe=
r string of up to four decimal places (including zero). Must have at least =
one digit after the decimal point.
                                  type: string
                                  anyOf:
                                    - description: A positive number string=
 of up to four decimal places (including zero). Must have at least one digi=
t after the decimal point.
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                    - description: A negative number string=
 of up to four decimal places (including zero). Must have at least one digi=
t after the decimal point.
                                      type: string
                                      pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                      example: '-1000.0000'
                                currencyCode:
                                  description: A code allocated to a curren=
cy by a Maintenance Agency under an international identification scheme, as=
 described in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                  type: string
                                  pattern: ^[A-Z]{3}$
                                  example: AUD
                              required:
                                - currencyCode
                            org:
                              description: CIS Key of the organisation
                              type: string
                              example: '06089457589'
                              pattern: ^\d{11}$
                            type:
                              description: Beneficiary account type either =
Pay id or BSB &amp; Account number
                              type: string
                              enum:
                                - PAYID
                                - BSB_ACCOUNT_NUMBER
                              example: BSB_ACCOUNT_NUMBER
                            reference:
                              description: Unique payment identifier for en=
d-to-end transaction tracking and reconciliation.
                              maxLength: 35
                              example: INV-123456790
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                            account:
                              type: object
                              description: Represents Account detail object
                              oneOf:
                                - type: object
                                  description: Object representing an accou=
nt identified by BSB, bank name, account name, and account number.
                                  required:
                                    - accountId
                                    - bankName
                                    - accountName
                                  properties:
                                    accountId:
                                      type: object
                                      description: Account ID (BSB and Acco=
unt Number)
                                      required:
                                        - BSB
                                        - accountNumber
                                      properties:
                                        BSB:
                                          description: Bank State Branch Nu=
mber
                                          type: string
                                          pattern: ^\d{6}$
                                          example: '035845'
                                        accountNumber:
                                          description: Account Number
                                          type: string
                                          pattern: ^[a-zA-Z\d.]+$
                                          minLength: 6
                                          maxLength: 28
                                          example: '01235674897'
                                      example:
                                        BSB: '035845'
                                        accountNumber: '10235674897'
                                    accountName:
                                      description: Account Name
                                      minLength: 1
                                      maxLength: 140
                                      example: Apple Tree
                                      type: string
                                      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                    bankName:
                                      description: Name of Bank
                                      minLength: 1
                                      maxLength: 70
                                      example: Westpac Banking Corporation
                                      type: string
                                      pattern: ^[\w ]+$
                                - type: object
                                  description: Represents PayID object
                                  oneOf:
                                    - type: object
                                      description: PAY ID with email
                                      required:
                                        - payIDName
                                        - payIDType
                                        - payIDValue
                                      properties:
                                        payIDName:
                                          description: Beneficiary Nickname
                                          type: string
                                          example: John
                                          minLength: 1
                                          maxLength: 70
                                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&=
gt;|%|#|"|=3D)).*[\s\S]*$
                                        payIDType:
                                          description: PayID type represent=
ing an Email address.
                                          enum:
                                            - EMAL
                                          type: string
                                          example: EMAL
                                        payIDValue:
                                          description: PAY ID value represe=
nting an Email address
                                          minLength: 5
                                          maxLength: 256
                                          example: john.doe@example.com
                                          type: string
                                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]=
*$
                                    - type: object
                                      description: PAY ID with telephone nu=
mber
                                      required:
                                        - payIDName
                                        - payIDType
                                        - payIDValue
                                      properties:
                                        payIDName:
                                          description: Beneficiary Nickname
                                          type: string
                                          example: John
                                          minLength: 1
                                          maxLength: 70
                                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&=
gt;|%|#|"|=3D)).*[\s\S]*$
                                        payIDType:
                                          description: PayID type represent=
ing a Telephone number.
                                          enum:
                                            - TELI
                                          type: string
                                          example: TELI
                                        payIDValue:
                                          description: PAY ID value represe=
nting a Telephone number
                                          type: string
                                          pattern: ^\+([1-9]{1}[0-9]{1,2})[=
-]{0,1}[0-9]+$
                                          minLength: 2
                                          maxLength: 30
                                          example: '+61412345678'
                                    - type: object
                                      description: PAY ID with Organisation=
 number
                                      required:
                                        - payIDName
                                        - payIDType
                                        - payIDValue
                                      properties:
                                        payIDName:
                                          description: Beneficiary Nickname
                                          type: string
                                          example: John
                                          minLength: 1
                                          maxLength: 70
                                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&=
gt;|%|#|"|=3D)).*[\s\S]*$
                                        payIDType:
                                          description: PayID type represent=
ing an Organisation ID.
                                          enum:
                                            - ORGN
                                          type: string
                                          example: ORGN
                                        payIDValue:
                                          description: PAY ID value represe=
nting an Organisation number
                                          minLength: 2
                                          maxLength: 256
                                          example: ORG-12345
                                          type: string
                                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]=
*$
                                    - type: object
                                      description: PAY ID with Australian B=
usiness number
                                      required:
                                        - payIDName
                                        - payIDType
                                        - payIDValue
                                      properties:
                                        payIDName:
                                          description: Beneficiary Nickname
                                          type: string
                                          example: John
                                          minLength: 1
                                          maxLength: 70
                                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&=
gt;|%|#|"|=3D)).*[\s\S]*$
                                        payIDType:
                                          description: PayID type represent=
ing an Australian Business Number (ABN).
                                          enum:
                                            - AUBN
                                          type: string
                                          example: AUBN
                                        payIDValue:
                                          description: PAY ID value represe=
nting an Australian Business Number (ABN)
                                          type: string
                                          pattern: ^\d+$
                                          minLength: 9
                                          maxLength: 11
                                          example: '12345678910'
                              example:
                                accountId:
                                  accountNumber: '01235674897'
                                  BSB: '035845'
                                accountName: Apple Tree
                                bankName: Westpac Banking Corporation
                      paging:
                        type: array
                        items:
                          type: object
                          properties:
                            id:
                              description: Paging Unique Id
                              type: string
                              maxLength: 3
                              pattern: ^\d+$
                              example: '1'
                            pageSize:
                              description: Number of items per page
                              type: integer
                              format: int32
                              example: 50
                            count:
                              description: Total number of items available
                              type: integer
                              format: int32
                              example: 160
                            previousPageKey:
                              description: Key for start of previous page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '0'
                            nextPageKey:
                              description: Key for start of next page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '2'
                            moreItems:
                              description: Indicator to show if there are m=
ore items available. If true, more records are available (by narrowing sear=
ch parameters)
                              type: boolean
                              example: true
                  result:
                    type: object
                    properties:
                      beneficiaryList:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      beneficiaryList:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
