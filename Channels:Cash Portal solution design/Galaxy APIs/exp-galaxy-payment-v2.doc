<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: sql; gutter: false; theme: RDark; collapse: true" data-theme=3D"RDark">{
  "creditTransferTransactionInformation": [
    {
      "creditor": {
        "name": "string", // [INTL] Account name (Beneficiary) | [RTGS] Acc=
ount name
        "countryOfResidence": "string", // [INTL] Beneficiary Country code =
| [RTGS] N/A
        "postalAddress": {
          "streetName": "string", // [INTL] Beneficiary Street Name | [RTGS=
] N/A
          "postCode": "string", // [INTL] Beneficiary Post Code | [RTGS] N/=
A
          "townName": "string", // [INTL] Beneficiary City | [RTGS] N/A
          "countrySubDivision": "string", // [INTL] Beneficiary State | [RT=
GS] N/A
          "country": "string" // [INTL] Beneficiary Country code | [RTGS] N=
/A
        }
      },
      "creditorAccount": {
        "identification": "string", // [INTL] Account number (beneficiary) =
| [RTGS] Account number (beneficiary)
        "IBAN": "string", // [INTL] IBAN if user has inputted IBAN. either =
IBAN or account number is expected. | [RTGS] N/A
        "issuer": "string", // [INTL] To Account (e.g. ABA/Sort Code) Not n=
eeded by International payment | [RTGS] To account BSB
        "name": "string", // [INTL] should use Creditor name and not to dup=
licate the same in Creditor Account name | [RTGS] should use Creditor name =
and not to duplicate the same in Creditor Account name
        "schemeName": "string",
        "type": "string"
      },
      "creditorAgent": {
        "BICFI": "string", // [INTL] Beneficiary SWIFT/BIC code | [RTGS] N/=
A
        "clearingSystemMemberIdentification": {
          "clearingSystemIdentification": {
            "code": "string" // [INTL] Beneficiary Branch Identifier name c=
ode | [RTGS] AUBSB
          },
          "memberIdentification": "string" // [INTL] Beneficiary Branch Ide=
ntifier number | [RTGS] BSB entered by customer
        },
        "name": "string" // [INTL] Beneficiary Bank name | [RTGS] N/A
      },
      "endToEndIdentification": "string", // [RTGS+INTL] Scheme E2E ID, UUI=
Dv4 (Generated by Channel, can re-use messageIdentification)
      "UETR": "string", // [INTL] UETR, UUIDv4 (Generated by Channel) | [RT=
GS] UETR, UUIDv4 (Generated by Channel)
      "chargeBearer": "string", // [INTL] Charge Bearer CRED - Borne by Cre=
ditor DEBT - Borne by Debtor SHAR - Shared | [RTGS] N/A
      "purpose": {
        "code": "string", // [INTL] Purpose of Payment code | [RTGS] N/A
        "proprietary": "string" // [INTL] Purpose of Payment in a proprieta=
ry form | [RTGS] N/A
      },
      "instructedAmount": {
        "amount": "string", // [INTL] Payment Amount | [RTGS] Payment amoun=
t from UI
        "currency": "AUD", // [INTL] Payment Currency code | [RTGS] Payment=
 currency code from UI (AUD only for AUG)
        "amountType": "InstructedAmount" // [INTL] InstructedAmount | [RTGS=
] InstructedAmount
      },
      "intermediaryAgent1": {
        "financialInstitutionIdentification": {
          "BICFI": "string", // [INTL] Intermediary SWIFT/BIC code | [RTGS]=
 N/A
          "clearingSystemMemberIdentification": {
            "memberIdentification": "string" // [INTL] Intermediary Branch =
Identifier number | [RTGS] N/A
          }
        }
      },
      "paymentIdentification": {
        "instructionIdentification": "string", // [INTL] Payment ID (Genera=
ted by payment endpoint) | [RTGS] Payment ID (Generated by payment endpoint=
)
      },
      "instructionForDebtorAgent": "string",
      "paymentTypeInformation": {
        "categoryPurpose": "string",
        "instructionPriority": "HIGH",
        "localInstrument": "string",
        "serviceLevel": "string"
      },
      "remittanceInformation": {
        "unstructured": ["string"] // [INTL] Credit description | [RTGS] Cr=
edit description
      },
      "supplementaryData": {
        "isNewPayee": "boolean",
        "aliasId": "string",
        "aliasType": "TELI",
        "beneficiaryId": "string",
        "templateId": "string",
        "aliasResolutionTime": "string",
        "cutoffTime": "string" // [INTL] Cut-off time for the payment to be=
 submitted by based on Country and Currency. | [RTGS] hardcoded to 4pm.
      }
    }
  ],
  "debtor": {
    "identification": "string", // From account cis key? | [INTL] CIS Key o=
f Debtor | [RTGS] CIS Key of Debtor
    "issuer": "string", // Westpac Group
    "name": "string" // From account owner name (enrich by PIO) DO NOT send=
 from Channel
  },
  "debtorAccount": {
    "identification": "string", // [INTL] From account number | [RTGS] From=
 account number
    "issuer": "string", // [INTL] From account BSB | [RTGS] From account BS=
B
    "name": "string", // [INTL] From account owner name | [RTGS] From accou=
nt owner name
    "schemeName": "string", // [INTL] BBAN | [RTGS] BBAN
    "type": "string"
  },
  "debtorAgent": {
    "BICFI": "string" // [INTL] WPACAU2S | [RTGS] WPACAU2S
  },
  "initiatingParty": {
    "name": "string", // [INTL] From account owner name (enrich by PIO) DO =
NOT send from channel | [RTGS] enrich by PIO, DO NOT send from channel
    "identification": {
      "other": [
        {
          "identification": "string", // [INTL] initiator Cis Key | [RTGS] =
initiator Cis Key
          "schemeName": {
            "proprietary": "string" // [INTL] Westpac | [RTGS] Westpac
          },
          "issuer": "string" // [INTL] Westpac Group | [RTGS] Westpac Group
        }
      ]
    }
  },
  "instructionForDebtorAgent": "string",
  "paymentInformation": {
    "controlSum": "string",
    "numberOfTransactions": "string", // [INTL] Set to 1 for single-transac=
tion submissions | [RTGS] Set to 1 for single-transaction submissions
    "chargeBearer": "string", // [INTL] Charge Bearer CRED - Borne by Credi=
tor DEBT - Borne by Debtor SHAR - Shared | [RTGS] N/A
    "requestedExecutionDate": {
      "date": "string", // [INTL] Date (Date of final approval) | [RTGS] Da=
te (Date of final approval)
      "dateTime": "string"
    },
    "paymentInformationIdentification": "string", // [INTL] what's needed f=
or this one? | [RTGS] what's needed for this one?
    "debtor": {
      "name": "string", // [INTL] From account owner name (enrich by PIO) D=
O NOT send from Channel | [RTGS] (enrich by PIO) DO NOT send from Channel
      "identification": {
        "other": [
          {
            "identification": "string", // [INTL] CIS Key of Debtor | [RTGS=
] CIS Key of Debtor
            "schemeName": {
              "proprietary": "string" // [INTL] Westpac | [RTGS] Westpac
            },
            "issuer": "string" // [INTL] Westpac Group | [RTGS] Westpac Gro=
up
          }
        ]
      }
    }
  },
  "paymentMethod": "TRF", // [INTL] TRF | [RTGS] TRF
  "paymentTypeInformation": {
    "categoryPurpose": "string",
    "instructionPriority": "HIGH", // [INTL] NORM | [RTGS] NORM
    "localInstrument": "string",
    "serviceLevel": "string" // [INTL] Any value needed for international? =
| [RTGS] G001 TBC if it's the value and whether it's returned as scheme eli=
gibility
  },
  "supplementaryData": {
    "debitDescription": "string", // [INTL] Debit Description | [RTGS] Debi=
t Description
    "instructionTraceIdentification": "string",
    "divisionId": "string",
    "divisionName": "string",
    "channelType": "string", // [INTL] clientContext.channelType | [RTGS] c=
lientContext.channelType
    "paymentProductId": "PP000003", // [INTL] send from UI. PP000003 | [RTG=
S] send from UI. PP000001
    "matchedCOPStatusCode": "V0C1",
    "matchedCOPAccountName": "ABC account"
  },
  "entitlementData": {
    "supplementaryData": [
      { "name": "W1_2FADEVICETYPE", "value": "SOFT TOKEN", "datatype": "STR=
ING" },
      { "name": "TENANT", "value": "TREASURY", "datatype": "STRING" },
      { "name": "W1C_CURRENCY", "value": "to currency e.g. AUD", "datatype"=
: "STRING" },
      { "name": "CROSS_CURRENCY_PAYMENT", "value": "true if from and to cur=
rency are different", "datatype": "STRING" },
      { "name": "CURRENCY_FROM", "value": "from account currency", "datatyp=
e": "STRING" },
      { "name": "NEWPAYEE", "value": "true if any beneficiary is a first-ti=
me payee and false if beneficiary is not first-time payee", "datatype": "BO=
OLEAN" },
      { "name": "PAYEEDESTINATIONACCOUNT", "value": "SWIFT code + account n=
umber/IBAN - for international payments", "datatype": "STRING" },
      { "name": "PAYEEPAYIDTYPE", "value": "MOBILE, EMAIL,LANDLINE, ABN, FR=
EEFORM", "datatype": "STRING" },
      { "name": "PAYEEPAYIDVALUE", "value": "Alias value", "datatype": "STR=
