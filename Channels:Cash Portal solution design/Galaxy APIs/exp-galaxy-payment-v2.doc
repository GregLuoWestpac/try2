  /paymentreturns:
    post:
      tags:
        - postPaymentReturns
      description: |
        This endpoint initiate a payment return
      operationId: postPaymentReturns
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: x-idempotency-key
          in: header
          description: A unique identifier for a transaction to support ide=
mpotency checks
          schema:
            type: string
            description: A unique identifier
            format: uuid
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
          required: true
        - name: x-channelRequestId
          in: header
          description: |
            Unique identifier for the request authorisation. This is used t=
o correlate the request in the maker-checker.
            This is generated by the channels and should be unique across a=
ll requests.
          required: true
          schema:
            description: Pattern for the channel request ID
            type: string
            pattern: ^[\w-]{15,36}$
      requestBody:
        required: true
        description: |
          Initiate the payment return through payment return cap endpoint a=
nd further via FIS POM API and return the code for success or error, this e=
nd point will support only single payment return.
        content:
          application/json:
            schema:
              type: object
              description: Submit Payment Return Details Request.
              properties:
                clientContext:
                  description: Client context information
                  type: object
                  properties:
                    channelType:
                      description: |-
                        Channel sending the request. Can be empty or null.
                          e.g.
                        - W1C_O_B_D_CP - W1C_O_A_D_SP
                      type: string
                      maxLength: 100
                      pattern: ^[A-Z0-9_-]+$
                originalMessageIdentification:
                  type: string
                  description: Point to point reference, as assigned by the=
 original instructing party, to unambiguously identify the original message=
.
                  minLength: 1
                  maxLength: 35
                  pattern: ^\w+$
                transactionInformation:
                  type: object
                  description: Information concerning the original transact=
ions, to which the return message refers.
                  required:
                    - returnedInterbankSettlementAmount
                    - supplementaryData
                  properties:
                    returnedInterbankSettlementAmount:
                      description: balance amount details.
                      type: object
                      properties:
                        amount:
                          description: The payment amount before deduction =
of charges, expressed in the currency as ordered by the initiating party.&l=
t;br&gt; Usage- Caller to map payment amount to this field.
                          type: string
                          pattern: \d{1,13}\.?\d{0,3}$
                        currency:
                          description: A code allocated to a currency by a =
Maintenance Agency under an international identification scheme, as describ=
ed in the latest edition of the international standard ISO 4217 =E2=80=9CCo=
des for the representation of currencies and funds=E2=80=9D.&lt;br&gt; Usag=
e- Caller to set 'AUD' to this field.
                          type: string
                          pattern: ^\w{3}$
                          example: AUD
                      required:
                        - amount
                        - currency
                    returnReason:
                      type: object
                      description: Provides further details on the reason o=
f the return of the transaction.
                      properties:
                        reasonCode:
                          type: string
                          description: Reason for the return, as published =
in an external reason code list.
                          enum:
                            - FOCR
                            - AC04
                            - AC06
                            - AM03
                            - AM05
                            - AM09
                            - BE05
                            - FR01
                            - MD06
                            - NARR
                            - RR04
                            - UPAY
                        additionalInformation:
                          type: string
                          description: Further details on the return reason=
.
                          maxLength: 200
                          minLength: 1
                          pattern: /^[\w ]*$/
                        cancellationCode:
                          type: string
                          description: Cancellation code for the return, as=
 published in an external reason code list.
                          enum:
                            - AGNT
                            - CURR
                            - CUST
                            - DUPL
                            - FRAD
                            - TECH
                            - UPAY
                        returnType:
                          type: string
                          description: Return type.
                          maxLength: 35
                          minLength: 1
                          pattern: /^[\w ]*$/
                      required:
                        - additionalInformation
                        - reasonCode
                        - returnType
                    creditor:
                      required:
                        - identification
                        - name
                        - issuer
                      type: object
                      description: Provides the details to identify an acco=
unt.
                      properties:
                        identification:
                          description: Full account number including BSB (w=
ithout any separators or spaces).&lt;br&gt; Usage- Caller to map debit acco=
unt number to this field.
                          maxLength: 34
                          type: string
                          pattern: ^[A-Za-z0-9\.]+$
                        issuer:
                          description: Entity that assigns the identificati=
on.&lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number of =
the debit account.
                          type: string
                          maxLength: 6
                          pattern: ^\d{6}$
                        name:
                          description: Name by which a party is known, and =
which is usually used to identify that party. For NPP payment, this is the =
Full Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this fi=
eld is expected to be provided by the payment enrichment system.
                          maxLength: 70
                          type: string
                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).=
*[\s\S]*$
                        schemeName:
                          description: |-
                            Name of the identification scheme, in a coded f=
orm as published in an external list.&lt;br&gt;
                             Usage- Caller to set this field to 'BBAN' to r=
epresent Australian Bank-State-Branch Code (BSB) identification.
                          maxLength: 4
                          type: string
                          pattern: ^\w+$
                        type:
                          description: Debtor's account type represented as=
 Canonical Product Code (CPC).&lt;br&gt; Usage- For future use.
                          maxLength: 35
                          type: string
                          pattern: ^\w+$
                    debtor:
                      required:
                        - identification
                        - name
                        - issuer
                      type: object
                      description: Provides the details to identify an acco=
unt.
                      properties:
                        identification:
                          description: Full account number including BSB (w=
ithout any separators or spaces).&lt;br&gt; Usage- Caller to map debit acco=
unt number to this field.
                          maxLength: 34
                          type: string
                          pattern: ^[A-Za-z0-9\.]+$
                        issuer:
                          description: Entity that assigns the identificati=
on.&lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number of =
the debit account.
                          type: string
                          maxLength: 6
                          pattern: ^\d{6}$
                        name:
                          description: Name by which a party is known, and =
which is usually used to identify that party. For NPP payment, this is the =
Full Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this fi=
eld is expected to be provided by the payment enrichment system.
                          maxLength: 70
                          type: string
                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).=
*[\s\S]*$
                        schemeName:
                          description: |-
                            Name of the identification scheme, in a coded f=
orm as published in an external list.&lt;br&gt;
                             Usage- Caller to set this field to 'BBAN' to r=
epresent Australian Bank-State-Branch Code (BSB) identification.
                          maxLength: 4
                          type: string
                          pattern: ^\w+$
                        type:
                          description: Debtor's account type represented as=
 Canonical Product Code (CPC).&lt;br&gt; Usage- For future use.
                          maxLength: 35
                          type: string
                          pattern: ^\w+$
                    debitDescription:
                      description: The reference assigned by the sending pa=
rty for the payment.&lt;br&gt;Usage- Caller to map debit description (state=
ment narrative) to this field.
                      maxLength: 35
                      type: string
                      pattern: ^(?!.*&lt;\/).*
                    creditDescription:
                      description: Remittance information to be supplied wi=
th a payment to assist the recipient to determine the intended purpose of t=
he payment. There are two lines of 140 characters.&lt;br&gt;Usage- Caller t=
o map credit description (statement narrative) to this field.
                      maxLength: 280
                      type: string
                      pattern: ^(?!.*&lt;\/).*
                    paymentReference:
                      description: The reference assigned by the sending pa=
rty for the payment.&lt;br&gt;Usage- Caller to map debit description (state=
ment narrative) to this field.
                      maxLength: 35
                      type: string
                      pattern: ^(?!.*&lt;\/).*
                    toAnotherAccount:
                      type: string
                      description: Provides further details if original deb=
tor is same as credior of this payment.
                      enum:
                        - 'Yes'
                        - 'No'
                    supplementaryData:
                      type: object
                      description: Additional information that cannot be ca=
ptured in the structured elements and/or any other specific block.
                      properties:
                        groupCaseId:
                          type: string
                          description: Internal Case management system refe=
rence id.
                          maxLength: 35
                          pattern: ^\w*$
                        ofiCaseId:
                          type: string
                          description: Case management system reference id =
for an NPP payment return.
                          maxLength: 35
                          pattern: ^\w*$
                        serviceLevel:
                          type: string
                          description: Specifies a pre-agreed service or le=
vel of service between the parties.&lt;br&gt; Usage- Caller to set this fie=
ld to 'npp.clear.01-x2p1.01' for NPP Osko payments.
                          maxLength: 35
                          pattern: /^[\w\.\-]+$/
                        paymentDetailsIdType:
                          type: string
                          description: Type of the transaction ID, which is=
 used to fetch original payment details.
                          enum:
                            - NPPID
                            - PMTID
              required:
                - originalMessageIdentification
      responses:
        '201':
          description: |
            Scenarios where Payment Return API sends a full response with a=
n ISO status:
              ACSC - Debit posted successfully. On-us credits, if any, post=
ed successfully. Off-us credits, if any, sent to the appropriate execution =
systems for clearing and settlement.
              RJCT - Payment Return rejected.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      paymentreturns:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Return Request.
                          type: object
                          properties:
                            id:
                              description: Point to point reference, as ass=
igned by the instructing party, and sent to the next party in the chain to =
identify the message. This field is mapped from the messageId in the CAP re=
sponse.
                              maxLength: 35
                              type: string
                              pattern: /^[\w ]+$/
                            creationDateTime:
                              description: Date and time at which the messa=
ge was created.
                              format: date-time
                              type: string
                            groupInformation:
                              description: Provides details on the original=
 group, to which the message refers
                              type: object
                              properties:
                                originalCreationDateTime:
                                  description: Date and time at which the o=
riginal message was created.
                                  format: date-time
                                  type: string
                                groupStatus:
                                  description: Specifies the ISO status at =
the group level.Usage- For future use.
                                  type: string
                                  pattern: /^[\w ]+$/
                                  maxLength: 32
                            groupStatusReasonInformation:
                              type: array
                              items:
                                description: Status reason information
                                type: object
                                properties:
                                  reason:
                                    type: string
                                    pattern: /^[\w ]+$/
                                    maxLength: 50
                                    description: |-
                                      Status reason description.

                                        Group status reason can have values=
 -
                                          AccountEligibilityFailure
                                          DuplicatePayment
                                          ExternalValidationEnrichmentFaile=
d
                                          PostingFailed
                                          PostingSucceeded
                                          ValidationFailure

                                        Instruction status reason can have =
values -
                                          AccountEligibilityFailure
                                          InsufficientAccountBalance
                                          DebitPostingFailed
                                          DebitPostingSucceeded
                                          ExternalValidationEnrichmentFaile=
d
                                          FraudCheckDeclined
                                          FraudCheckDelayed
                                          FraudCheckNotAvailable
                                          FraudCheckOnHold
                                          FraudCheckReferred
                                          FundsReservationFailed
                                          FundsReservationSucceeded
                                          InvalidExecutionDate
                                          ValidationFailure

                                        Transaction status reason can have =
values -
                                          ClearingAndSettlementRejected
                                          AccountEligibilityFailure
                                          CreditPostingAborted
                                          CreditPostingFailed
                                          SchemeDeterminationFailed
                                          ValidationFailure
                                  additionalInformation:
                                    type: string
                                    pattern: /^[\w ]+$/
                                    maxLength: 120
                                    description: Further information about =
the above status reason from downstream.
                            transactionStatusInformation:
                              type: array
                              items:
                                description: Provides information on the or=
iginal transactions to which the status report message refers.
                                properties:
                                  transactionStatus:
                                    type: string
                                    description: Specifies the ISO status o=
f the credit transaction within the payment, in case of on-us payments. &lt=
;br&gt; Usage-  Possible values- ACSC - Accepted Settlement Completed (succ=
ess) RJCT - Rejected (posting rejected) ACSP - Accepted Settlement In Proce=
ss (auto retry in progress in case of technical failure
                                    enum:
                                      - ACSC
                                      - RJCT
                                      - ACSP
                                  statusReasonInformation:
                                    type: array
                                    items:
                                      description: Status reason informatio=
n
                                      type: object
                                      properties:
                                        reason:
                                          type: string
                                          pattern: /^[\w ]+$/
                                          maxLength: 50
                                          description: |-
                                            Status reason description.

                                              Group status reason can have =
values -
                                                AccountEligibilityFailure
                                                DuplicatePayment
                                                ExternalValidationEnrichmen=
tFailed
                                                PostingFailed
                                                PostingSucceeded
                                                ValidationFailure

                                              Instruction status reason can=
 have values -
                                                AccountEligibilityFailure
                                                InsufficientAccountBalance
                                                DebitPostingFailed
                                                DebitPostingSucceeded
                                                ExternalValidationEnrichmen=
tFailed
                                                FraudCheckDeclined
                                                FraudCheckDelayed
                                                FraudCheckNotAvailable
                                                FraudCheckOnHold
                                                FraudCheckReferred
                                                FundsReservationFailed
                                                FundsReservationSucceeded
                                                InvalidExecutionDate
                                                ValidationFailure

                                              Transaction status reason can=
 have values -
                                                ClearingAndSettlementReject=
ed
                                                AccountEligibilityFailure
                                                CreditPostingAborted
                                                CreditPostingFailed
                                                SchemeDeterminationFailed
                                                ValidationFailure
                                        additionalInformation:
                                          type: string
                                          pattern: /^[\w ]+$/
                                          maxLength: 120
                                          description: Further information =
about the above status reason from downstream.
                                  supplementaryData:
                                    description: W1C Echoed from the reques=
t.
                                    properties:
                                      id:
                                        description: Usage- Echoed from the=
 request, mapped from originalEndToEndIdentification.
                                        type: string
                                        pattern: ^\w+$
                                        maxLength: 32
                          required:
                            - id
                            - creationDateTime
                  result:
                    type: object
                    properties:
                      paymentreturns:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
        '202':
          description: |
            Scenarios where Payment Initation API sends a full response wit=
h an ISO status:
              RCVD - Received payment instruction. Payment status unknown a=
t this stage.
              PDNG - Payment held by fraud for further investigation.
              ACCP - Payment timed out on debit posting, retrying posting.
              ACSP - Technical failure on debit posting, retrying posting.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      paymentreturns:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Return Request.
                          type: object
                          properties:
                            id:
                              description: Point to point reference, as ass=
igned by the instructing party, and sent to the next party in the chain to =
identify the message. This field is mapped from the messageId in the CAP re=
sponse.
                              maxLength: 35
                              type: string
                              pattern: /^[\w ]+$/
                            creationDateTime:
                              description: Date and time at which the messa=
ge was created.
                              format: date-time
                              type: string
                            groupInformation:
                              description: Provides details on the original=
 group, to which the message refers
                              type: object
                              properties:
                                originalCreationDateTime:
                                  description: Date and time at which the o=
riginal message was created.
                                  format: date-time
                                  type: string
                                groupStatus:
                                  description: Specifies the ISO status at =
the group level.Usage- For future use.
                                  type: string
                                  pattern: /^[\w ]+$/
                                  maxLength: 32
                            groupStatusReasonInformation:
                              type: array
                              items:
                                description: Status reason information
                                type: object
                                properties:
                                  reason:
                                    type: string
                                    pattern: /^[\w ]+$/
                                    maxLength: 50
                                    description: |-
                                      Status reason description.

                                        Group status reason can have values=
 -
                                          AccountEligibilityFailure
                                          DuplicatePayment
                                          ExternalValidationEnrichmentFaile=
d
                                          PostingFailed
                                          PostingSucceeded
                                          ValidationFailure

                                        Instruction status reason can have =
values -
                                          AccountEligibilityFailure
                                          InsufficientAccountBalance
                                          DebitPostingFailed
                                          DebitPostingSucceeded
                                          ExternalValidationEnrichmentFaile=
d
                                          FraudCheckDeclined
                                          FraudCheckDelayed
                                          FraudCheckNotAvailable
                                          FraudCheckOnHold
                                          FraudCheckReferred
                                          FundsReservationFailed
                                          FundsReservationSucceeded
                                          InvalidExecutionDate
                                          ValidationFailure

                                        Transaction status reason can have =
values -
                                          ClearingAndSettlementRejected
                                          AccountEligibilityFailure
                                          CreditPostingAborted
                                          CreditPostingFailed
                                          SchemeDeterminationFailed
                                          ValidationFailure
                                  additionalInformation:
                                    type: string
                                    pattern: /^[\w ]+$/
                                    maxLength: 120
                                    description: Further information about =
the above status reason from downstream.
                            transactionStatusInformation:
                              type: array
                              items:
                                description: Provides information on the or=
iginal transactions to which the status report message refers.
                                properties:
                                  transactionStatus:
                                    type: string
                                    description: Specifies the ISO status o=
f the credit transaction within the payment, in case of on-us payments. &lt=
;br&gt; Usage-  Possible values- ACSC - Accepted Settlement Completed (succ=
ess) RJCT - Rejected (posting rejected) ACSP - Accepted Settlement In Proce=
ss (auto retry in progress in case of technical failure
                                    enum:
                                      - ACSC
                                      - RJCT
                                      - ACSP
                                  statusReasonInformation:
                                    type: array
                                    items:
                                      description: Status reason informatio=
n
                                      type: object
                                      properties:
                                        reason:
                                          type: string
                                          pattern: /^[\w ]+$/
                                          maxLength: 50
                                          description: |-
                                            Status reason description.

                                              Group status reason can have =
values -
                                                AccountEligibilityFailure
                                                DuplicatePayment
                                                ExternalValidationEnrichmen=
tFailed
                                                PostingFailed
                                                PostingSucceeded
                                                ValidationFailure

                                              Instruction status reason can=
 have values -
                                                AccountEligibilityFailure
                                                InsufficientAccountBalance
                                                DebitPostingFailed
                                                DebitPostingSucceeded
                                                ExternalValidationEnrichmen=
tFailed
                                                FraudCheckDeclined
                                                FraudCheckDelayed
                                                FraudCheckNotAvailable
                                                FraudCheckOnHold
                                                FraudCheckReferred
                                                FundsReservationFailed
                                                FundsReservationSucceeded
                                                InvalidExecutionDate
                                                ValidationFailure

                                              Transaction status reason can=
 have values -
                                                ClearingAndSettlementReject=
ed
