                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '401':
          description: |
            &lt;br&gt;__UNAUTHORIZED__
            &lt;br&gt; Possible errors
            &lt;table&gt;
              &lt;tr&gt;
                &lt;td&gt;Error Code&lt;/td&gt;
                &lt;td&gt;Error Message&lt;/td&gt;
                &lt;td&gt;Error Description&lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;8125&lt;/td&gt;
                &lt;td&gt;Authoriser Approval Required&lt;/td&gt;
                &lt;td&gt;The request is pending approval {workflowId}&lt;/=
td&gt;
              &lt;/tr&gt;
            &lt;/table&gt;
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /accountNameCheck:
    post:
      description: This endpoint validates the customer name for both, On-U=
s or Off-Us Scenarios.
      operationId: postAccountNameCheck
      tags:
        - AccountNameCheck
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        content:
          application/json:
            schema:
              description: Request for account name check.
              type: object
              required:
                - payee
              properties:
                payee:
                  type: object
                  required:
                    - accountName
                    - accountId
                  properties:
                    accountName:
                      description: Account Name
                      minLength: 1
                      maxLength: 140
                      example: Apple Tree
                      type: string
                      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                    accountId:
                      type: object
                      description: Account ID (BSB and Account Number)
                      required:
                        - BSB
                        - accountNumber
                      properties:
                        BSB:
                          description: Bank State Branch Number
                          type: string
                          pattern: ^\d{6}$
                          example: '035845'
                        accountNumber:
                          description: Account Number
                          type: string
                          pattern: ^[a-zA-Z\d.]+$
                          minLength: 6
                          maxLength: 28
                          example: '01235674897'
                      example:
                        BSB: '035845'
                        accountNumber: '10235674897'
              example:
                payee:
                  accountName: Paul Walker
                  accountId:
                    accountNumber: '345623189665'
                    BSB: '037724'
      responses:
        '200':
          description: The resolved Account Name Check response
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      accountNameCheck:
                        type: array
                        items:
                          description: Represents The Account Name Check Re=
sponse Object
                          allOf:
                            - type: object
                              properties:
                                id:
                                  description: A unique id generated for an=
 entity which is the mode of communication between the UI and Exp API, via =
redux store
                                  example: d0868661-b955-4e76-9f15-d97626f7=
df6b
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            - type: object
                              properties:
                                matchedCOPAccountName:
                                  description: Account Name
                                  minLength: 1
                                  maxLength: 140
                                  example: Apple Tree
                                  type: string
                                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                matchedCOPStatusCode:
                                  description: ERDM encoded value
                                  type: string
                                  pattern: ^V[012AET]C[1-8]$
                                  example: V0C1
                                matchedCOPColour:
                                  type: string
                                  description: The matched colour based on =
ERDM encoded value
                                  example: Blue
                                  enum:
                                    - Blue
                                    - Amber
                                    - Red
                  result:
                    type: object
                    properties:
                      accountNameCheck:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      accountNameCheck:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
</pre>
</div>
</div>
</div>
</div>
