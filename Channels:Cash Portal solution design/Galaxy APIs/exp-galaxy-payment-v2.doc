<pre style=3D"font-size: 12px;">openapi: 3.0.3
info:
  version: 1.0.0
  title: Galaxy-Payment Experience API
  description: This API allows interaction for the Galaxy SPA with the Paym=
ent Initiation API and allows retrieving of payees for the logged in user. =
It supports getting arrangements too
  contact:
    url: https://mesh.westpac.com.au/components/microFrontends/galaxy-payme=
nt
  x-baseSchemaVersion: 0.8.0
servers:
  - url: /exp/galaxy/payment/v2
components:
  securitySchemes:
    BasicAuth:
      type: http
      scheme: basic
    ScopedAccess:
      description: ScopedAccess is used to provide ACL
      type: oauth2
      flows:
        implicit:
          authorizationUrl: https://ignored-for-scoped-access
          scopes: {}
  parameters:
    x-channelType:
      name: x-channelType
      in: header
      description: Channel Type
      required: true
      schema:
        type: string
        enum:
          - Internal
    x-brandId:
      name: x-brandId
      in: header
      description: |-
        The `brand` as per Enterprise Reference Data
        NOTE:
        - The values here were previously aligned to NetIQ brands which map=
 to the Gel themes
        - These have now been normalised as per ERD from UI
        - The major changes are for STG where as per ERD the value is SGB
        All Experience APIs MUST change their swaggers to align with this c=
hange.
      required: true
      schema:
        type: string
        enum:
          - WBC
          - SGB
          - BSA
          - BOM
          - RAMS
          - WNZL
    x-authorization:
      name: x-authorization
      in: header
      description: The credentials required for authentication or authorisa=
tion to a downstream system.  This header must follow the same conventions =
as for the standard HTTP authorization header as defined in RFC2616 (ie. sc=
heme and credentials).
      schema:
        type: string
        pattern: ^Bearer\s[\w\.-]+$
    x-deviceExperience:
      name: x-deviceExperience
      in: header
      description: |-
        Non-functional header to provide telemetry and debugging aids when =
logged to Splunk. The proposal is to have a single string encoded value wit=
h the below attributes to start off with. Other attributes can be added as =
the need arises

        TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWPORT:=
xs|sm|md|lg,ORIENTATION:portrait|landscape
      schema:
        type: array
        items:
          type: string
          pattern: ^[\w:,-]{1,250}$
      style: simple
      explode: false
      required: true
    x-deviceFingerprint:
      name: x-deviceFingerprint
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        A unique device finger print generated either by
          1. The NativeJS interface when device detection alludes to native=
 app
          2. The external RSA vendor javascript when device detection is no=
t a native app
      schema:
        type: string
        maxLength: 8000
        pattern: ^[a-zA-Z0-9%+=3D]+$
      required: false
    x-devicePerms:
      name: x-devicePerms
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        Device permissions as returned by the NativeJS interface when devic=
e detection alludes to native app
        This header will not be present when a SAFI request is made from a =
browser
      schema:
        type: string
        pattern: ^[a-zA-Z0-9%+=3D]+$
        maxLength: 500
      required: false
    x-onBehalfOfId:
      name: x-onBehalfOfId
      in: header
      description: The unique identifier for the party on whose behalf the =
user identified by x-userId is acting. (eg. Customer internal identifier su=
ch as CIS/GCIS key).
      schema:
        type: string
        pattern: ^[\d]{7,16}$
      required: false
    x-originatingDeviceId:
      name: x-originatingDeviceId
      in: header
      description: Identifies the device from which this request originated=
.  The device could be a staff computer, ATM, internal server, mobile devic=
e.
      schema:
        type: string
        pattern: /^[\w ]+$/
        maxLength: 300
      required: false
    x-consumer-id:
      name: x-consumer-id
      in: header
      description: Identifies the calling application of the API. DO NOT PO=
PULATE as Gateway will inject this value. Also gateway overrides the header=
 if already present
      schema:
        type: string
        pattern: /^[\w ]+$/
        maxLength: 300
      required: false
    x-idempotency-key:
      name: x-idempotency-key
      in: header
      description: A unique identifier for a transaction to support idempot=
ency checks
      schema:
        type: string
        description: A unique identifier
        format: uuid
        pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{=
3}-[0-9a-f]{12}$
      required: true
    sort:
      name: sortBy
      in: query
      schema:
        type: string
        pattern: /^[(\,|\+|\-)*\w]+$/
        maxLength: 500
      description: This field allows the client to provide a list of field =
and sorting order for the server to return the response in. You can indicat=
e using a + sign for ascending sorting and - for descending sorting in fron=
t of the field. You can do multi colomn sorting by comma sepearting the fie=
lds and their sorting type. Eg `?sortBy=3D-last_modified,+email` or `?sortB=
y=3D+email`
    search:
      name: search
      in: query
      description: This field allows a client to provide the a search query=
 (account name, bsb, account number) to narrow down the respones returned b=
y the server.
      schema:
        type: string
        pattern: /^[\w ]+$/
        minLength: 2
        maxLength: 500
    pageSize:
      name: pageSize
      in: query
      description: Number of entries to be returned in a single page
      schema:
        type: integer
        format: int32
        minimum: 100
        maximum: 1000
        default: 1000
      required: false
      example: 100
    pageKey:
      name: pageKey
      in: query
      description: The key identifying the page of data to be returned
      schema:
        type: integer
        format: int32
        maximum: 1000
        default: 0
      required: false
    arrangementStatus:
      name: arrangementStatus
      description: Account status. "ACTIVE" will fetch arrangements which a=
re active only. "ACTIVE_AND_INACTIVE" will fetch arrangements which are Act=
ive and Inactive both. If user is not passing this query parameter then def=
ault option of ACTIVE_AND_INACTIVE will be used.
      in: query
      required: false
      example: ACTIVE_AND_INACTIVE
      schema:
        type: string
        pattern: ^(ACTIVE|ACTIVE_AND_INACTIVE){1}$
        enum:
          - ACTIVE
          - ACTIVE_AND_INACTIVE
    pdpQueryAction:
      name: pdpQueryAction
      description: PDP Query Action. This field allows the client to specif=
y actions for the PDP query.
      in: query
      required: false
      example: VIEW_PAYMENT
      schema:
        type: string
        pattern: ^(VIEW_PAYMENT|INITIATE_PAYMENT|INITIATE_TRANSFER){1}$
        enum:
          - VIEW_PAYMENT
          - INITIATE_PAYMENT
          - INITIATE_TRANSFER
  responses:
    200SuccessResponse:
      description: Success
      content:
        application/json:
          schema:
            type: string
            description: Contains a generic success response
    400ErrorResponse:
      description: Bad Request
      content:
        application/json:
          schema:
            type: object
            description: Contains list of Errors
            properties:
              result:
                type: object
                description: Contains list of Errors
                properties:
                  errors:
                    type: array
                    items:
                      type: object
                      description: Represents an individual error
                      properties:
                        code:
                          description: Error Code
                          type: integer
                          format: int32
                          example: 400
                        message:
                          description: Error Message
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Bad Request
                        details:
                          description: |
                            Detailed information about the error. If it is =
an error scenario where an error mappping is required as per MAD teams' spe=
cification, the string will contain the UIError object.
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Check logs for details
                      required:
                        - code
                        - message
    401ErrorResponse:
      description: |
        &lt;br&gt;__UNAUTHORIZED__
        &lt;br&gt; Possible errors
        &lt;table&gt;
          &lt;tr&gt;
            &lt;td&gt;Error Code&lt;/td&gt;
            &lt;td&gt;Error Message&lt;/td&gt;
            &lt;td&gt;Error Description&lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td&gt;8125&lt;/td&gt;
            &lt;td&gt;Authoriser Approval Required&lt;/td&gt;
            &lt;td&gt;The request is pending approval {workflowId}&lt;/td&g=
t;
          &lt;/tr&gt;
        &lt;/table&gt;
      content:
        application/json:
          schema:
            type: object
            description: Contains list of Errors
            properties:
              result:
                type: object
                description: Contains list of Errors
                properties:
                  errors:
                    type: array
                    items:
                      type: object
                      description: Represents an individual error
                      properties:
                        code:
                          description: Error Code
                          type: integer
                          format: int32
                          example: 400
                        message:
                          description: Error Message
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Bad Request
                        details:
                          description: |
                            Detailed information about the error. If it is =
an error scenario where an error mappping is required as per MAD teams' spe=
cification, the string will contain the UIError object.
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Check logs for details
                      required:
                        - code
                        - message
    403ErrorResponse:
      description: Access denied. Require further information.
      content:
        application/json:
          schema:
            type: object
            description: Contains list of Errors
            properties:
              result:
                type: object
                description: Contains list of Errors
                properties:
                  errors:
                    type: array
                    items:
                      type: object
                      description: Represents a safi error. This error woul=
d tell what sort of safi challenge is requested and also returns token whic=
h should be used in each subsequent calls.
                      properties:
                        code:
                          description: Error Code
                          type: integer
                          format: int32
                        message:
                          description: Error Message
                          type: string
                        details:
                          description: |
                            Detailed information about the error. If it is =
an error scenario where an error mappping is required as per MAD teams' spe=
cification, the string will contain the UIError object.
                          type: object
                          properties:
                            analysis:
                              description: safi analyse result code.
                              type: string
                              enum:
                                - ALLOW
                                - DENY
                                - CHALLENGE
                                - DELAY_AND_REVIEW
                                - REVIEW
                            challengeType:
                              description: safi analyse result with challen=
ge type.
                              type: string
                              enum:
                                - SMSOTP
                                - SECURID
                                - EXEMPTION_TEMP
                                - EXEMPTION_PERM
                            phoneNumber:
                              description: safi analyse result challenge de=
tails has masked phoneNumber.
                              type: string
                              maxLength: 16
                              pattern: ^[\w]+$
                            token:
                              description: An encrypted string which has sa=
fi initiated transaction and device token details.
                              type: string
                              maxLength: 8000
                              pattern: ^[a-zA-Z0-9+=3D\/]+$
    403VerificationErrorResponse:
      description: Access denied. Require further information.
      content:
        application/json:
          schema:
            type: object
            description: Contains list of Errors
            properties:
              errors:
                type: array
                items:
                  type: object
                  description: Represents a safi error. This error would te=
ll what sort of safi challenge is requested and also returns token which sh=
ould be used in each subsequent calls.
                  properties:
                    code:
                      description: Error Code
                      type: integer
                      format: int32
                    message:
                      description: Error Message
                      type: string
                    details:
                      description: |
                        Detailed information about the error.
                      type: object
                      properties:
                        analysis:
                          description: safi analyse result code.
                          type: string
                          enum:
                            - ALLOW
                            - DENY
                            - CHALLENGE
                            - DELAY_AND_REVIEW
                            - REVIEW
                        challengeType:
                          description: safi analyse result with challenge t=
ype.
                          type: string
                          enum:
                            - SMSOTP
                            - SECURID
                            - EXEMPTION_TEMP
                            - EXEMPTION_PERM
                        phoneNumber:
                          description: safi analyse result challenge detail=
s has masked phoneNumber.
                          type: string
                          maxLength: 16
                          pattern: ^[\w]+$
                        token:
                          description: An encrypted string which has safi i=
nitiated transaction and device token details.
                          type: string
                          maxLength: 8000
                          pattern: ^[a-zA-Z0-9+=3D\/]+$
                        verification:
                          description: safi verification result code.
                          type: string
                          enum:
                            - ACCESS_DENIED_OTP_INCORRECT
                            - NEXT_CODE_REQUIRED
                        remainingAttempts:
                          description: If the authentication failed this el=
ement will be populated with the number of remaining authentication attempt=
s before the device is suspended in this network.
                          type: integer
                          format: int32
    500ErrorResponse:
      description: Internal Server Error
      content:
        application/json:
          schema:
            type: object
            description: Contains list of Errors
            properties:
              result:
                type: object
                description: Contains list of Errors
                properties:
                  errors:
                    type: array
                    items:
                      type: object
                      description: Represents an individual error
                      properties:
                        code:
                          description: Error Code
                          type: integer
                          format: int32
                          example: 400
                        message:
                          description: Error Message
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Bad Request
                        details:
                          description: |
                            Detailed information about the error. If it is =
an error scenario where an error mappping is required as per MAD teams' spe=
cification, the string will contain the UIError object.
                          type: string
                          pattern: ^[\w ]+$
                          maxLength: 32
                          example: Check logs for details
                      required:
                        - code
                        - message
    200healthCheckStatusResponse:
      description: healthcheck status
      content:
        application/json:
          schema:
            description: healthcheck status
            properties:
              status:
                type: string
                enum:
                  - success
    200contextHandoverResponse:
      description: get context handover data
      content:
        application/json:
          schema:
            type: object
            description: returns the context handover data from redis cache
            properties:
              entities:
                description: N/A
                type: object
                properties:
                  contexts:
                    description: N/A
                    type: array
                    items:
                      description: returns the list of fields from the redi=
s cache
                      type: object
                      properties:
                        id:
                          description: An unique context ref identifier.
                          type: string
                          maxLength: 14
                          pattern: ^[\w-]+$
                        fields:
                          type: array
                          description: List of fields stored as key value p=
airs in the redis
                          items:
                            description: returns the list of fields from th=
e redis cache
                            type: object
                            properties:
                              fieldName:
                                description: field name.
                                type: string
                                maxLength: 256
                                pattern: ^[\w-]+$
                              value:
                                description: value of the field
                                maxLength: 256
                                pattern: ^[\w-\s\.]+$
                                type: string
              result:
                type: object
                properties:
                  contexts:
                    description: A list of ids relating to the resource tha=
t was requested
                    type: array
                    items:
                      description: Entity Id
                      type: string
    200PostContextHandoverResponse:
      description: get reference id after posting the context handover
      content:
        application/json:
          schema:
            type: object
            description: returns the context handover data and reference id=
 for the posted contexts
            properties:
              entities:
                description: N/A
                type: object
                properties:
                  contexts:
                    description: N/A
                    type: array
                    items:
                      description: context handover block to hold contextId=
.
                      type: object
                      properties:
                        id:
                          description: It corresponds to the referenceId at=
tribute from cap api response.
                          type: string
                          maxLength: 14
                          pattern: ^[\w-]+$
                        referenceId:
                          description: It corresponds to the referenceId at=
tribute from cap api response.
                          type: string
                          maxLength: 14
                          pattern: ^[\w-]+$
                        redirectUrl:
                          description: The url that the application is expe=
cted to redirect.
                          type: string
                          maxLength: 2000
                          pattern: ^((http[s]?):\/)?\/?([^:\/\s]+)((\/\w+)*=
\/)([\w\-\.]+[^#?\s]+)(.*)?(#[\w\-]+)?$
                        targetFrameName:
                          description: The target frame for destination app=
lication.
                          type: string
                          maxLength: 256
                          pattern: ^[\w-]+$
              result:
                type: object
                properties:
                  contexts:
                    description: A list of ids relating to the resource tha=
t was requested
                    type: array
                    items:
                      description: Entity Id
                      type: string
    200PostOtpChallengeResponse:
      description: should return the challenge
      content:
        application/json:
          schema:
            type: object
            description: otp challenge response details
            properties:
              entities:
                description: otp challenge response
                type: object
                properties:
                  challenges:
                    description: N/A
                    type: array
                    items:
                      description: fraud assessment response data
                      type: object
                      properties:
                        id:
                          description: unique identifier
                          type: string
                          maxLength: 30
                          pattern: ^[a-zA-Z0-9]+$
                        analysis:
                          description: safi analyse result code.
                          type: string
                          enum:
                            - ALLOW
                            - DENY
                            - CHALLENGE
                            - DELAY_AND_REVIEW
                            - REVIEW
                        challengeType:
                          description: safi analyse result with challenge t=
ype.
                          type: string
                          enum:
                            - SMSOTP
                            - SECURID
                            - EXEMPTION_TEMP
                            - EXEMPTION_PERM
                        phoneNumber:
                          description: safi analyse result challenge detail=
s has masked phoneNumber.
                          type: string
                          maxLength: 16
                          pattern: ^[\w]+$
                        token:
                          description: An encrypted string which has safi i=
nitiated transaction and device token details.
                          type: string
                          maxLength: 8000
                          pattern: ^[a-zA-Z0-9+=3D\/]+$
              result:
                type: object
                properties:
                  challenges:
                    description: A list of ids relating to the resource tha=
t was requested
                    type: array
                    items:
                      description: Entity Id
                      type: string
    204PostOtpResponse:
      description: successful but no response
    204PostLogsResponse:
      description: successful
  schemas:
    LogRequest:
      type: object
      description: Contains a list of logs
      required:
        - logs
      properties:
        logs:
          type: array
          items:
            type: object
            description: A single log record
            required:
              - id
              - timestamp
              - scope
              - level
            properties:
              id:
                type: string
                pattern: ^[\w-]{7,14}$
                description: the unique id representing the log record
              timestamp:
                type: string
                description: the utc timestamp of the log record as per rfc=
-3339 (https://tools.ietf.org/html/rfc3339#section-5.6)
                format: date-time
              scope:
                type: string
                pattern: ^[\w-@/]{1,100}$
                description: The ui functional area that triggers the log.
                example: '@wdpui/common-with-theme'
              level:
                type: string
                description: The log level for filtering.
                enum:
                  - ERROR
                  - WARN
                  - INFO
                  - DEBUG
                  - SILLY
              message:
                type: string
                pattern: ^[\w\-:;,.+#\[\]@()${}=3D!'"\\\/ ]+$
                maxLength: 2000
                description: The message including payload information that=
 is intended for logging.
                example: '{"type": "@@redux-form/REGISTER_FIELD","meta":{"f=
orm": "payments"},"payload":{"name":"name","type":"Field"}}'
    Log:
      type: object
      description: A single log record
      required:
        - id
        - timestamp
        - scope
        - level
      properties:
        id:
          type: string
          pattern: ^[\w-]{7,14}$
          description: the unique id representing the log record
        timestamp:
          type: string
          description: the utc timestamp of the log record as per rfc-3339 =
(https://tools.ietf.org/html/rfc3339#section-5.6)
          format: date-time
        scope:
          type: string
          pattern: ^[\w-@/]{1,100}$
          description: The ui functional area that triggers the log.
          example: '@wdpui/common-with-theme'
        level:
          type: string
          description: The log level for filtering.
          enum:
            - ERROR
            - WARN
            - INFO
            - DEBUG
            - SILLY
        message:
          type: string
          pattern: ^[\w\-:;,.+#\[\]@()${}=3D!'"\\\/ ]+$
          maxLength: 2000
          description: The message including payload information that is in=
tended for logging.
          example: '{"type": "@@redux-form/REGISTER_FIELD","meta":{"form": =
"payments"},"payload":{"name":"name","type":"Field"}}'
    Success:
      type: string
      description: Contains a generic success response
    Errors:
      type: object
      description: Contains list of Errors
      properties:
        errors:
          type: array
          items:
            type: object
            description: Represents an individual error
            properties:
              code:
                description: Error Code
                type: integer
                format: int32
                example: 400
              message:
                description: Error Message
                type: string
                pattern: ^[\w ]+$
                maxLength: 32
                example: Bad Request
              details:
                description: |
                  Detailed information about the error. If it is an error s=
cenario where an error mappping is required as per MAD teams' specification=
, the string will contain the UIError object.
                type: string
                pattern: ^[\w ]+$
                maxLength: 32
                example: Check logs for details
            required:
              - code
              - message
    ErrorResult:
      type: object
      description: Contains list of Errors
