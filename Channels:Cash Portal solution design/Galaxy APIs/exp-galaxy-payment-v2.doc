                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
  /aliasLookupByBeneId:
    post:
      description: This endpoint allows to resolve a PayID alias by benefic=
iary ID
      operationId: postAliasLookupByBeneId
      tags:
        - postAliasLookupByBeneId
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        content:
          application/json:
            schema:
              description: Represents Alias Lookup by Beneficiary ID Reques=
t Object
              type: object
              properties:
                id:
                  description: Beneficiary Id
                  type: string
                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab=
][0-9a-f]{3}-[0-9a-f]{12}$
              required:
                - id
      responses:
        '200':
          description: Alias lookup details success response.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      aliasLookupByBeneId:
                        type: array
                        items:
                          description: Represents The Alias Lookup By Benef=
iciary ID Response Object
                          type: object
                          properties:
                            id:
                              description: A unique id generated for a look=
up result which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            aliasType:
                              description: Alias Type of the beneficiary
                              maxLength: 4
                              enum:
                                - EMAL
                                - TELI
                                - AUBN
                                - ORGN
                              type: string
                            name:
                              description: Nickname of the beneficiary
                              type: string
                              example: John
                              minLength: 1
                              maxLength: 70
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                            resolutionDateTime:
                              description: The date/time when the alias was=
 resolved.
                              type: string
                              format: date-time
                            returnCode:
                              description: The response code mapped from th=
e provider service.
                              pattern: ^[0-9]+$
                              minLength: 1
                              maxLength: 5
                              example: 200
                  result:
                    type: object
                    properties:
                      aliasLookupByBeneId:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      aliasLookupByBeneId:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
