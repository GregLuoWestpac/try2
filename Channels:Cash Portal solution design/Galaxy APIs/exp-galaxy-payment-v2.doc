  /bsbLookup:
    get:
      description: This endpoint allows to lookup a BSB
      operationId: getBsbLookup
      tags:
        - Lookup
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: BSB
          in: query
          description: The BSB number of the account
          required: true
          schema:
            description: Bank State Branch Number
            type: string
            pattern: ^\d{6}$
            example: '035845'
      responses:
        '200':
          description: The resolved BSB Lookup response
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      bsbLookup:
                        type: array
                        items:
                          description: Represents BSB Lookup Response Objec=
t
                          type: object
                          properties:
                            id:
                              description: A unique id generated for a look=
up result which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            branchId:
                              description: Represents the branch Id for whi=
ch the reference data is to be retrieved
                              type: string
                              pattern: ^[\w ]+$
                              minLength: 1
                              maxLength: 30
                              example: '501226'
                            BSB:
                              description: Bank State Branch Number
                              type: string
                              pattern: ^\d{6}$
                              example: '035845'
                            branchName:
                              description: Name of the Branch
                              type: string
                              pattern: ^[\w ]+$
                              minLength: 1
                              maxLength: 70
                              example: Central
                            bankName:
                              description: Name of Bank
                              minLength: 1
                              maxLength: 70
                              example: Westpac Banking Corporation
                              type: string
                              pattern: ^[\w ]+$
                            bankCode:
                              description: Branch Identification code
                              type: string
                              pattern: ^[\w ]+$
                              minLength: 1
                              maxLength: 70
                              example: '03'
                            brand:
                              description: A set of available predefined va=
lues representing the label names used by Westpac for its products and serv=
ices
                              type: string
                              enum:
                                - WBC
                                - SGB
                                - BOM
                                - BSA
                              example: WBC
                            branchStatus:
                              description: Status of the Branch
                              type: string
                              enum:
                                - OPERATIONAL
                                - CLOSED
                              example: OPERATIONAL
                            branchAvailable:
                              description: Branch Available indicate if the=
 BSB is valid for origination
                              type: boolean
                              example: true
                            address:
                              description: Address of the Branch
                              type: object
                              properties:
                                addressLine1:
                                  description: First line of the address
                                  type: string
                                  pattern: ^[\w ]+$
                                  minLength: 1
                                  maxLength: 100
                                  example: 123 Main St
                                addressLine2:
                                  description: Second line of the address
                                  type: string
                                  pattern: ^[\w ]+$
                                  minLength: 0
                                  maxLength: 100
                                  example: Suite 456
                                city:
                                  description: City of the address
                                  type: string
                                  pattern: ^[\w ]+$
                                  minLength: 1
                                  maxLength: 50
                                  example: Sydney
                                state:
                                  description: State of the address
                                  type: string
                                  pattern: ^[\w ]+$
                                  minLength: 1
                                  maxLength: 50
                                  example: NSW
                                postCode:
                                  type: string
                                  description: postcode
                                  maxLength: 10
                                  pattern: ^\w+$
                  result:
                    type: object
                    properties:
                      bsbLookup:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      bsbLookup:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /divisionList:
    get:
      description: The endpoint will query PDP to retrieve the divisions ba=
sed on OrgCISKey and logged in user's CISKey
      operationId: getDivisionList
      tags:
        - getDivisionList
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
        - name: pdpQueryAction
          description: PDP Query Action. This field allows the client to sp=
ecify actions for the PDP query.
          in: query
          required: false
          example: VIEW_PAYMENT
          schema:
            type: string
            pattern: ^(VIEW_PAYMENT|INITIATE_PAYMENT|INITIATE_TRANSFER){1}$
            enum:
              - VIEW_PAYMENT
              - INITIATE_PAYMENT
              - INITIATE_TRANSFER
      responses:
        '200':
          description: The retrieved divisions for the user / groupId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      divisionList:
                        type: array
                        items:
                          allOf:
                            - type: object
                              properties:
                                divisionName:
                                  description: Division Name
                                  example: AUD Group
                                  type: string
                                  maxLength: 70
                                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                divisionId:
                                  description: Division id
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            - type: object
                              properties:
                                id:
                                  description: A unique identifier
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                  result:
                    type: object
                    properties:
                      divisionList:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      divisionList:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /transferCreate:
    post:
      tags:
        - postTransferCreate
      description: |
        This endpoint submits a payment order only for users who gets INITI=
ATE_TRANSFER permutations
      operationId: postTransferCreate
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: x-idempotency-key
          in: header
          description: A unique identifier for a transaction to support ide=
mpotency checks
          schema:
            type: string
            description: A unique identifier
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
          required: true
        - name: x-channelRequestId
          in: header
          description: |
            Unique identifier for the request authorisation. This is used t=
o correlate the request in the maker-checker.
            This is generated by the channels and should be unique across a=
ll requests.
          required: true
          schema:
            description: Pattern for the channel request ID
            type: string
            pattern: ^[\w-]{15,36}$
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        required: true
        description: Initiate the payment through FIS POM API and return th=
e code for success or error
        content:
          application/json:
            schema:
              description: Transfer details object for initiating a transfe=
r.
              type: object
              properties:
                clientContext:
                  type: object
                  properties:
                    channelType:
                      description: |-
                        Channel sending the request. Can be empty or null.
                          e.g.
                        - W1C_O_B_D_CP - W1C_O_A_D_SP
                      type: string
                      maxLength: 100
                      pattern: ^[A-Z0-9_-]+$
                creditTransferTransactionInformation:
                  type: array
                  items:
                    description: Provides information on the individual tra=
nsaction(s) included in the message.
                    type: object
                    properties:
                      creditor:
                        type: object
                        properties:
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. (Creditor name or Alias Sho=
rt Name).&lt;br&gt; Usage- Caller to map creditor's name to this field.
                            maxLength: 140
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                        required:
                          - name
                      creditorAccount:
                        type: object
                        description: Provides the details to identify an ac=
count.
                        properties:
                          identification:
                            description: Full account number including BSB =
(without any separators or spaces).&lt;br&gt; Usage- Caller to map debit ac=
count number to this field.
                            maxLength: 34
                            type: string
                            pattern: ^[A-Za-z0-9\.]+$
                          issuer:
                            description: Entity that assigns the identifica=
tion.&lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number o=
f the debit account.
                            type: string
                            maxLength: 6
                            pattern: ^\d{6}$
                          name:
                            description: Name by which a party is known, an=
d which is usually used to identify that party. For NPP payment, this is th=
e Full Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this =
field is expected to be provided by the payment enrichment system.
                            maxLength: 70
                            type: string
                            pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)=
).*[\s\S]*$
                          schemeName:
                            description: |-
                              Name of the identification scheme, in a coded=
 form as published in an external list.&lt;br&gt;
                               Usage- Caller to set this field to 'BBAN' to=
 represent Australian Bank-State-Branch Code (BSB) identification.
                            maxLength: 4
                            type: string
                            pattern: ^\w+$
                          type:
                            description: Debtor's account type represented =
as Canonical Product Code (CPC).&lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^\w+$
                      creditorAgent:
                        type: object
                        properties:
                          BICFI:
                            description: Code allocated to a financial inst=
itution by the ISO 9362 Registration Authority as described in ISO 9362 "Ba=
nking - Banking telecommunication messages - Business identifier code (BIC)=
".&lt;br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SON=
E'.
                            type: string
                            maxLength: 11
                            pattern: ^\w+$
                          financialInstitutionIdentification:
                            type: object
                            properties:
                              clearingSystemMemberIdentification:
                                description: Unique identification of a cle=
aring system member.
                                type: object
                                properties:
                                  clearingSystemIdentification:
                                    type: object
                                    properties:
                                      code:
                                        description: Service level Identifi=
cation Code
                                        type: string
                                        enum:
                                          - AUBSB
                        required:
                          - BICFI
                      endToEndIdentification:
                        description: A reference assigned by the initiating=
 party to unambiguously identify the payment. This identifier is passed on =
unchanged throughout the entire end-to-end payment flow. The end-to-end ide=
ntification can be used for reconciliation or to link tasks relating to the=
 payment. It can be included in several messages related to the payment.&lt=
;br&gt; Example- INV-123456790&lt;br&gt; Usage- Caller to map customer's pa=
yment reference to this field.  For NPP Osko payments. May only be provided=
 if customerType in the header is set to 'Organisation'. Must be set to 'NO=
TPROVIDED' if customerType in the header is set to 'Individual'.
                        maxLength: 35
                        example: INV-123456790
                        type: string
                        pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[=
\s\S]*$
                      instructedAmount:
                        description: This object will be deprecated from Ma=
y-2026-ERM release. Use CurrencyAmount definition instead.
                        type: object
                        deprecated: true
                        properties:
                          amount:
                            description: The payment amount before deductio=
n of charges, expressed in the currency as ordered by the initiating party.=
&lt;br&gt; Usage- Caller to map payment amount to this field.
                            type: string
                            pattern: \d{1,13}\.?\d{0,3}$
                          currency:
                            description: A code allocated to a currency by =
a Maintenance Agency under an international identification scheme, as descr=
ibed in the latest edition of the international standard ISO 4217 =E2=80=9C=
Codes for the representation of currencies and funds=E2=80=9D.&lt;br&gt; Us=
age- Caller to set 'AUD' to this field.
                            type: string
                            pattern: ^[A-Z]{3}$
                            example: AUD
                        required:
                          - amount
                          - currency
                      instructionForDebtorAgent:
                        description: Further information related to the pro=
cessing of the payment instruction, that may need to be acted upon by the d=
ebtor agent, depending on agreement between debtor and the debtor agent. Wh=
en present, it applies to ALL credit transfer transaction information occur=
rences, present in the payment information. &lt;br&gt; Usage- For future us=
e.
                        maxLength: 140
                        type: string
                        pattern: /^[\w\-]+$/
                      paymentTypeInformation:
                        description: Set of elements used to further specif=
y the type of transaction.
                        type: object
                        properties:
                          categoryPurpose:
                            description: Specifies the high-level purpose o=
f the instruction based on a set of pre-defined categories. This is used by=
 the initiating party to provide information concerning the processing of t=
he payment. &lt;br&gt; Usage- For future use.
                            maxLength: 35
                            type: string
                            pattern: ^[\w ]+$
                          instructionPriority:
                            description: |-
                              Indicator of the urgency or order of importan=
ce that the instructing party would like the instructed party to apply to t=
he processing of the instruction. The possible values are-&lt;br&gt;
                                HIGH: High. &lt;br&gt;
                                NORM: Normal.&lt;br&gt;
                                Usage- For future use.
                            enum:
                              - HIGH
                              - NORM
                            type: string
                          serviceLevel:
                            description: |-
                              Specifies a pre-agreed service or level of se=
rvice between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Att=
ended payments are defined as Payments whereby the sending participant requ=
ires a real-time response to their payment instruction&lt;br&gt; UNAT - For=
 'Unattended' transaction. Unattended payments are defined as Payments wher=
eby the sending participant does not require a real-time response to their =
payment instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&l=
t;br&gt;
                              creditTransferInformation Description - Speci=
fies a pre-agreed service or level of service between the parties.&lt;br&gt=
;
                              Usage- Caller to set this field to 'npp.clear=
.01-x2p1.01' for NPP Osko payments.
                            maxLength: 35
                            type: string
                            pattern: /^[\w\.\-]+$/
                      remittanceInformation:
                        description: Remittance information to be supplied =
with the payment.
                        type: object
                        properties:
                          unstructured:
                            type: array
                            maxItems: 2
                            description: Information supplied to enable the=
 matching/reconciliation of an entry with the items that the payment is int=
ended to settle, such as commercial invoices in an accounts'' receivable sy=
stem.
                            items:
                              maxLength: 140
                              description: Matches any string, including Un=
icode characters, and emoji, except semicolon (;), double hyphen (--), left=
 and right curly bracket ({ }), less than (&lt;),  greater than (&gt;), per=
centage sign (%), hash (#), quotation mark ("), and equal sign (=3D).  Use =
for fields that are protected by perfect express sanitizer library
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                      supplementaryData:
                        description: Additional Westpac Data Elements to su=
pport the PAYMENT transaction (Credit).
                        type: object
                        properties:
                          isNewPayee:
                            type: boolean
                            description: Indicates whether the payment is f=
or an existing beneficiary or a new/unsaved beneficiary.
                            example: false
                          aliasId:
                            description: |-
                              aka Payment Alias also known as PayID.  This =
field will be populated if there was a payId type payment,
                              &lt;br&gt;Usage format-
                                 &lt;br&gt;For type TELI-  The telephone nu=
mber must consist of a =E2=80=9C+=E2=80=9D followed by the country code (fr=
om 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any combina=
tion of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1=
,1}[0-9]{1,29}$ Example- +61-123456789
                                &lt;br&gt; For type EMAL- Consists of a cha=
racter string with a maximum length of 256 characters. This must include th=
e =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and no wh=
ite spaces. Only lower case characters will be supported.
                                 Format pattern- Maximum of 256 characters =
^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-=
]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)=
$ Example- 123@NPP.com
                                &lt;br&gt; For type AUBN- This is assigned =
by the Australian Taxation Office to identify an individual Australian Busi=
ness. Consists of a nine-to-eleven digit number. If the length is 9 digits =
than the last digit is the check digit. If the length is 11 digits, then an=
 algorithm is used to validate the entire value as there is no check digit =
as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                 &lt;br&gt; For type ORGN- The Identifier m=
ust be representative of the company name, organisation name, trading name,=
 associated product, campaign or an identifier recognisable as associated w=
ith the specific business or organisation, with no whitespace at the beginn=
ing or end. Maximum of 256 characters in lower case, to be drawn from Print=
able ASCII (decimal 32-126) and without leading or trailing whitespace. For=
 avoidance of doubt, upper case letters (A-Z, decimal 65-90) are excluded.
                                 Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!=
-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                            maxLength: 256
                            type: string
                            pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}=
~\.\x20-\x7E\+\-]+$
                            example: tay.tay@westpac.com.au
                          aliasType:
                            description: |-
                              For a PayID payment, the type of the PayID.
                                &lt;br&gt;TELI- Telephone Number
                                &lt;br&gt;EMAL- Email Address
                                &lt;br&gt;AUBN- Australian Business Number
                                &lt;br&gt;ORGN- Organisation ID
                            maxLength: 4
                            enum:
                              - EMAL
                              - TELI
                              - AUBN
                              - ORGN
                            type: string
                          beneficiaryId:
                            description: Usage- Caller to map this field wi=
th the Beneficiary Id of the recipient for the On-Platform payment
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    required:
                      - instructedAmount
                      - creditor
                      - creditorAgent
                debtor:
                  description: Party that owes an amount of money to the (u=
ltimate) creditor.
                  type: object
                  properties:
                    identification:
                      description: Unique and unambiguous identification of=
 a person. For example, CIS Key of the debtor account.&lt;br&gt; Usage- Cal=
ler to map debtor's identification to this field.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    issuer:
                      description: Entity that assigns the identification. =
 Example- WPAC &lt;br&gt; Usage- Caller to set this field to 'WPAC'.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify sending party.&lt;br&gt; Usage- Caller to map=
 debtor's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                debtorAccount:
                  required:
                    - identification
                    - schemeName
                    - issuer
                  type: object
                  description: Provides the details to identify an account.
                  properties:
                    identification:
                      description: Full account number including BSB (witho=
ut any separators or spaces).&lt;br&gt; Usage- Caller to map debit account =
number to this field.
                      maxLength: 34
                      type: string
                      pattern: ^[A-Za-z0-9\.]+$
                    issuer:
                      description: Entity that assigns the identification.&=
lt;br&gt; Usage- Caller to map this field to the 6-digit BSB number of the =
debit account.
                      type: string
                      maxLength: 6
                      pattern: ^\d{6}$
                    name:
                      description: Name by which a party is known, and whic=
h is usually used to identify that party. For NPP payment, this is the Full=
 Legal Account Name (FLAN). &lt;br&gt; Usage- For NPP payments, this field =
is expected to be provided by the payment enrichment system.
                      maxLength: 70
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                    schemeName:
                      description: |-
                        Name of the identification scheme, in a coded form =
as published in an external list.&lt;br&gt;
                         Usage- Caller to set this field to 'BBAN' to repre=
sent Australian Bank-State-Branch Code (BSB) identification.
                      maxLength: 4
                      type: string
                      pattern: ^\w+$
                    type:
                      description: Debtor's account type represented as Can=
onical Product Code (CPC).&lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^\w+$
                debtorAgent:
                  type: object
                  properties:
                    BICFI:
                      description: Code allocated to a financial institutio=
n by the ISO 9362 Registration Authority as described in ISO 9362 "Banking =
- Banking telecommunication messages - Business identifier code (BIC)".&lt;=
br&gt; Usage- Caller to set this field to the new WIB BIC 'WPACAU2SONE'.
                      type: string
                      maxLength: 11
                      pattern: ^\w+$
                    financialInstitutionIdentification:
                      type: object
                      properties:
                        clearingSystemMemberIdentification:
                          description: Unique identification of a clearing =
system member.
                          type: object
                          properties:
                            clearingSystemIdentification:
                              type: object
                              properties:
                                code:
                                  description: Service level Identification=
 Code
                                  type: string
                                  enum:
                                    - AUBSB
                  required:
                    - BICFI
                initiatingParty:
                  description: Party that initiates the payment. This can e=
ither be the debtor or the party that initiates the credit transfer on beha=
lf of the debtor.
                  type: object
                  properties:
                    name:
                      description: Initiating party's full name.&lt;br&gt;U=
sage- Caller to map initiating party's name to this field.
                      maxLength: 140
                      type: string
                      pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s=
\S]*$
                instructionForDebtorAgent:
                  description: Further information related to the processin=
g of the payment instruction, that may need to be acted upon by the debtor =
agent, depending on agreement between debtor and the debtor agent. When pre=
sent, it applies to ALL credit transfer transaction information occurrences=
, present in the payment information. &lt;br&gt; Usage- For future use.
                  maxLength: 140
                  type: string
                  pattern: /^[\w\-]+$/
                paymentInformation:
                  description: Set of characteristics that applies to the p=
ayment instruction.
                  type: object
                  properties:
                    numberOfTransactions:
                      description: Number of individual transactions contai=
ned in the payment information group.&lt;br&gt; Usage- Caller to set this f=
ield to 1 to indicate there's only one transaction in the payment. For Bulk=
 payment in the future, this field will need to be set by the caller to the=
 actual number of transactions in the bulk instruction.
                      pattern: '[0-9]{1,15}$'
                      type: string
                paymentMethod:
                  description: Specifies the means of payment that will be =
used to move the amount of money.&lt;br&gt; Usage- Caller to set this field=
 to 'TRF'.
                  type: string
                  enum:
                    - TRF
                    - CHK
                    - TRA
                  example: TRF
                paymentTypeInformation:
                  description: Set of elements used to further specify the =
type of transaction.
                  type: object
                  properties:
                    categoryPurpose:
                      description: Specifies the high-level purpose of the =
instruction based on a set of pre-defined categories. This is used by the i=
nitiating party to provide information concerning the processing of the pay=
ment. &lt;br&gt; Usage- For future use.
                      maxLength: 35
                      type: string
                      pattern: ^[\w ]+$
                    instructionPriority:
                      description: |-
                        Indicator of the urgency or order of importance tha=
t the instructing party would like the instructed party to apply to the pro=
cessing of the instruction. The possible values are-&lt;br&gt;
                          HIGH: High. &lt;br&gt;
                          NORM: Normal.&lt;br&gt;
                          Usage- For future use.
                      enum:
                        - HIGH
                        - NORM
                      type: string
                    serviceLevel:
                      description: |-
                        Specifies a pre-agreed service or level of service =
between the parties.&lt;br&gt; NORM - For 'Attended' transaction. Attended =
payments are defined as Payments whereby the sending participant requires a=
 real-time response to their payment instruction&lt;br&gt; UNAT - For 'Unat=
tended' transaction. Unattended payments are defined as Payments whereby th=
e sending participant does not require a real-time response to their paymen=
t instruction.&lt;br&gt; Usage- Caller to set this field to 'NORM'.&lt;br&g=
t;
                        creditTransferInformation Description - Specifies a=
 pre-agreed service or level of service between the parties.&lt;br&gt;
                        Usage- Caller to set this field to 'npp.clear.01-x2=
p1.01' for NPP Osko payments.
                      maxLength: 35
                      type: string
                      pattern: /^[\w\.\-]+$/
                supplementaryData:
                  description: Additional Westpac Data Elements to support =
the PAYMENT Instruction (Debit).
                  type: object
                  allOf:
                    - type: object
                      properties:
                        divisionName:
                          description: Division Name
                          example: AUD Group
                          maxLength: 70
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        divisionId:
                          description: Division id
                          type: string
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                    - type: object
                      properties:
                        debitDescription:
                          description: The reference assigned by the sendin=
g party for the payment.&lt;br&gt;Usage- Caller to map debit description (s=
tatement narrative) to this field.
                          maxLength: 35
                          type: string
                          pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).=
*[\s\S]*$
                        instructionTraceIdentification:
                          type: string
                          description: UUId to uniquely identify the paymen=
t instruction.
                          pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3=
}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                        matchedCOPStatusCode:
                          description: ERDM encoded value
                          type: string
                          pattern: ^V[012AET]C[1-8]$
                          example: V0C1
                        matchedCOPAccountName:
                          description: Account Name
                          minLength: 1
                          maxLength: 140
                          example: Apple Tree
                          type: string
                          pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                        paymentProductId:
                          description: Product Id associated with the payme=
nt instruction.&lt;br&gt; Usage- Caller to map product id to this field.
                          type: string
                          enum:
                            - PP000020
                            - PP000004
                            - PP000016
                            - PP000012
                            - PP000005
                entitlementData:
                  type: object
                  description: Entitlement data for SAFI integration for tr=
ansfer endpoints
                  properties:
                    supplementaryData:
                      type: array
                      description: |
                        Additional data required for SAFI. Each item is a n=
ame/value/datatype triple.
                        Required fields for all transfers:
                        - W1_2FADEVICETYPE (STRING)
                        - TENANT (STRING)
                        - W1C_CURRENCY (STRING)
                        - PAYEEDESTINATIONACCOUNT (STRING) [BSB + account n=
umber for domestic payments, SWIFT code + account number for international =
payments, empty - for bulk payments (when/if they come in)]
                        - PAYEENICKNAME (STRING)
                        - PAYMENT_REFNO (STRING, use x-channelRequestId)
                      items:
                        oneOf:
                          - type: object
                            description: W1_2FADEVICETYPE field (must be 'S=
OFT TOKEN')
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1_2FADEVICETYPE
                              value:
                                type: string
                                enum:
                                  - SOFT TOKEN
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: TENANT field (must be 'TREASURY')
                            properties:
                              name:
                                type: string
                                enum:
                                  - TENANT
                              value:
                                type: string
                                enum:
                                  - TREASURY
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: W1C_CURRENCY field (currency code)
                            properties:
                              name:
                                type: string
                                enum:
                                  - W1C_CURRENCY
                              value:
                                description: A code allocated to a currency=
 by a Maintenance Agency under an international identification scheme, as d=
escribed in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                type: string
                                pattern: ^[A-Z]{3}$
                                example: AUD
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEEDESTINATIONACCOUNT field (BSB=
 + account number)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEEDESTINATIONACCOUNT
                              value:
                                description: Full account number with forma=
t &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                type: string
                                pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                maxLength: 35
                                example: 035845 103784254
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYEENICKNAME field (account nickn=
ame)
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYEENICKNAME
                              value:
                                description: Beneficiary Nickname
                                type: string
                                example: John
                                minLength: 1
                                maxLength: 70
                                pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                          - type: object
                            description: PAYMENT_REFNO field
                            properties:
                              name:
                                type: string
                                enum:
                                  - PAYMENT_REFNO
                              value:
                                type: string
                                pattern: ^\w+$
                                maxLength: 36
                                description: A unique id generated to refer=
ence a specific payment transaction
                              datatype:
                                type: string
                                enum:
                                  - STRING
                            required:
                              - name
                              - value
                              - datatype
                            additionalProperties: false
                      example:
                        - name: W1_2FADEVICETYPE
                          value: SOFT TOKEN
                          datatype: STRING
                        - name: TENANT
                          value: TREASURY
                          datatype: STRING
                        - name: W1C_CURRENCY
                          value: AUD
                          datatype: STRING
                        - name: PAYEEDESTINATIONACCOUNT
                          value: 123456 789012
                          datatype: STRING
                        - name: PAYEENICKNAME
                          value: John Doe Savings
                          datatype: STRING
                        - name: PAYMENT_REFNO
                          value: WP12345678901234567
                          datatype: STRING
              required:
                - clientContext
                - paymentMethod
                - initiatingParty
                - debtorAccount
                - creditTransferTransactionInformation
                - supplementaryData
      responses:
        '201':
          description: |
            Scenarios where Payment Initation API sends a full response wit=
h an ISO status:
              ACSC - Debit posted successfully. On-us credits, if any, post=
ed successfully. Off-us credits, if any, sent to the appropriate execution =
systems for clearing and settlement.
              RJCT - Payment rejected.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      transferCreate:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Details Request.
                          type: object
                          properties:
                            creationDateTime:
                              description: Date and time at which the messa=
ge was created.
                              format: date-time
                              type: string
                            groupInformation:
                              description: Provides details on the original=
 group, to which the message refers
                              type: object
                              properties:
                                groupStatus:
                                  description: Specifies the ISO status at =
the group level.Usage- For future use.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                                originalControlSum:
                                  description: Total of all individual amou=
nts included in the original message, irrespective of currencies.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                                originalCreationDateTime:
                                  description: Date and time at which the o=
riginal message was created.
                                  format: date-time
                                  type: string
                                originalNumberOfTransactions:
                                  description: Number of individual transac=
tions contained in the original message.
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                              required:
                                - originalCreationDateTime
                                - originalNumberOfTransactions
                                - groupStatus
                            groupStatusReasonInformation:
                              type: array
                              items:
                                description: Status reason information
                                type: object
                                properties:
                                  reason:
                                    maxLength: 50
                                    description: |-
                                      Status reason description.

                                        Group status reason can have values=
 -
                                          AccountEligibilityFailure
                                          DuplicatePayment
                                          ExternalValidationEnrichmentFaile=
d
                                          PostingFailed
                                          PostingSucceeded
                                          ValidationFailure

                                        Instruction status reason can have =
values -
                                          AccountEligibilityFailure
                                          InsufficientAccountBalance
                                          DebitPostingFailed
                                          DebitPostingSucceeded
                                          ExternalValidationEnrichmentFaile=
d
                                          FraudCheckDeclined
                                          FraudCheckDelayed
                                          FraudCheckNotAvailable
                                          FraudCheckOnHold
                                          FraudCheckReferred
                                          FundsReservationFailed
                                          FundsReservationSucceeded
                                          InvalidExecutionDate
                                          ValidationFailure

                                        Transaction status reason can have =
values -
                                          ClearingAndSettlementRejected
                                          AccountEligibilityFailure
                                          CreditPostingAborted
                                          CreditPostingFailed
                                          SchemeDeterminationFailed
                                          ValidationFailure
                                    type: string
                                    pattern: ^[\w ]+$
                                  additionalInformation:
                                    maxLength: 120
                                    description: Further information about =
the above status reason from downstream.
                                    type: string
                                    pattern: ^[\w ]+$
                            id:
                              description: Point to point reference, as ass=
igned by the instructing party, and sent to the next party in the chain to =
identify the message. This field is mapped from the messageId in the CAP re=
sponse.
                              maxLength: 35
                              type: string
                              pattern: ^[\w ]+$
                            paymentInformation:
                              description: Information concerning the origi=
nal payment information, to which the status report message refers.
                              type: object
                              properties:
                                paymentInformationStatus:
                                  description: Specifies the ISO status of =
the payment. Usage- Possible values -&lt;br&gt; ACSC- Accepted Settlement C=
ompleted (success) &lt;br&gt; ACSP- Accepted Settlement In Process (auto re=
try in progress in case of technical failure)&lt;br&gt; RJCT- Rejected
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                                paymentId:
                                  description: Usage- Echoed from the reque=
st. This is mapped from the CAP response nested in supplementaryDataRespons=
eObject
                                  maxLength: 32
                                  type: string
                                  pattern: ^[\w ]+$
                              required:
                                - paymentInformationStatus
                            paymentStatusReasonInformation:
                              type: array
                              items:
                                description: Status reason information
                                type: object
                                properties:
                                  reason:
                                    maxLength: 50
                                    description: |-
                                      Status reason description.

                                        Group status reason can have values=
 -
                                          AccountEligibilityFailure
                                          DuplicatePayment
                                          ExternalValidationEnrichmentFaile=
d
                                          PostingFailed
                                          PostingSucceeded
                                          ValidationFailure

                                        Instruction status reason can have =
values -
                                          AccountEligibilityFailure
                                          InsufficientAccountBalance
                                          DebitPostingFailed
                                          DebitPostingSucceeded
                                          ExternalValidationEnrichmentFaile=
d
                                          FraudCheckDeclined
                                          FraudCheckDelayed
                                          FraudCheckNotAvailable
                                          FraudCheckOnHold
                                          FraudCheckReferred
                                          FundsReservationFailed
                                          FundsReservationSucceeded
                                          InvalidExecutionDate
                                          ValidationFailure

                                        Transaction status reason can have =
values -
                                          ClearingAndSettlementRejected
                                          AccountEligibilityFailure
                                          CreditPostingAborted
                                          CreditPostingFailed
                                          SchemeDeterminationFailed
                                          ValidationFailure
                                    type: string
                                    pattern: ^[\w ]+$
                                  additionalInformation:
                                    maxLength: 120
                                    description: Further information about =
the above status reason from downstream.
                                    type: string
                                    pattern: ^[\w ]+$
                            transactionInformation:
                              items:
                                description: Provides information on the or=
iginal transactions to which the status report message refers.
                                type: object
                                properties:
                                  transactionStatus:
                                    type: string
                                    description: Specifies the ISO status o=
f the credit transaction within the payment, in case of on-us payments. &lt=
;br&gt; Usage-  Possible values- ACSC - Accepted Settlement Completed (succ=
ess) RJCT - Rejected (posting rejected) ACSP - Accepted Settlement In Proce=
ss (auto retry in progress in case of technical failure
                                    enum:
                                      - ACSC
                                      - RJCT
                                      - ACSP
                                  statusReasonInformation:
                                    type: array
                                    items:
                                      description: Status reason informatio=
n
                                      type: object
                                      properties:
                                        reason:
                                          maxLength: 50
                                          description: |-
                                            Status reason description.

                                              Group status reason can have =
values -
                                                AccountEligibilityFailure
                                                DuplicatePayment
                                                ExternalValidationEnrichmen=
tFailed
                                                PostingFailed
                                                PostingSucceeded
                                                ValidationFailure

                                              Instruction status reason can=
 have values -
                                                AccountEligibilityFailure
                                                InsufficientAccountBalance
                                                DebitPostingFailed
                                                DebitPostingSucceeded
                                                ExternalValidationEnrichmen=
tFailed
                                                FraudCheckDeclined
                                                FraudCheckDelayed
                                                FraudCheckNotAvailable
                                                FraudCheckOnHold
                                                FraudCheckReferred
                                                FundsReservationFailed
                                                FundsReservationSucceeded
                                                InvalidExecutionDate
                                                ValidationFailure

                                              Transaction status reason can=
 have values -
                                                ClearingAndSettlementReject=
ed
                                                AccountEligibilityFailure
                                                CreditPostingAborted
                                                CreditPostingFailed
                                                SchemeDeterminationFailed
                                                ValidationFailure
                                          type: string
                                          pattern: ^[\w ]+$
                                        additionalInformation:
                                          maxLength: 120
                                          description: Further information =
about the above status reason from downstream.
                                          type: string
                                          pattern: ^[\w ]+$
                              type: array
                          required:
                            - groupInformation
                  result:
                    type: object
                    properties:
                      transferCreate:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      transferCreate:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '202':
          description: |
            Scenarios where Payment Initation API sends a full response wit=
h an ISO status:
              RCVD - Received payment instruction. Payment status unknown a=
t this stage.
              PDNG - Payment held by fraud for further investigation.
              ACCP - Payment timed out on debit posting, retrying posting.
              ACSP - Technical failure on debit posting, retrying posting.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      transferCreate:
                        type: array
                        items:
                          description: Synchronous response to Submit Payme=
nt Details Request.
                          type: object
