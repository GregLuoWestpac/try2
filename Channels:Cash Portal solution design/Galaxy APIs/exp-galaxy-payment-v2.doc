  /schemeEligibilities:
    post:
      tags:
        - postSchemeEligibilities
      description: This endpoint returns a list of eligible payment methods=
.
      operationId: postSchemeEligibilities
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              description: Scheme Eligibility Request.
              required:
                - debtorAccount
                - creditorAccount
              properties:
                debtorAccount:
                  type: object
                  description: Details of issuer and schemeName.
                  properties:
                    issuer:
                      type: string
                      maxLength: 6
                      pattern: ^\d{6}$
                      description: BSB for account.
                    schemeName:
                      description: Schema code for example BBAN.
                      type: string
                      enum:
                        - BBAN
                  required:
                    - schemeName
                    - issuer
                creditorAccount:
                  type: object
                  description: Creditor Account. It consists of either Acco=
unt or PayAliasId.
                  properties:
                    issuer:
                      type: string
                      maxLength: 6
                      pattern: ^\d{6}$
                      description: BSB for account.
                    schemeName:
                      description: Schema code for example BBAN.
                      type: string
                      enum:
                        - BBAN
                    payAlias:
                      description: Alias PayId Details are optional if cred=
itor account is provided.
                      required:
                        - authBIC8
                        - id
                        - type
                      type: object
                      properties:
                        id:
                          description: |-
                            aka Payment Alias also known as PayID.  This fi=
eld will be populated if there was a payId type payment,
                            &lt;br&gt;Usage format-
                               &lt;br&gt;For type TELI-  The telephone numb=
er must consist of a =E2=80=9C+=E2=80=9D followed by the country code (from=
 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any combinati=
on of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[1-9]{1,1=
}[0-9]{1,29}$ Example- +61-123456789
                              &lt;br&gt; For type EMAL- Consists of a chara=
cter string with a maximum length of 256 characters. This must include the =
=E2=80=9C@=E2=80=9D symbol with leading and trailing characters and no whit=
e spaces. Only lower case characters will be supported.
                               Format pattern- Maximum of 256 characters ^(=
?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+=
)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)$ =
Example- 123@NPP.com
                              &lt;br&gt; For type AUBN- This is assigned by=
 the Australian Taxation Office to identify an individual Australian Busine=
ss. Consists of a nine-to-eleven digit number. If the length is 9 digits th=
an the last digit is the check digit. If the length is 11 digits, then an a=
lgorithm is used to validate the entire value as there is no check digit as=
 such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                               &lt;br&gt; For type ORGN- The Identifier mus=
t be representative of the company name, organisation name, trading name, a=
ssociated product, campaign or an identifier recognisable as associated wit=
h the specific business or organisation, with no whitespace at the beginnin=
g or end. Maximum of 256 characters in lower case, to be drawn from Printab=
le ASCII (decimal 32-126) and without leading or trailing whitespace. For a=
voidance of doubt, upper case letters (A-Z, decimal 65-90) are excluded.
                               Format pattern- ^[!-@[-~][ -@[-~]{0,254}[!-@=
[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                          maxLength: 256
                          type: string
                          pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?^_`{|}~\=
.\x20-\x7E\+\-]+$
                          example: tay.tay@westpac.com.au
                        type:
                          description: |-
                            For a PayID payment, the type of the PayID.
                              &lt;br&gt;TELI- Telephone Number
                              &lt;br&gt;EMAL- Email Address
                              &lt;br&gt;AUBN- Australian Business Number
                              &lt;br&gt;ORGN- Organisation ID
                          maxLength: 4
                          enum:
                            - EMAL
                            - TELI
                            - AUBN
                            - ORGN
                          type: string
                        authBIC8:
                          type: string
                          maxLength: 8
                          default: WPACAU3S
                          description: W1C to set this field to the BIC 'WP=
ACAU3S'.
                          enum:
                            - WPACAU3S
                returnAllSchemes:
                  type: boolean
                  description: Optional, default value is false, If set to =
true, all supported scheme values will be returned
      responses:
        '200':
          description: Scheme Eligibility Response Success response.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      schemeEligibilities:
                        type: array
                        items:
                          description: Scheme Eligibility
                          type: object
                          properties:
                            id:
                              description: A unique id generated for each r=
ecord which is the mode of communication between the UI and Exp API
                              type: string
                              format: uuid
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            paymentMethod:
                              description: The description of the identific=
ation of the payment scheme along with payment scheme code (only for staffs=
)
                              type: object
                              properties:
                                code:
                                  type: string
                                  maxLength: 35
                                  pattern: ^[a-z0-9.-]+$
                                  example: npp.clear.01-sct.01
                                description:
                                  type: string
                                  example: Fast Payment
                                  enum:
                                    - Funds transfer
                                    - Fast Payment
                                    - Osko
                                    - PayTo
                                    - Pay Anyone
                  result:
                    type: object
                    properties:
                      schemeEligibilities:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      schemeEligibilities:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Bad Request
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 32
                              example: Check logs for details
                          required:
                            - code
                            - message
