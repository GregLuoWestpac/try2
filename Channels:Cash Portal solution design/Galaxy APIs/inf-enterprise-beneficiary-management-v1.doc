<pre style=3D"font-size: 12px;">openapi: "3.0.3"

###########################################################################=
#####
#                       API Information                                    =
    #
###########################################################################=
#####
info:
  title: "Beneficiary Management"
  description: "The API represents the enterprise INF layer for the benefic=
iary management."
  version: "1.0.1"
  contact:
    url: "https://mesh.westpac.com.au/components/apis/beneficiary-managemen=
t-v1"
  x-baseSchemaVersion: "0.13.0" # The version of openapi-base on which this=
 specification is based

###########################################################################=
#####
#                  Base Path                                               =
    #
###########################################################################=
#####
servers:
  - url: "/inf/beneficiary/management/v1"

###########################################################################=
#####
#                                  Security                                =
    #
###########################################################################=
#####
security:
  - BasicAuth: []

tags:
  - name: createBeneficiaries
  - name: getBeneficiary
  - name: updateBeneficiary
  - name: updateBeneficiaryStatus
  - name: listBeneficiaries
  - name: health Check
###########################################################################=
#####
#                      Paths                                               =
    #
###########################################################################=
#####
paths:
  /healthcheck:
    get:
      description: Retrieve HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        "200":
          $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/responses/200healthCheckStatusResponse"
      tags:
        - health Check
  /beneficiaries:
    post:
      requestBody:
        description: Create beneficiaries
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                beneficiaries:
                  type: array
                  items:
                    $ref: "#/components/schemas/BeneficiaryRequest"
      tags:
        - createBeneficiaries
      operationId: createBeneficiaries
      summary: create beneficiaries
      description: create beneficiaries
      responses:
        "201":
          $ref: "#/components/responses/CreateBeneficiariesResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
  /beneficiaries/{id}:
    get:
      description: get the details of the beneficiary by id
      tags:
        - getBeneficiary
      operationId: getBeneficiaryDetail
      summary: retrieve a beneficiary detail
      parameters:
        - name: id
          in: path
          required: true
          description: unique id of the beneficiary
          schema:
            $ref: "#/components/schemas/beneficiaryId"
      responses:
        "200":
          $ref: "#/components/responses/GetBeneficiaryDetailResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "404":
          $ref: "#/components/responses/404NotFound"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
    put:
      description: update beneficiary details by id
      tags:
        - updateBeneficiary
      operationId: updateBeneficiary
      summary: update a beneficiary
      parameters:
        - name: id
          in: path
          required: true
          description: unique id of the beneficiary to be updated
          schema:
            $ref: "#/components/schemas/beneficiaryId"
      requestBody:
        description: Update beneficiary
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BeneficiaryUpdateRequest"
      responses:
        "200":
          $ref: "#/components/responses/UpdateBeneficiaryResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "404":
          $ref: "#/components/responses/404NotFound"
        "409":
          $ref: "#/components/responses/409Conflict"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
    patch:
      summary: Update a property of a beneficiary; limited to status proper=
ty with value ARCHIVED
      description: Update beneficiary status to ARCHIVED
      tags:
        - updateBeneficiaryStatus
      operationId: updateBeneficiaryStatus
      parameters:
        - name: id
          in: path
          required: true
          description: unique id of the beneficiary to update the status
          schema:
            $ref: "#/components/schemas/beneficiaryId"
      requestBody:
        required: true
        content:
          application/merge-patch+json:
            schema:
              type: object
              required:
                - status
              properties:
                status:
                  $ref: "#/components/schemas/status"
      responses:
        "204":
          description: Successfully updated (no content returned)
        "400":
          $ref: "#/components/responses/400BadRequest"
        "409":
          $ref: "#/components/responses/409Conflict"
        "404":
          $ref: "#/components/responses/404NotFound"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"

  /beneficiaries/summary:
    post:
      summary: retrieve a list of beneficiaries by ids and other search par=
ameters
      description: retrieve a list of beneficiaries by ids and other search=
 parameters
      tags:
        - listBeneficiaries
      operationId: ListBeneficiaries
      parameters:
        - name: pageKey
          description: current page for pagination
          in: query
          schema:
            type: integer
            default: 0
            example: 0
        - name: pageSize
          description: page size for the pagination
          in: query
          schema:
            type: integer
            default: 1000
            example: 100
        - name: sort
          in: query
          description: for sorting with the sorting pattern, + for asc and =
- for desc
          schema:
            type: string
            default: "+nickname"
            example: "+nickname"
            pattern: "^[\\+\\-][a-zA-Z]+[a-zA-Z0-9]*$"
      requestBody:
        description: retrieve a list of beneficiaries
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/ListBeneficiariesRequest"
      responses:
        "200":
          $ref: "#/components/responses/ListBeneficiariesResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"

###########################################################################=
#####
#                           Components                                     =
    #
###########################################################################=
#####
components:
  # parameters:

  # schemas:
  schemas:
    nickname:
      description: nickname of the beneficiary
      type: string
      example: "office 1"
      minLength: 1
      maxLength: 70
      pattern: "^[a-zA-Z0-9\\- !,.:\\;?_]+$"
    accountName:
      description: account name of the beneficiary
      type: string
      pattern: "^[a-zA-Z0-9\\- !,.:\\;?_]+$"
      minLength: 1
      maxLength: 140
      example: "Apple Tree"
    status:
      description: status of the beneficiaries ACTIVE, ON-HOLD OR ARCHIVED
      example: "ARCHIVED"
      type: string
      enum:
        - ACTIVE
        - ARCHIVED
        - ON-HOLD
    type:
      description: beneficiary account type either PayId or BSB &amp; Accou=
nt number
      type: string
      example: BSB_ACCOUNT_NUMBER
      enum:
        - PAYID
        - BSB_ACCOUNT_NUMBER
    org:
      description: Name of Organisation
      type: string
      example: "18342800027"
      minLength: 0
      maxLength: 15
      pattern: '^[0-9]+$'
    currency:
      description: currency used by the beneficiary
      type: string
      example: AUD
      minLength: 1
      maxLength: 3
      pattern: "^[A-Z]{3}$"
    beneficiaryId:
      description: unique id of the beneficiary
      type: string
      format: uuid
      example: "4b2b93ad-d6b8-4b6d-a446-0a5b56f1a804"
    externalId:
      description: external id of the beneficiary from legacy system
      type: string
      format: uuid
      example: "4b2b93ad-d6b8-4b6d-a446-0a5b56f1a804"
    isNew:
      description: indicates if the payment for the beneficiary is the firs=
t payment (true) or not (false)
      type: boolean
      example: true
    amount:
      description: Payment amount to be paid
      type: string
      pattern: '^\d{1,13}\.?\d{1,4}$'
    reference:
      description: A reference assigned by the initiating party to unambigu=
ously identify the payment
      type: string
      maxLength: 35
      pattern: '^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s\S]*$'
    divisionId:
      description: id required by IROM api
      type: string
      format: uuid
      example: "9129cb19-bc35-4ef5-91dc-0deb09d2e577"
    BeneficiaryResponse:
      description: Represents Beneficiary Response Object
      title: BeneficiaryResponse
      properties:
        id:
          $ref: "#/components/schemas/beneficiaryId"
        externalId:
          $ref: "#/components/schemas/externalId"
        nickname:
          $ref: "#/components/schemas/nickname"
        divisionId:
          $ref: "#/components/schemas/divisionId"
        currency:
          $ref: "#/components/schemas/currency"
        org:
         $ref: "#/components/schemas/org"
        status:
          $ref: "#/components/schemas/status"
        type:
          $ref: "#/components/schemas/type"
        account:
          $ref: "#/components/schemas/Account"
        isNew:
          $ref: "#/components/schemas/isNew"
        reference:
          $ref: "#/components/schemas/reference"
        amount:
          $ref: "#/components/schemas/amount"
    BeneficiaryRequest:
      description: Represents Beneficiary Request Object
      title: CreateBeneficiaryRequest
      required:
        - id
        - nickname
        - currency
        - account
        - type
        - org
      properties:
        id:
          $ref: "#/components/schemas/beneficiaryId"
        externalId:
          $ref: "#/components/schemas/externalId"
        nickname:
          $ref: "#/components/schemas/nickname"
        divisionId:
          $ref: "#/components/schemas/divisionId"
        currency:
          $ref: "#/components/schemas/currency"
        org:
          $ref: "#/components/schemas/org"
        type:
          $ref: "#/components/schemas/type"
        account:
          $ref: "#/components/schemas/Account"
        isNew:
          allOf:
            - $ref: "#/components/schemas/isNew"
          default: true
        reference:
          $ref: "#/components/schemas/reference"
        amount:
          $ref: "#/components/schemas/amount"
    BeneficiaryUpdateRequest:
      description: Represents Beneficiary Request Object
      title: UpdateBeneficiaryRequest
      required:
        - nickname
        - currency
        - account
        - type
      properties:
        nickname:
          $ref: "#/components/schemas/nickname"
        currency:
          $ref: "#/components/schemas/currency"
        type:
         $ref: "#/components/schemas/type"
        account:
          $ref: "#/components/schemas/Account"
        isNew:
          $ref: "#/components/schemas/isNew"
        reference:
          $ref: "#/components/schemas/reference"
        amount:
          $ref: "#/components/schemas/amount"
    ListBeneficiariesRequest:
      type: object
      description: Represents List Beneficiary Request Object
      title: ListBeneficiariesRequest
      required:
        - ids
      properties:
        ids:
          description: list of beneficiary ids to search and retrieve
          type: array
          items:
            $ref: "#/components/schemas/beneficiaryId"
        query:
          type: string
          description: |=20
            Text to search in nickname and account fields. It supports part=
ial and case insensitive search.=20
            The given text should be a substring of either nickname or acco=
untName to be considered as a match.
          example: "1123456"
          maxLength: 256
          minLength: 1
          pattern: "^(.+)$"
        statuses:
          type: array
          description: list of beneficiary status to filter the search. Giv=
en statues are ORed in the search
          items:
            $ref: "#/components/schemas/status"
    Account:
      type: object
      description: Represents Account detail object as json string
      oneOf:
        - $ref: "#/components/schemas/BankDetails"
        - $ref: "#/components/schemas/PayIdDetails"
      example:
        accountId:
          BSB: "123456"
          accountNumber: "123456789"
        accountName: "John Doe"
        bankName: "Westpac Banking Corporation"
    BankDetails:
      type: object
      description: Represents Account detail object
      required:
        - accountId
        - accountName
        - bankName
      properties:
        accountId:
          type: object
          description: Account ID (BSB and Account Number) of the beneficia=
ry
          required:
            - BSB
            - accountNumber
          properties:
            BSB:
              description: BSB for the account
              type: string
              example: "123456"
              minLength: 6
              maxLength: 6
              pattern: "^[0-9]+$"
            accountNumber:
              description: Account number
              type: string
              example: "123456789"
              minLength: 1
              maxLength: 28
              pattern: "^[a-zA-Z0-9.]+$"
        accountName:
          $ref: "#/components/schemas/accountName"
        bankName:
          description: Name of the Bank
          type: string
          pattern: "^[\\w ]+$"
          minLength: 1
          maxLength: 70
          example: "Westpac Banking Corporation"
    PayIdDetails:
      type: object
      description: Represents Account detail object
      required:
        - payIDType
        - payIDName
        - payIDValue
      properties:
        payIDType:
          description: "alias type for the PayID, either email / phone / or=
gId / bsb"
          type: string
          example: "123456789"
          minLength: 1
          maxLength: 20
        payIDName:
          description: "pay id name returned from the alias resolution"
          type: string
          example: "123456789"
          minLength: 1
          maxLength: 256
        payIDValue:
          description: "alias id for the PayID, either email / phone / orgI=
d / bsb"
          type: string
          example: "123456789"
          minLength: 1
          maxLength: 256
  # responses:
  responses:
    200healthCheckStatusResponse:
      description: healthcheck status
      content:
        application/json:
          schema:
            type: object
            properties:
              status:
                type: string
                enum:
                  - success
    GetBeneficiaryDetailResponse:
      description: get beneficiary detail response
      content:
        application/json:
          schema:
            title: GetBeneficiaryDetailResponse
            type: object
            properties:
              data:
                allOf:
                  - $ref: "#/components/schemas/BeneficiaryResponse"
                title: GetBeneficiaryDetailData
    ListBeneficiariesResponse:
      description: beneficiary creation response
      content:
        application/json:
          schema:
            type: object
            title: ListBeneficiariesResponse
            properties:
              data:
                type: object
                title: ListBeneficiariesData
                properties:
                  beneficiaries:
                    type: array
                    items:
                      $ref: "#/components/schemas/BeneficiaryResponse"
              paging:
                type: object
                title: pageDetails
                properties:
                  pageSize:
                    description: Number of items per page
                    type: integer
                    format: int32
                    minimum: 1
                    example: 50
                  count:
                    description: Total number of items available
                    type: integer
                    format: int32
                    example: 160
                  previousPageKey:
                    description: Key for start of previous page. -1 if no p=
revious page exists
                    type: integer
                    format: int32
                    minimum: 0
                    example: 0
                  nextPageKey:
                    description: Key for start of next page. -1 if no next =
page exists
                    type: integer
                    format: int32
                    minimum: 0
                    example: 2
                  moreItems:
                    description: Indicator to show if there are more items =
available. If true, more records are available (by narrowing search paramet=
ers)
                    type: boolean
                    example: true
