  /statementTokenCreate:
    post:
      description: This endpoint generates a token that can be used to retr=
ieve a document from or add a document to, or check in a document to, a doc=
ument repository.
      operationId: postStatementTokenGenerator
      tags:
        - Statements
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        content:
          application/json:
            schema:
              description: Generate a token that can be used to retrieve a =
document from or add a document to, or check in a document to, a document r=
epository.
              type: object
              required:
                - accountId
                - repositoryId
                - documentId
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
                repositoryId:
                  description: The unique identifier provided to the consum=
er to identify the document repository.
                  type: string
                  example: TST000001
                  maxLength: 32
                  pattern: ^[^\s\-][\w \-:]+[^\s\-]$
                documentId:
                  description: The unique identifier for the document, as p=
er the repository system (e.g. for Filenet this is the GUID).
                  type: string
                  maxLength: 1000
                  example: Y13trJzYCu6uaDTv9ZYqUwgeEZ76+qu0wtrFTn51XIx6g1TL=
+Uco+OHFQ+ld7bQzMdVElXtPQrJCfxfuwXT9DYfZJhMBhlApdbM1yP+VKnW+qT/68Kkg8phUTJS=
E+cEvE8E8vZac1iu+eXuW5vp5VHgEo5LPvGbVdWC/p51cXBScj328kmpDMJJMLUwWWhoykzZfRq=
JbzAbMfrpxCWQCPU1smehFyGnxPEi+D4EZianhDXxS7fTQR/4yvf9ACJXDPF
                  pattern: ^[\w\-+\/=3D]+$
      responses:
        '200':
          description: The downloaded statement
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      statementTokenCreate:
                        type: array
                        items:
                          description: Fetch Statement token
                          type: object
                          properties:
                            id:
                              description: A unique id generated for the st=
atement
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            documentTransferToken:
                              type: string
                              format: base64
                              maxLength: 100000
                              description: Token in JWT format to download =
the statement
                              example: SGVsbG8sIFdvcmxkIQ=3D=3D
                            documentTransferProxyURL:
                              type: string
                              description: Proxy URL for transfer of docume=
nts.
                              pattern: ^https:\/\/[a-zA-Z0-9.-]+(?:\.[a-zA-=
Z]{2,})+(?:\/[^\s]*)?$
                              example: https://gw-lft.sit1.api.srv.westpac.=
com.au/
                  result:
                    type: object
                    properties:
                      statementTokenCreate:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      statementTokenCreate:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /taxAndInterestList:
    post:
      description: This endpoint retrieves a list of tax and interest summa=
ry for all accounts / account group that the user is entitled to.
      operationId: postTaxAndInterestList
      tags:
        - TaxAndInterest
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: groupId
          in: query
          required: false
          description: Group ID used for filtering results
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: pageSize
          in: query
          description: |
            Number of entries to be returned in a single page.
          schema:
            type: integer
            format: int32
            minimum: 10
            maximum: 1000
            default: 1000
          required: false
          example: 100
        - name: pageKey
          in: query
          description: The key identifying the page of data to be returned
          schema:
            type: integer
            format: int32
            maximum: 1000
            default: 0
          required: false
        - name: year
          in: query
          required: true
          description: The financial year to filter the results
          schema:
            description: The relevant financial year
            type: string
            pattern: ^\d{4}$
            example: '2025'
        - name: divisionId
          in: query
          required: false
          description: Division ID used for returning account associated wi=
th that division
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        description: The request body for the tax and interest list endpoin=
t
        required: false
        content:
          application/json:
            schema:
              description: Request object for retrieving the interest and t=
ax summary list.
              type: object
              properties:
                searchFilter:
                  maxLength: 256
                  example: Payroll
                  description: Matches any string, including Unicode charac=
ters, and emoji, except semicolon (;), double hyphen (--), left and right c=
urly bracket ({ }), less than (&lt;),  greater than (&gt;), percentage sign=
 (%), hash (#), quotation mark ("), and equal sign (=3D).  Use for fields t=
hat are protected by perfect express sanitizer library
                  type: string
                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=3D)).*[\s\S]*=
$
      responses:
        '200':
          description: The retrieved tax and interest summary information f=
or all the entitled accounts
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      taxAndInterestList:
                        type: array
                        items:
                          type: object
                          properties:
                            id:
                              description: A unique id generated for intere=
st and tax list
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            years:
                              type: array
                              items:
                                type: array
                                items:
                                  description: Summary object of tax and in=
terest details for one financial year for a given account
                                  type: object
                                  properties:
                                    year:
                                      description: The relevant financial y=
ear for the tax/interest detail object. This value is the year in which the=
 relevant financial year ends, e.g. 2023 is for FY 2022-2023.
                                      type: string
                                      pattern: ^[\d]+$
                                    accountId:
                                      description: Full account number with=
 format &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                      type: string
                                      pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                      maxLength: 35
                                      example: 035845 103784254
                                    accountName:
                                      description: Account Name
                                      minLength: 1
                                      maxLength: 140
                                      example: Apple Tree
                                      type: string
                                      pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                    currencyCode:
                                      description: Currency of the account
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                    interestEarned:
                                      description: Interest earned for the =
selected financial year (sum of all credit interest transactions, including=
 adjustments)
                                      type: string
                                      anyOf:
                                        - description: A positive number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^\d{1,13}\.\d{1,4}$
                                          example: '1000.0000'
                                        - description: A negative number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^(?:-\d{1,13}|0)\.\d{1,4=
}$
                                          example: '-1000.0000'
                                    interestPaid:
                                      description: Interest paid for the se=
lected financial year (sum of all debit interest transactions, including ad=
justments)
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                    withholdingTax:
                                      description: Withholding tax paid for=
 the selected financial year (net value of all credit and debit WHT transac=
tions)
                                      type: string
                                      pattern: ^\d{1,13}\.\d{1,4}$
                                      example: '1000.0000'
                                  example:
                                    year: '2025'
                                    accountId: 035845 103784254
                                    accountName: Account A
                                    currencyCode: AUD
                                    interestEarned: '10000.00'
                                    interestPaid: '100.00'
                                    withholdingTax: '100.00'
                      paging:
                        type: array
                        items:
                          type: object
                          required:
                            - id
                            - pageSize
                            - count
                            - previousPageKey
                            - nextPageKey
                          properties:
                            id:
                              description: Paging Unique Id
                              type: string
                              maxLength: 3
                              pattern: ^\d+$
                              example: '1'
                            pageSize:
                              description: Number of items per page
                              type: integer
                              format: int32
                              example: 50
                            count:
                              description: Total number of items available
                              type: integer
                              format: int32
                              example: 160
                            previousPageKey:
                              description: Key for start of previous page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '0'
                            nextPageKey:
                              description: Key for start of next page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '2'
                            moreItems:
                              description: Boolean flag indicating if there=
 are more items available
                              type: boolean
                              example: true
                  result:
                    type: object
                    properties:
                      taxAndInterestList:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      taxAndInterestList:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /taxAndInterestDetail:
    post:
      description: This endpoint retrieves tax and interest data for an acc=
ount that the user is entitled to for the past three financial years.
      operationId: postTaxAndInterestDetail
      tags:
        - TaxAndInterest
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        description: The account ID that user is searching for
        required: true
        content:
          application/json:
            schema:
              description: The account ID that user is searching for
              type: object
              required:
                - accountId
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
      responses:
        '200':
          description: The retrieved tax and interest detail for the specif=
ied accountId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      taxAndInterestDetail:
                        type: array
                        items:
                          description: Detailed object of tax and interest =
details for one financial year for a given account
                          type: object
                          properties:
                            id:
                              description: A unique id generated for intere=
st and tax detail of a year
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            year:
                              description: The relevant financial year for =
the tax/interest detail object. This value is the year in which the relevan=
t financial year ends, e.g. 2023 is for FY 2022-2023.
                              type: string
                              pattern: ^[\d]+$
                            interestEarned:
                              description: Interest earned for the selected=
 financial year (sum of all credit interest transactions, including adjustm=
ents)
                              type: string
                              anyOf:
                                - description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            interestPaid:
                              description: Interest paid for the selected f=
inancial year (sum of all debit interest transactions, including adjustment=
s)
                              type: string
                              pattern: ^\d{1,13}\.\d{1,4}$
                              example: '1000.0000'
                            withholdingTax:
                              description: Withholding tax paid for the sel=
ected financial year (net value of all credit and debit WHT transactions)
                              type: string
                              pattern: ^\d{1,13}\.\d{1,4}$
                              example: '1000.0000'
                          example:
                            year: '2023'
                            interestEarned: '10000.00'
                            interestPaid: '100.00'
                            withholdingTax: '100.00'
                      accruedDebitInterest:
                        type: array
                        items:
                          description: Accrued interest (debit or credit) f=
rom the downstream AccrualDetails API
                          allOf:
                            - type: object
                              properties:
                                id:
                                  description: A unique id generated for an=
 entity which is the mode of communication between the UI and Exp API, via =
redux store
                                  example: d0868661-b955-4e76-9f15-d97626f7=
df6b
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            - type: object
                              properties:
                                currencyAmount:
                                  description: The accrued interest amount =
and currency
                                  type: object
                                  properties:
                                    amount:
                                      description: A positive or negative n=
umber string of up to four decimal places (including zero). Must have at le=
ast one digit after the decimal point.
                                      type: string
                                      anyOf:
                                        - description: A positive number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^\d{1,13}\.\d{1,4}$
                                          example: '1000.0000'
                                        - description: A negative number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^(?:-\d{1,13}|0)\.\d{1,4=
}$
                                          example: '-1000.0000'
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                  required:
                                    - currencyCode
                      accruedCreditInterest:
                        type: array
                        items:
                          description: Accrued interest (debit or credit) f=
rom the downstream AccrualDetails API
                          allOf:
                            - type: object
                              properties:
                                id:
                                  description: A unique id generated for an=
 entity which is the mode of communication between the UI and Exp API, via =
redux store
                                  example: d0868661-b955-4e76-9f15-d97626f7=
df6b
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            - type: object
                              properties:
                                currencyAmount:
                                  description: The accrued interest amount =
and currency
                                  type: object
                                  properties:
                                    amount:
                                      description: A positive or negative n=
umber string of up to four decimal places (including zero). Must have at le=
ast one digit after the decimal point.
                                      type: string
                                      anyOf:
                                        - description: A positive number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^\d{1,13}\.\d{1,4}$
                                          example: '1000.0000'
                                        - description: A negative number st=
ring of up to four decimal places (including zero). Must have at least one =
digit after the decimal point.
                                          type: string
                                          pattern: ^(?:-\d{1,13}|0)\.\d{1,4=
}$
                                          example: '-1000.0000'
                                    currencyCode:
                                      description: A code allocated to a cu=
rrency by a Maintenance Agency under an international identification scheme=
, as described in the latest edition of the international standard ISO 4217=
 =E2=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt=
;br&gt; Usage- Caller to set 'AUD' to this field.
                                      type: string
                                      pattern: ^[A-Z]{3}$
                                      example: AUD
                                  required:
                                    - currencyCode
                  result:
                    type: object
                    properties:
                      taxAndInterestDetail:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      taxAndInterestDetail:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
