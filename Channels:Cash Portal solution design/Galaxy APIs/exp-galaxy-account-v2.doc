                                - description: A negative number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^(?:-\d{1,13}|0)\.\d{1,4}$
                                  example: '-1000.0000'
                            closingBalance:
                              description: The closing balance held for the=
 arrangement
