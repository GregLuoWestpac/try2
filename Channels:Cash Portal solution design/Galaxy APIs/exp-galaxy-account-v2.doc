  /statementList:
    post:
      description: This endpoint gets list of statements
      operationId: postStatementList
      tags:
        - Statements
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        required: true
        content:
          application/json:
            schema:
              description: The statement user is requesting for
              type: object
              required:
                - accountId
                - statementPeriod
                - statementType
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
                statementPeriod:
                  description: The period for which statements will to be r=
etrieved.
                  type: string
                  pattern: ^btn:(\d{4}-\d{2}-\d{2}),(\d{4}-\d{2}-\d{2})$
                  example: btn:2000-01-01,2021-05-15
                statementType:
                  description: Specifies the type of statement document bas=
ed on its issuance frequency. (e.g. "Monthly" refers to statements issued e=
very month, while "Annual" refers to statements issued once a year).
                  type: string
                  enum:
                    - Monthly
                    - Annual
      responses:
        '200':
          description: The retrieved statements
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      statementList:
                        type: array
                        items:
                          description: Statement List
                          type: object
                          required:
                            - id
                            - repositoryId
                            - documentId
                            - issueDate
                            - statementType
                            - statementMIMEType
                            - statementNumber
                            - account
                          properties:
                            id:
                              description: A unique id generated for the st=
atement fetch
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            issueDate:
                              description: Statement issue date.
                              type: string
                              example: '2025-02-20T00:00:00.000+11:00'
                              format: date-time
                            statementType:
                              description: Specifies the type of statement =
document based on its issuance frequency. (e.g. "Monthly" refers to stateme=
nts issued every month, while "Annual" refers to statements issued once a y=
ear).
                              type: string
                              enum:
                                - Monthly
                                - Annual
                            statementMIMEType:
                              description: Statement format to be returned.
                              type: string
                              enum:
                                - PDF
                                - Text
                              pattern: ^(PDF|Text){1,4}$
                            statementNumber:
                              description: A unique id generated for a stat=
ement as per the repository system
                              type: string
                              example: '4865'
                              pattern: ^\w+$
                              maxLength: 128
                            account:
                              type: object
                              description: Account ID (BSB and Account Numb=
er)
                              required:
                                - BSB
                                - accountNumber
                              properties:
                                BSB:
                                  description: Bank State Branch Number
                                  type: string
                                  pattern: ^\d{6}$
                                  example: '035845'
                                accountNumber:
                                  description: Account Number
                                  type: string
                                  pattern: ^[a-zA-Z\d.]+$
                                  minLength: 6
                                  maxLength: 28
                                  example: '01235674897'
                              example:
                                BSB: '035845'
                                accountNumber: '10235674897'
                            repositoryId:
                              description: The unique identifier provided t=
o the consumer in the search API results to identify the document repositor=
y.
                              type: string
                              example: TST000001
                              maxLength: 32
                              pattern: ^[^\s\-][\w \-:]+[^\s\-]$
                            documentId:
                              description: The unique identifier for the do=
cument, as per the repository system (e.g. for Filenet this is the GUID).
                              type: string
                              maxLength: 1000
                              example: Y13trJzYCu6uaDTv9ZYqUwgeEZ76+qu0wtrF=
Tn51XIx6g1TL+Uco+OHFQ+ld7bQzMdVElXtPQrJCfxfuwXT9DYfZJhMBhlApdbM1yP+VKnW+qT/=
68Kkg8phUTJSE+cEvE8E8vZac1iu+eXuW5vp5VHgEo5LPvGbVdWC/p51cXBScj328kmpDMJJMLU=
wWWhoykzZfRqJbzAbMfrpxCWQCPU1smehFyGnxPEi+D4EZianhDXxS7fTQR/4yvf9ACJXDPF
                              pattern: ^[\w\-+\/=3D]+$
                      paging:
                        type: array
                        items:
                          type: object
                          required:
                            - id
                            - pageSize
                            - count
                            - previousPageKey
                            - nextPageKey
                          properties:
                            id:
                              description: Paging Unique Id
                              type: string
                              maxLength: 3
                              pattern: ^\d+$
                              example: '1'
                            pageSize:
                              description: Number of items per page
                              type: integer
                              format: int32
                              example: 50
                            count:
                              description: Total number of items available
                              type: integer
                              format: int32
                              example: 160
                            previousPageKey:
                              description: Key for start of previous page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '0'
                            nextPageKey:
                              description: Key for start of next page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '2'
                            moreItems:
                              description: Boolean flag indicating if there=
 are more items available
                              type: boolean
                              example: true
                  result:
                    type: object
                    properties:
                      statements:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      statements:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
