mat &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                  type: string
                                  pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                  maxLength: 35
                                  example: 035845 103784254
                            debtorAccountId:
                              description: Debtor's account internal ID in =
the account host system; example, 10x subscription key.
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            debitDescription:
                              description: Debit description
                              type: string
                              pattern: ^[\w\. -]+$
                              maxLength: 35
                              example: some text here
                            debtorFI:
                              description: The financial institution servic=
ing an account for the debtor.
                              type: string
                              pattern: ^\w+$
                              maxLength: 11
                              example: WPACAU2SONE
                            beneficiary:
                              description: Creditor's name and account numb=
er in multi-line; applicable for inbound and outbound payments
                              type: object
                              properties:
                                name:
                                  description: account name
                                  maxLength: 255
                                  example: John S
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                nickName:
                                  description: account alias name (nickname=
)
                                  maxLength: 255
                                  example: Payroll account
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                accountId:
                                  description: Full account number with for=
mat &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                  type: string
