                      paging:
                        type: array
                        items:
                          type: object
                          required:
                            - id
                            - pageSize
                            - count
                            - previousPageKey
                            - nextPageKey
                          properties:
                            id:
                              description: Paging Unique Id
                              type: string
                              maxLength: 3
                              pattern: ^\d+$
                              example: '1'
                            pageSize:
                              description: Number of items per page
                              type: integer
                              format: int32
                              example: 50
                            count:
                              description: Total number of items available
                              type: integer
                              format: int32
                              example: 160
                            previousPageKey:
                              description: Key for start of previous page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '0'
                            nextPageKey:
                              description: Key for start of next page
                              type: string
                              pattern: ^\d+$
                              maxLength: 3
                              example: '2'
                            moreItems:
                              description: Boolean flag indicating if there=
 are more items available
                              type: boolean
                              example: true
                  result:
                    type: object
                    properties:
                      arrangements:
                        description: A list of ids relating to the resource=
 that was requested
