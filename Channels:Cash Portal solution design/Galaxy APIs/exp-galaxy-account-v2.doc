  /arrangementDetails:
    post:
      description: This endpoint retrieves a detailed arrangement object, b=
ased on a singleton accountId
      operationId: postArrangementDetails
      tags:
        - Arrangements
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        description: The account ID that user is searching for
        required: true
        content:
          application/json:
            schema:
              description: The account IDs that user is searching for
              type: object
              required:
                - accountId
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
      responses:
        '200':
          description: The retrieved enriched arrangement for the specified=
 accountId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      arrangementDetails:
                        type: array
                        items:
                          description: Detailed Customer arrangement (accou=
nt)
                          type: object
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            entityName:
                              description: Entity Name
                              minLength: 1
                              maxLength: 250
                              example: Bayer, Miller and MacGyver
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            accountName:
                              description: Arrangement alias name
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                              maxLength: 50
                            accountType:
                              description: Account type; it is product name=
 in master product system
                              minLength: 1
                              maxLength: 250
                              example: Corporate Investment Account
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            status:
                              description: Status; example-&gt; ACTIVE, INA=
CTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                              example: ACTIVE
                            currencyCode:
                              description: A code allocated to a currency b=
y a Maintenance Agency under an international identification scheme, as des=
cribed in the latest edition of the international standard ISO 4217 =E2=80=
=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&gt;=
 Usage- Caller to set 'AUD' to this field.
                              type: string
                              pattern: ^[A-Z]{3}$
                              example: AUD
