                                  maxLength: 35
                                  example: 035845 103784254
                            creditAccount:
                              description: Creditor's account nickname and =
account number in multi-line; applicable for funds transafer.
                              type: object
                              properties:
                                name:
                                  description: account name
                                  maxLength: 255
                                  example: John S
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                nickName:
                                  description: account alias name (nickname=
)
                                  maxLength: 255
                                  example: Payroll account
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                accountId:
                                  description: Full account number with for=
mat &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                  type: string
                                  pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                  maxLength: 35
                                  example: 035845 103784254
                            creditorAccountId:
                              description: Creditor's account internal ID i=
n the account host system; example, 10x subscription key.
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            creditorDescription:
                              description: Credit description
                              type: string
                              pattern: ^[\w\. -]+$
                              maxLength: 280
                              example: some text here
                            reference:
                              description: |
                                A supplied reference for the credit transfe=
r information, that appears on both the debtor and the creditor's account.
                                For example, the identification used to rec=
oncile an accounts payable with an accounts receivable (e.g. a receipt or i=
nvoice number)
                              type: string
                              pattern: ^[\w\. -]+$
                              maxLength: 35
                              example: some text here
                            creditorReference:
                              description: The reference supplied by the in=
itiating party for e-invoicing or category purpose code payments
                              type: string
                              pattern: ^[\w\. -]+$
                              maxLength: 35
                              example: some text here
                            creditorFI:
                              description: The financial institution servic=
ing an account for the creditor.
                              type: string
                              pattern: ^\w+$
                              maxLength: 11
                              example: WPACAU2SONE
                            paymentMethod:
                              description: The description of the identific=
ation of the payment scheme along with payment scheme code (only for staffs=
)
                              type: object
                              properties:
                                code:
                                  type: string
                                  maxLength: 35
                                  pattern: ^[a-z0-9.-]+$
                                  example: npp.clear.01-sct.01
                                description:
                                  type: string
                                  example: Fast Payment
                                  enum:
                                    - Funds transfer
                                    - Fast Payment
                                    - Osko
                                    - PayTo
                                    - Pay Anyone
                                    - International
                            receiptNumber:
                              description: The unique transaction ID genera=
ted by Channel / FIS to trace transactions for customers to allow them to q=
uery.
                              type: string
                              pattern: ^[\w-]+$
                              maxLength: 36
                              example: WP123456789
                            schemeCategoryPurpose:
                              description: The description for the category=
 purpose code supplied by the initiating party.
                              type: string
                              pattern: ^[\w- ]+$
                              maxLength: 35
                              example: Salary Payment
                            paymentStatus:
                              description: A customer-facing course-grained=
 status of the payment; expected values are "Processed", "Failed", "Process=
ing" and "Submitted"
                              type: string
                              enum:
                                - Processing
                                - Processed
                                - Failed
                              example: Processed
                            transactionId:
                              description: Account Ledger Transaction ID (a=
.k.a. 10x Transaction ID), a unique reference assigned by FIS CBIS (as Exte=
rnal Reference ID) to request a transaction posting at 10x.
                              type: string
                              minLength: 1
                              maxLength: 128
                              pattern: ^[\w-]+$
                              example: d0868661-b955-4e76-9f15-d97626f7df6b
                            transactionCode:
                              description: The identification assigned by c=
ore banking system (e.g. 10x, Trading Bank) to identify the type of transac=
tion being reported orchestrated, processed.
                              type: string
                              pattern: ^[\w._]+$
                              maxLength: 50
                              example: PMNT.IRCT.DMCT_FIS_NPP_ACCT
                            instructionId:
                              type: string
                              pattern: ^\w+$
                              maxLength: 36
                              description: Generated by Mesh (appcorrelatio=
nid) and used as the unique key for the event in PODS database.
                              example: NPPAAU2TXXXI20220928024204362274890
                            transactionTraceIdentification:
                              type: string
                              description: Unique reference assigned by the=
 initiating party to identify the transaction trace.
                              example: d0868661-b955-4e76-9f15-d97626f7df6b
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            numberOfTransactions:
                              type: string
                              pattern: ^[0-9]{1,15}$
                              description: The number of individual transac=
tions contained in the payment information group.
                              example: '10'
                            paymentId:
                              description: A unique ID assigned to a paymen=
t instruction, which can be used for reconciliation and tracking purposes.
                              example: WP123456789
                              type: string
                              pattern: ^\w+$
                              maxLength: 36
                            mandateId:
                              type: string
                              pattern: ^\w+$
                              maxLength: 35
                              description: NPP Mandate ID, a unique referen=
ce assigned for an NPP payment as per NPP industry regulation.
                              example: 2dd54fe0247511ebb99c632981f9b8ae
                            uetr:
                              description: Unique End-to-end Transfer Refer=
ence of a payment transaction
                              example: b147197f-5bb2-4685-8cb1-9134ff0ff3f2
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            originalMessageName:
                              description: The type of value message
                              type: string
                              pattern: ^[\w\. ]+$
                              maxLength: 35
                              example: pacs.008
                            originalMessageId:
                              description: The point to point reference ass=
igned by the original instructing party to identify the original message.
                              type: string
                              pattern: ^[\w -]+$
                              maxLength: 35
                              example: WPACAUSNXXX20160414020000000000001
                            originalTransactionId:
                              type: string
                              pattern: ^[\w -]+$
                              maxLength: 35
                              example: CTBAAUSNXXXN20240128010133672678000
                            reversalIndicator:
                              type: boolean
                              description: Indicates if this posting entry =
is a business reversal of the original posting. It is set to TRUE if the po=
sting is a business reversal.
                              example: true
                            reversalReason:
                              type: object
                              properties:
                                code:
                                  description: The ISO code of reversal
                                  type: string
                                  pattern: ^\w+$
                                  maxLength: 4
                                  example: AM04
                                description:
                                  description: The ISO description of rever=
sal
                                  type: string
                                  maxLength: 100
                                  pattern: ^[\w -]+$
                                  example: Amount of funds available to cov=
er specified message amount is insufficient
                            returnReason:
                              type: object
                              description: Provides further details on the =
reason of the return of the transaction.
                              properties:
                                code:
                                  description: Reason for the return, as pu=
blished in an external reason code list.
                                  type: string
                                  pattern: ^\w+$
                                  maxLength: 4
                                  example: FR01
                                description:
                                  description: Reason for the return, as pu=
blished in an external reason code list.
                                  type: string
                                  pattern: ^[\w -]+$
                                  maxLength: 100
                                  example: Returned as a result of fraud
                                additionalInformation:
                                  type: array
                                  description: Further details on the retur=
n reason.
                                  items:
                                    type: string
                                    pattern: ^[\w -\\]+$
                                    example: /CASE/CSXX01
                                    maxItems: 3
                            returnedMessageId:
                              type: string
                              maxLength: 35
                              pattern: ^\w+$
                              example: WPACAUSNXXX20160414020000000000001
                            returnedTransactionId:
                              type: string
                              maxLength: 35
                              pattern: ^\w+$
                              example: CTBAAUSNXXXN20240128010133672678000
                            supplementaryData:
                              description: Additional Westpac Data Elements=
 to support the PAYMENT transaction (Credit).
                              type: object
                              properties:
                                aliasId:
                                  description: |-
                                    aka Payment Alias also known as PayID. =
 This field will be populated if there was a payId type payment,
                                    &lt;br&gt;Usage format-
                                       &lt;br&gt;For type TELI-  The teleph=
one number must consist of a =E2=80=9C+=E2=80=9D followed by the country co=
de (from 1 to 3 characters) then a =E2=80=9C-=E2=80=9C &amp; finally, any c=
ombination of numbers (up to 30 characters).Format pattern- ^\+[0-9]{1,3}-[=
1-9]{1,1}[0-9]{1,29}$ Example- +61-123456789
                                      &lt;br&gt; For type EMAL- Consists of=
 a character string with a maximum length of 256 characters. This must incl=
ude the =E2=80=9C@=E2=80=9D symbol with leading and trailing characters and=
 no white spaces. Only lower case characters will be supported.
                                       Format pattern- Maximum of 256 chara=
cters ^(?:[a-z0-9!#$%&amp;'*+/=3D?^_`{|}~-]+(?:\.[a-z0-9!#$%&amp;'*+/=3D?^_=
`{|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0=
-9])?)$ Example- 123@NPP.com
                                      &lt;br&gt; For type AUBN- This is ass=
igned by the Australian Taxation Office to identify an individual Australia=
n Business. Consists of a nine-to-eleven digit number. If the length is 9 d=
igits than the last digit is the check digit. If the length is 11 digits, t=
hen an algorithm is used to validate the entire value as there is no check =
digit as such. Format pattern- ^((\d{9})|(\d{11}))$ Example- 601428737
                                       &lt;br&gt; For type ORGN- The Identi=
fier must be representative of the company name, organisation name, trading=
 name, associated product, campaign or an identifier recognisable as associ=
ated with the specific business or organisation, with no whitespace at the =
beginning or end. Maximum of 256 characters in lower case, to be drawn from=
 Printable ASCII (decimal 32-126) and without leading or trailing whitespac=
e. For avoidance of doubt, upper case letters (A-Z, decimal 65-90) are excl=
uded.
                                       Format pattern- ^[!-@[-~][ -@[-~]{0,=
254}[!-@[-~]$ Example- ABC Pty. Ltd. Sydney NSW
                                  maxLength: 256
                                  type: string
                                  pattern: ^[\d@a-zA-Z0-9!#$%&amp;'*+\/=3D?=
^_`{|}~\.\x20-\x7E\+\-]+$
                                  example: tay.tay@westpac.com.au
                                aliasType:
                                  description: |-
                                    For a PayID payment, the type of the Pa=
yID.
                                      &lt;br&gt;TELI- Telephone Number
                                      &lt;br&gt;EMAL- Email Address
                                      &lt;br&gt;AUBN- Australian Business N=
umber
                                      &lt;br&gt;ORGN- Organisation ID
                                  maxLength: 4
                                  enum:
                                    - EMAL
                                    - TELI
                                    - AUBN
                                    - ORGN
                                  type: string
                  result:
                    type: object
                    properties:
                      transactionDetails:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      transactionDetails:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '404':
          description: Not Found
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /healthcheck:
    get:
      tags:
        - HealthCheck
      description: retrieves HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        '200':
          description: healthcheck status
          content:
            application/json:
              schema:
                description: healthcheck status
                properties:
                  status:
                    type: string
                    enum:
                      - success
