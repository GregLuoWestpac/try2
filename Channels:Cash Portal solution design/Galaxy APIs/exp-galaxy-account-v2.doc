                          description: Division and the associated accountG=
roups
                          allOf:
                            - type: object
                              properties:
                                divisionName:
                                  description: Division Name
                                  example: AUD Group
                                  type: string
                                  maxLength: 70
                                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                                divisionId:
                                  description: Division id
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            - type: object
                              properties:
                                id:
                                  description: A unique id generated for an=
 entity which is the mode of communication between the UI and Exp API, via =
redux store
                                  example: d0868661-b955-4e76-9f15-d97626f7=
df6b
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
