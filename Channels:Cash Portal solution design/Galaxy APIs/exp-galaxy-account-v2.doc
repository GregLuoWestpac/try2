<pre style=3D"font-size: 12px;">openapi: 3.0.3
info:
  version: 1.1.0
  title: Galaxy-Account Experience API
  description: This API retrieves the account balances for the Westpac Cash=
 portal customers
  contact:
    url: https://mesh.westpac.com.au/components/microFrontends/galaxy-accou=
nt
  x-baseSchemaVersion: 0.13.0
servers:
  - url: /exp/galaxy/account/v2
components:
  securitySchemes:
    BasicAuth:
      type: http
      scheme: basic
    ScopedAccess:
      description: ScopedAccess is used to provide ACL
      type: oauth2
      flows:
        implicit:
          authorizationUrl: https://ignored-for-scoped-access
          scopes: {}
  parameters:
    x-brandId:
      name: x-brandId
      in: header
      description: The `brand` as per Enterprise Reference Data. For public=
 channels, it is expected that the UI platform will derive this value from =
the URL of the application and inject it as it is done today for the authen=
ticated customer channel
      schema:
        type: string
        enum:
          - WBC
          - WBG
          - SGB
          - BSA
          - BOM
          - RAMS
          - WNZL
      required: true
    x-authorization:
      name: x-authorization
      in: header
      description: The credentials required for authentication or authorisa=
tion to a downstream system. This header must follow the same conventions a=
s for the standard HTTP authorization header as defined in RFC2616 (ie. sch=
eme and credentials).
      schema:
        type: string
        pattern: ^Bearer\s[\w.-]+$
    x-deviceExperience:
      name: x-deviceExperience
      in: header
      description: |-
        Non-functional header to provide telemetry and debugging aids when =
logged to Splunk. The proposal is to have a single string encoded value wit=
h the below attributes to start off with. Other attributes can be added as =
the need arises

        TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWPORT:=
xs|sm|md|lg,ORIENTATION:portrait|landscape
      schema:
        type: array
        items:
          type: string
          pattern: ^[\w;,-]{1,250}$
      required: false
    x-deviceFingerprint:
      name: x-deviceFingerprint
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        A unique device finger print generated either by
          1. The NativeJS interface when device detection alludes to native=
 app
          2. The external RSA vendor javascript when device detection is no=
t a native app
      schema:
        type: string
        maxLength: 8000
        pattern: ^[a-zA-Z0-9%+=3D]+$
      required: false
    x-devicePerms:
      name: x-devicePerms
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        Device permissions as returned by the NativeJS interface when devic=
e detection alludes to native app
        This header will not be present when a SAFI request is made from a =
browser
      schema:
        type: string
        pattern: ^[a-zA-Z0-9%+=3D]+$
        maxLength: 500
      required: false
    x-onBehalfOfId:
      name: x-onBehalfOfId
      in: header
      description: The unique identifier for the party on whose behalf the =
user identified by x-userId is acting. (eg. Customer internal identifier su=
ch as CIS/GCIS key).
      schema:
        type: string
        pattern: ^[\d]{7,16}$
      required: false
    x-originatingDeviceId:
      name: x-originatingDeviceId
      in: header
      description: Identifies the device from which this request originated=
. The device could be a staff computer, ATM, internal server, mobile device=
.
      schema:
        type: string
      required: false
    x-consumer-id:
      name: x-consumer-id
      in: header
      description: Identifies the calling application of the API. DO NOT PO=
PULATE as Gateway will inject this value. Also gateway overrides the header=
 if already present
      schema:
        type: string
      required: false
  schemas:
    healthCheckStatus:
      description: healthcheck status
      properties:
        status:
          type: string
          enum:
            - success
    Error:
      description: Represent an individual error.
      type: object
      required:
        - code
        - message
      properties:
        code:
          description: Error Code.
          type: integer
          format: int32
        message:
          description: Error Message
          type: string
        details:
          description: Detailed information about the error
          type: string
  responses:
    200healthCheckStatusResponse:
      description: healthcheck status
      content:
        application/json:
          schema:
            description: healthcheck status
            properties:
              status:
                type: string
                enum:
                  - success
    400ErrorResponse:
      description: |
        __Bad Request__

        Possible errors

          | Error Code | Error Message | Error Description |
          | ------- | -------- | --- |
          | n   | A business description of the error  | Detailed informati=
on about the business error. All errors surfaced to the UI MUST be business=
 errors and not technical |
      content:
        application/json:
          schema:
            type: object
            properties:
              errors:
                type: array
                items:
                  description: Represent an individual error.
                  type: object
                  required:
                    - code
                    - message
                  properties:
                    code:
                      description: Error Code.
                      type: integer
                      format: int32
                    message:
                      description: Error Message
                      type: string
                    details:
                      description: Detailed information about the error
                      type: string
            example:
              errors:
                - code: 10001
                  message: One or more request parameters are missing or in=
valid
                  details: Contact the application support team to investig=
ate if the issue persists
    403ErrorResponse:
      description: |
        __Forbidden__

        Possible errors

          | Error Code | Error Message | Error Description |
          | ------- | -------- | --- |
          | n   | A business description of the error  | Detailed informati=
on about the business error. All errors surfaced to the UI MUST be business=
 errors and not technical |
      content:
        application/json:
          schema:
            type: object
            properties:
              errors:
                type: array
                items:
                  description: Represent an individual error.
                  type: object
                  required:
                    - code
                    - message
                  properties:
                    code:
                      description: Error Code.
                      type: integer
                      format: int32
                    message:
                      description: Error Message
                      type: string
                    details:
                      description: Detailed information about the error
                      type: string
            example:
              errors:
                - code: 20001
                  message: You may not have the appropriate access to the r=
equested information
                  details: Contact the application support team to investig=
ate if the issue persists
    404ErrorResponse:
      description: |
        __Resource not found__

        Possible errors

          | Error Code | Error Message | Error Description |
          | ------- | -------- | --- |
          | n   | A business description of the error  | Detailed informati=
on about the business error. All errors surfaced to the UI MUST be business=
 errors and not technical |
          | 2   | Oops! Something went wrong | The application encountered =
some unexpected issues while processing the request. Refer to the logs for =
more details |
      content:
        application/json:
          schema:
            type: object
            properties:
              errors:
                type: array
                items:
                  description: Represent an individual error.
                  type: object
                  required:
                    - code
                    - message
                  properties:
                    code:
                      description: Error Code.
                      type: integer
                      format: int32
                    message:
                      description: Error Message
                      type: string
                    details:
                      description: Detailed information about the error
                      type: string
            example:
              errors:
                - code: 2
                  message: Oops! Something went wrong
                  details: The application encountered some unexpected issu=
es while processing the request. Refer to the logs for more details
    500ErrorResponse:
      description: |
        __Internal Server Error__

        Possible errors

          | Error Code | Error Message | Error Description |
          | ------- | -------- | --- |
          | 10001   | Oops! Something went wrong  | The application encount=
ered some unexpected issues while processing the request. Please try again =
later |
      content:
        application/json:
          schema:
            type: object
            properties:
              errors:
                type: array
                items:
                  description: Represent an individual error.
                  type: object
                  required:
                    - code
                    - message
                  properties:
                    code:
                      description: Error Code.
                      type: integer
                      format: int32
                    message:
                      description: Error Message
                      type: string
                    details:
                      description: Detailed information about the error
                      type: string
            example:
              errors:
                - code: 10001
                  message: Oops! Something went wrong
                  details: The application encountered some unexpected issu=
es while processing the request. Please try again later
security:
  - BasicAuth: []
paths:
  /arrangements:
    post:
      description: This endpoint retrieves an enriched list of arrangements=
 for the accounts the logged in user is entitled to see.
      operationId: postArrangements
      tags:
        - Arrangements
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: arrangementStatus
          description: Account status. "ACTIVE" will fetch arrangements whi=
ch are active only. "ACTIVE_AND_INACTIVE" will fetch arrangements which are=
 Active and Inactive both. If user is not passing this query parameter then=
 default option of ACTIVE_AND_INACTIVE will be used.
          in: query
          required: false
          example: ACTIVE_AND_INACTIVE
          schema:
            type: string
            pattern: ^(ACTIVE|ACTIVE_AND_INACTIVE){1}$
            enum:
              - ACTIVE
              - ACTIVE_AND_INACTIVE
        - name: groupId
          in: query
          required: false
          description: Group ID used for filtering results
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: divisionId
          in: query
          required: false
          description: Division ID used for returning account associated wi=
th that division
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: asAtDateQueryParam
          in: query
          description: |
            The date (ISO 8601) for which to retrieve arrangements "as at".
            If not provided, the default effective date is T-1 day.
          required: true
          schema:
            description: The date in ISO 8601 format
            type: string
            format: date
            example: '2024-01-28'
          example: '2026-01-13'
        - name: sortBy
          in: query
          description: |
            A pre-defined set of named values to sort the results by.
            Use `+` for ascending and `-` for descending sorting.
          schema:
            type: string
            enum:
              - +accountId
              - '-accountId'
              - +accountName
              - '-accountName'
          required: false
          example: +accountId
        - name: pageSize
          in: query
          description: |
            Number of entries to be returned in a single page.
          schema:
            type: integer
            format: int32
            minimum: 10
            maximum: 1000
            default: 1000
          required: false
          example: 100
        - name: pageKey
          in: query
          description: The key identifying the page of data to be returned
          schema:
            type: integer
            format: int32
            maximum: 1000
            default: 0
          required: false
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      requestBody:
        description: The search filter to be applied to arrangements
        content:
          application/json:
            schema:
              description: The search filter to be applied to arrangements
              type: object
              properties:
                searchFilter:
                  example: Payroll
                  description: Field allowing some special characters
                  type: string
                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                  maxLength: 50
      responses:
        '200':
          description: The retrieved arrangements for all the entitled acco=
unts
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      arrangements:
                        type: array
                        items:
                          description: Customer arrangement (account)
                          type: object
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            entityName:
