                          type: string
                    example:
                      arrangements:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
