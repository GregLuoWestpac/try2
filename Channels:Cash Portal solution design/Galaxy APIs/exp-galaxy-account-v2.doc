  /accountGroups:
    get:
      description: This endpoint retrieves a list of account groups.
      operationId: getAccountGroups
      tags:
        - AccountGroups
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: entAction
          in: query
          description: The entitlement action to be performed. For Account =
listing ACTION will be "viewAccounts"
          required: true
          schema:
            type: string
            pattern: ^[\w,-]+$
            minLength: 5
            maxLength: 50
          example: viewAccounts
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
      responses:
        '200':
          description: The list of account groups response
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      accountGroups:
                        type: array
                        items:
                          type: object
                          description: Account group details
                          allOf:
                            - type: object
                              description: Account group details
                              properties:
                                groupId:
                                  description: Group ID of the account grou=
p
                                  minLength: 5
                                  maxLength: 50
                                  example: e7b8a2c2-1d2f-4a6b-9c3e-12345678=
9abc
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                                groupName:
                                  description: Group name of the account gr=
oup
                                  minLength: 1
                                  maxLength: 200
                                  example: AUD Group
                                  type: string
                                  pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            - type: object
                              properties:
                                id:
                                  description: A unique id generated for an=
 entity which is the mode of communication between the UI and Exp API, via =
redux store
                                  example: d0868661-b955-4e76-9f15-d97626f7=
df6b
                                  type: string
                                  pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0=
-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                  result:
                    type: object
                    properties:
                      accountGroups:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      accountGroups:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
  /accountList:
    get:
      description: This endpoint retrieves all accounts from PDP(Entitlemen=
ts) that the user is entitled to view. And if an account group id is suppli=
ed, the endpoint will retrieve all accounts from PDP(Entitlements) the user=
 is entitled to view for the supplied account ID.
      operationId: getAccountList
      tags:
        - getAccountList
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
        - name: groupId
          in: query
          required: false
          description: Group ID used for filtering results
          schema:
            description: A unique identifier
            type: string
            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a=
-f]{3}-[0-9a-f]{12}$
        - name: protected-orgId
          description: This header is used to send the query parameter Orga=
nisation CISKey.
          in: header
          required: true
          example: '06089457589'
          schema:
            description: CIS Key of the organisation
            type: string
            example: '06089457589'
            pattern: ^\d{11}$
        - name: accountStatus
          description: Account status. "ACTIVE" will fetch arrangements whi=
ch are active only. "ACTIVE_AND_INACTIVE" will fetch accounts which are bot=
h Active and Inactive. If no parameter is passed, the default option of ACT=
IVE_AND_INACTIVE will be used.
          in: query
          required: false
          example: ACTIVE_AND_INACTIVE
          schema:
            type: string
            default: ACTIVE_AND_INACTIVE
            enum:
              - ACTIVE
              - ACTIVE_AND_INACTIVE
      responses:
        '200':
          description: The retrieved accountList for the user / groupId
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      accountList:
                        type: array
                        items:
                          type: object
                          properties:
                            id:
                              description: A unique id generated for an arr=
angement which is the mode of communication between the UI and Exp API
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            accountName:
                              description: Account Name
                              minLength: 1
                              maxLength: 140
                              example: Apple Tree
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            accountType:
                              description: Account type; it is product name=
 in master product system
                              minLength: 1
                              maxLength: 250
                              example: Corporate Investment Account
                              type: string
                              pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                            status:
                              description: Status; example-&gt; ACTIVE, INA=
CTIVE
                              type: string
                              enum:
                                - ACTIVE
                                - INACTIVE
                              example: ACTIVE
                            currencyCode:
                              description: A code allocated to a currency b=
y a Maintenance Agency under an international identification scheme, as des=
cribed in the latest edition of the international standard ISO 4217 =E2=80=
=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&gt;=
 Usage- Caller to set 'AUD' to this field.
                              type: string
                              pattern: ^[A-Z]{3}$
                              example: AUD
                  result:
                    type: object
                    properties:
                      accountList:
                        description: A list of ids relating to the resource=
 that was requested
                        type: array
                        items:
                          description: Entity Id
                          type: string
                    example:
                      accountList:
                        - d0868661-b955-4e76-9f15-d97626f7df6b
        '400':
          description: Bad Request
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
        '500':
          description: Internal Server Error
          content:
            application/json:
              schema:
                type: object
                description: Contains list of Errors
                properties:
                  result:
                    type: object
                    description: Contains list of Errors
                    properties:
                      errors:
                        type: array
                        items:
                          type: object
                          description: Represents an individual error
                          properties:
                            code:
                              description: Error Code
                              type: integer
                              format: int32
                              example: 400
                            message:
                              description: Error Message
                              maxLength: 32
                              example: Bad Request
                              type: string
                              pattern: ^[\w ]+$
                            details:
                              description: |
                                Detailed information about the error. If it=
 is an error scenario where an error mappping is required as per MAD teams'=
 specification, the string will contain the UIError object.
                              type: string
                              pattern: ^[\w-., ]+$
                              maxLength: 500
                              example: Check logs for details
                          required:
                            - code
                            - message
