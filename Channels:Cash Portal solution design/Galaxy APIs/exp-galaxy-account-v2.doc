3456789abc
                                        type: string
                                        pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[=
0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                                      groupName:
                                        description: Group name of the acco=
unt group
                                        minLength: 1
                                        maxLength: 200
                                        example: AUD Group
                                        type: string
                                        pattern: ^[a-zA-Z0-9\- !,.:\;?_@]*$
                  result:
                    type: object
                    properties:
