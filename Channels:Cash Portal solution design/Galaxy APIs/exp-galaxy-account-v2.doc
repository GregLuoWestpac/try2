            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        description: The account ID and transaction ID to be searched for t=
he transaction details.
        required: true
        content:
          application/json:
            schema:
              description: The account ID and transaction ID to be searched=
 for the transaction details.
              type: object
              required:
                - accountId
                - transactionId
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
                transactionId:
                  description: Account Ledger Transaction ID (a.k.a. 10x Tr=
ansaction ID), a unique reference assigned by FIS CBIS (as External Referen=
ce ID) to request a transaction posting at 10x.
                  type: string
                  minLength: 1
                  maxLength: 128
                  pattern: ^[\w-]+$
                  example: d0868661-b955-4e76-9f15-d97626f7df6b
      responses:
        '200':
          description: The retrieved transaction details for the provided q=
uery.
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      transactionDetails:
                        type: array
                        items:
                          description: Transaction details
                          type: object
                          properties:
                            id:
                              description: A unique id generated for each r=
ecord which is the mode of communication between the UI and Exp API
                              example: d0868661-b955-4e76-9f15-d97626f7df6b
                              type: string
                              pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-=
f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                            accountName:
                              description: Arrangement alias name
                              type: string
                              pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|"|=
=3D)).*[\s\S]*$
                              maxLength: 50
                            accountId:
                              description: Full account number with format =
&lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                              type: string
                              pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                              maxLength: 35
                              example: 035845 103784254
                            narrative:
                              description: Transaction narrative
                              type: string
                              pattern: ^[\w ]+$
                              maxLength: 100
                              example: Deposit to 062000 11111111
                            transactionDateTime:
                              type: string
                              description: the utc timestamp of the log rec=
ord as per rfc-3339 (https://tools.ietf.org/html/rfc3339#section-5.6)
                              format: date-time
                              example: '2024-01-28T15:27:49.732Z'
                            amount:
                              description: The transaction amount
                              type: object
                              deprecated: true
                              properties:
                                currencyCode:
                                  description: A code allocated to a curren=
cy by a Maintenance Agency under an international identification scheme, as=
 described in the latest edition of the international standard ISO 4217 =E2=
=80=9CCodes for the representation of currencies and funds=E2=80=9D.&lt;br&=
gt; Usage- Caller to set 'AUD' to this field.
                                  type: string
                                  pattern: ^[A-Z]{3}$
                                  example: AUD
                                amount:
                                  description: A positive number string of =
up to four decimal places (including zero). Must have at least one digit af=
ter the decimal point.
                                  type: string
                                  pattern: ^\d{1,13}\.\d{1,4}$
                                  example: '1000.0000'
                                position:
                                  type: string
                                  enum:
                                    - CR
                                    - DR
                                  example: CR
                            type:
                              description: Transaction direction; either
                              type: string
                              enum:
                                - Debit
                                - Credit
                              example: Debit
                            payer:
                              description: Debtor's entity name and account=
 number in multi-line; applicable for the inbound payments
                              type: object
                              properties:
                                name:
                                  description: account name
                                  maxLength: 255
                                  example: John S
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                nickName:
                                  description: account alias name (nickname=
)
                                  maxLength: 255
                                  example: Payroll account
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                accountId:
                                  description: Full account number with for=
mat &lt;BSB  Account Number&gt; -&gt; "035845 123456789"
                                  type: string
                                  pattern: ^[0-9]{6} [a-zA-Z\d.]{6,28}$
                                  maxLength: 35
                                  example: 035845 103784254
                            debitAccount:
                              description: Debtor's account nickname and ac=
count number in multi-line; applicable for outbound payment and funds trans=
fer.
                              type: object
                              properties:
                                name:
                                  description: account name
                                  maxLength: 255
                                  example: John S
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                nickName:
                                  description: account alias name (nickname=
)
                                  maxLength: 255
                                  example: Payroll account
                                  type: string
                                  pattern: ^(?!.*(;|--|\{|\}|&lt;|&gt;|%|#|=
"|=3D)).*[\s\S]*$
                                accountId:
