<p><br></p>
<h2 id=3D"expgalaxyaccountv2-POST/statements/{statementId}">POST /<span sty=
le=3D"font-size: 14.0px;letter-spacing: 0.0px;">statements</span><span styl=
e=3D"letter-spacing: -0.008em;">/</span><span style=3D"font-size: 14.0px;le=
tter-spacing: 0.0px;">{statementId}</span></h2>
