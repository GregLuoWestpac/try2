  /arrangements/interestFacilities:
    post:
      description: This endpoint retrieves interest facilities information =
for a specific account
      operationId: postArrangementsInterestFacilities
      tags:
        - InterestFacilities
      parameters:
        - name: x-authorization
          in: header
          description: The credentials required for authentication or autho=
risation to a downstream system.  This header must follow the same conventi=
ons as for the standard HTTP authorization header as defined in RFC2616 (ie=
. scheme and credentials).
          schema:
            type: string
            pattern: ^Bearer\s[\w\.-]+$
        - name: x-brandId
          in: header
          description: |-
            The `brand` as per Enterprise Reference Data
            NOTE:
            - The values here were previously aligned to NetIQ brands which=
 map to the Gel themes
            - These have now been normalised as per ERD from UI
            - The major changes are for STG where as per ERD the value is S=
GB
            All Experience APIs MUST change their swaggers to align with th=
is change.
          required: true
          schema:
            type: string
            enum:
              - WBC
              - SGB
              - BSA
              - BOM
              - RAMS
              - WNZL
        - name: x-channelType
          in: header
          description: Channel Type
          required: true
          schema:
            type: string
            enum:
              - Internal
        - name: x-deviceExperience
          in: header
          description: |-
            Non-functional header to provide telemetry and debugging aids w=
hen logged to Splunk. The proposal is to have a single string encoded value=
 with the below attributes to start off with. Other attributes can be added=
 as the need arises

            TYPE:app|browser,PLATFORM:ios|andriod|windows|linux|macos,VIEWP=
ORT:xs|sm|md|lg,ORIENTATION:portrait|landscape
          schema:
            type: array
            items:
              type: string
              pattern: ^[\w:,-]{1,250}$
          style: simple
          explode: false
          required: true
      requestBody:
        description: Account ID information to retrieve interest facilities
        required: true
        content:
          application/json:
            schema:
              description: Request to retrieve interest facilities for a sp=
ecific account
              type: object
              required:
                - accountId
              properties:
                accountId:
                  type: object
                  description: Account ID (BSB and Account Number)
                  required:
                    - BSB
                    - accountNumber
                  properties:
                    BSB:
                      description: Bank State Branch Number
                      type: string
                      pattern: ^\d{6}$
                      example: '035845'
                    accountNumber:
                      description: Account Number
                      type: string
                      pattern: ^[a-zA-Z\d.]+$
                      minLength: 6
                      maxLength: 28
                      example: '01235674897'
                  example:
                    BSB: '035845'
                    accountNumber: '10235674897'
      responses:
        '200':
          description: Interest facilities information retrieved successful=
ly
          content:
            application/json:
              schema:
                type: object
                properties:
                  entities:
                    type: object
                    properties:
                      interestFacilities:
                        description: Interest facilities information for an=
 account
                        type: object
                        properties:
                          id:
                            description: A unique identifier for the intere=
st facility
                            type: string
                            pattern: ^[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]=
{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$
                          isPreferential:
                            description: Whether the facility has preferent=
ial rates
                            type: boolean
                            example: true
                          debitInterest:
                            description: Debit interest rate information
                            type: object
                            properties:
                              rateWithinLimit:
                                type: array
                                items:
                                  description: Interest rate details with e=
ffective date
                                  type: object
                                  properties:
                                    effectiveFromDate:
                                      type: string
                                      format: date
                                      example: '2024-01-01'
                                    effectiveToDate:
                                      type: string
                                      format: date
                                      example: '2024-12-31'
                                    rate:
                                      description: Interest rate and calcul=
ation method
                                      type: object
