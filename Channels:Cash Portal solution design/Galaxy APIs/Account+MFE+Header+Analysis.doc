<td class=3D"confluenceTd">
<div class=3D"content-wrapper">
<p><span class=3D"status-macro aui-lozenge aui-lozenge-success">NO</span></=
p>
</div></td>
<td class=3D"confluenceTd"><br></td>
</tr>
<tr class=3D"">
