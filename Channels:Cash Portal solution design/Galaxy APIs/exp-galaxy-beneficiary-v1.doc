<pre style=3D"font-size: 12px;">openapi: 3.0.3

###########################################################################=
#####
#                       API Information                                    =
    #
###########################################################################=
#####

info:
  title: 'EXP API for beneficiary management'
  description: 'The API represents the EXP layer for the beneficiary manage=
ment.'
  version: 1.0.0
  contact:
    url: "https://mesh.westpac.com.au/components/apis/galaxy-beneficiary-mi=
crofrontend"
  x-baseSchemaVersion: 0.13.0

###########################################################################=
#####
#                  Base Path                                               =
    #
###########################################################################=
#####
servers:
  - url: /exp/galaxy/beneficiary/v2

###########################################################################=
#####
#                                  Security                                =
    #
###########################################################################=
#####
security:
  - BasicAuth: []

###########################################################################=
#####
#                      Paths                                               =
    #
###########################################################################=
#####
paths:
  /healthcheck:
    get:
      description: Retrieve HealthCheck Summary of API.
      operationId: getHealthCheckStatus
      responses:
        "200":
          $ref: "#/components/responses/200healthCheckStatusResponse"

  /beneficiaries/beneficiary:
    post:
      requestBody:
        description: Create beneficiary
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BeneficiaryRequest"
      tags:
        - beneficiaries
      operationId: postBeneficiary
      summary: create beneficiary
      description: Create beneficiary
      parameters:
        # in case generated contract already contains the below it's okay t=
o remove.
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-messageId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-appCorrelationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-organisationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-originatingSystemId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-consumerType"
        - $ref: "#/components/parameters/x-brandId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-authorization"
        - $ref: "#/components/parameters/x-deviceExperience"
      responses:
        "201":
          $ref: "#/components/responses/200SuccessfulCreationResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
  /beneficiaries/id:
    put:
      requestBody:
        description: Update beneficiary
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BeneficiaryUpdateRequest"
      tags:
        - beneficiaries
      operationId: putBeneficiary
      summary: update beneficiary
      description: Update beneficiary
      parameters:
        # in case generated contract already contains the below it's okay t=
o remove.
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-messageId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-appCorrelationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-organisationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-originatingSystemId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-consumerType"
        - $ref: "#/components/parameters/x-brandId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-authorization"
        - $ref: "#/components/parameters/x-deviceExperience"
      responses:
        "200":
          $ref: "#/components/responses/200SuccessfulCreationResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
  /beneficiaries/summary:
    get:
      summary: retrieve beneficiary list
      description: retrieve beneficiary list
      tags:
        - beneficiaries
      operationId: beneficiaries
      parameters:
        - name: pageKey
          description: current page for pagination
          in: query
          schema:
            type: integer
            example: 0
        - name: pageSize
          description: page size for the pagination
          in: query
          schema:
            type: integer
            example: 100
        - name: nickanme
          in: query
          description: page size for the pagination
          schema:
            type: string
            description: beneficiaryNickname for filtering, optional
            example: "nickname"
            pattern: "^[a-zA-Z0-9\\s\\W]+$"
        - name: detail
          in: query
          description: beneficiaryDetail for filtering, optional
          schema:
            type: string
            example: "payID name"
            pattern: "^[a-zA-Z0-9\\s\\W]+$"
        - name: type
          in: query
          description: beneficiaryType for filtering, optional
          schema:
            type: string
            example: "BSB and account"
            pattern: "^[a-zA-Z0-9\\s\\W]+$"
        - name: status
          in: query
          description: beneficiaryStatus for filtering, optional
          schema:
            type: string
            example: "ACTIVE"
            pattern: "^[a-zA-Z0-9\\s\\W]+$"
        - name: sort
          in: query
          description: for sorting with the sorting pattern, + for asc and =
- for desc
          schema:
            type: string
            example: "+age,+name.surname"
            pattern: "^[a-zA-Z0-9\\.\\,\\+\\-]+$"
        # in case generated contract already contains the below it's okay t=
o remove.
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-messageId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-appCorrelationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-organisationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-originatingSystemId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-consumerType"
        - $ref: "#/components/parameters/x-brandId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-authorization"
        - $ref: "#/components/parameters/x-deviceExperience"
      responses:
        "200":
          $ref: "#/components/responses/200SuccessfulRetrievalResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"

  /beneficiaries/ids:
    patch:
      summary: archiving a beneficiary
      description: archiving a beneficiary
      tags:
        - beneficiaries
      operationId: archiveBeneficiaries
      requestBody:
        content:
          application/merge-patch+json:
            schema:
              type: array
              items:
                  type: object
                  description: beneficiary request object
                  properties:
                    id:
                      type: string
                      example: "266c399d-ddb4-4f6b-b560-c7b26e968866"
                      pattern: "^[a-zA-Z0-9\\-]+$"
                      description: id of the beneficiary
      parameters:
        # in case generated contract already contains the below it's okay t=
o remove.
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-messageId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-appCorrelationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-organisationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-originatingSystemId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-consumerType"
        - $ref: "#/components/parameters/x-brandId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-authorization"
        - $ref: "#/components/parameters/x-deviceExperience"
      responses:
        "200":
          $ref: "#/components/responses/200SuccessfulDeletionBeneficiaryRes=
ponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
  /alias/lookup:
    post:
      description: Facade of payment alias lookup endpoint
      requestBody:
        description: Facade of payment alias lookup endpoint
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                authBIC8:
                  type: string
                  description: BIC8 identifier
                  example: "MIDLGB22"
                  pattern: "^[a-zA-Z0-9]+$"
                aliasId:
                  type: string
                  description: alias id of the PayID
                  example: "0407123456"
                  pattern: "^[0-9]+$"
                aliasType:
                  type: string
                  description: alias type of the PayID
                  example: TELI
                  pattern: "^[a-zA-Z]+$"
      tags:
        - aliasLookup
      operationId: aliasLookup
      parameters:
        # in case generated contract already contains the below it's okay t=
o remove.
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-messageId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-appCorrelationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-organisationId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-originatingSystemId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-consumerType"
        - $ref: "#/components/parameters/x-brandId"
        - $ref: "https://schema.mesh.westpac.com.au/platform/contracts/0.13=
.0/openapi-base.yaml#/components/parameters/x-authorization"
        - $ref: "#/components/parameters/x-deviceExperience"
      responses:
        "200":
          $ref: "#/components/responses/200AliasLookupResponse"
        "400":
          $ref: "#/components/responses/400BadRequest"
        "500":
          $ref: "#/components/responses/500InternalServerErrorResponse"
components:
  schemas:
    BeneficiaryResponse:
      description: Represents Beneficiary Response Object
      properties:
        id:
          description: unique id for the beneficiary
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        externalId:
          description: external id for the beneficiary
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        nickname:
          description: nickname for the beneficiary
          type: string
          example: office 1
          minLength: 0
          maxLength: 40
        currency:
          description: AUD
          type: string
          example: abc
          minLength: 0
          maxLength: 3
        status:
          description: status of the beneficiary
          type: string
          example: ACTIVE
          enum:
            - "ACTIVE"
            - "ARCHIVED"
        account:
          $ref: "#/components/schemas/Account"
    BeneficiaryUpdateRequest:
      description: Represents Beneficiary Update Request Object
      properties:
        id:
          description: unique id for the beneficiary
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        externalId:
          description: external id for the beneficiary
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        nickname:
          description: nickname for the beneficiary
          type: string
          example: "office 1"
          minLength: 0
          maxLength: 20
          pattern: "^[a-zA-Z0-9\\s]+$"
        currency:
          description: currency used
          type: string
          example: abc
          minLength: 0
          maxLength: 40
          pattern: '^([a-zA-Z])+$'
        account:
          $ref: "#/components/schemas/Account"
    BeneficiaryRequest:
      description: Represents Beneficiary Request Object
      properties:
        nickname:
          description: nickname for the beneficiary
          type: string
          example: "office 1"
          minLength: 0
          maxLength: 20
          pattern: "^[a-zA-Z0-9\\s]+$"
        currency:
          description: currency used
          type: string
          example: abc
          minLength: 0
          maxLength: 40
          pattern: '^([a-zA-Z])+$'
        account:
          $ref: "#/components/schemas/Account"
    Account:
      type: object
      description: Represents Account detail object
      oneOf:
        - $ref: "#/components/schemas/Bsb"
        - $ref: "#/components/schemas/PayID"
    Bsb:
      type: object
      description: Represents Account detail object
      properties:
        bsb:
          description: bsb for the account
          type: string
          example: "123456"
          minLength: 0
          maxLength: 6
          pattern: "^[0-9]+$"
        accountName:
          description: name of the account
          type: string
          example: "payee 1"
          minLength: 0
          maxLength: 40
        accountNumber:
          description: account number
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 20
          pattern: "^[0-9]+$"
    PayID:
      type: object
      description: Represents Account detail object
      properties:
        payIDType:
          description: "alias type for the PayID, either email / phone / or=
gId / bsb"
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 20
        payIDName:
          description: "pay id name returned from the alias resolution"
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 256
        payIDValue:
          description: "alias id for the PayID, either email / phone / orgI=
d / bsb"
          type: string
          example: "123456789"
          minLength: 0
          maxLength: 256
    AliasLookupResponse:
      description: Represents Alias lookup Response Object, it depends on t=
he upstream definition.
      properties:
        aliasType:
          description: alias type
          type: string
          example: "email"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        name:
          description: name of the alias
          type: string
          example: "someone"
          pattern: "^[a-zA-Z0-9]+$"
        servicerBIC:
          description: servicer BIC of the alias
          type: string
          example: "BIC"
          pattern: "^[a-zA-Z0-9]+$"
        registrationDateTime:
          description: registration date time
          type: string
          format: date-time
          example: "2020-04-22T13:05:10Z"
        lastUpdatedDateTime:
          description: last data updated time
          type: string
          format: date-time
          example: "2020-04-22T13:05:10Z"
        resolutionDateTime:
          description: resolution time
          type: string
          format: date-time
          example: "2020-04-22T13:05:10Z"
        accountId:
          description: account id
          type: string
          example: "123456"
          pattern: "^[a-zA-Z0-9]+$"
        issuer:
          description: name of the alias
          type: string
          example: "someone"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        idScheme:
          description: id scheme of the alias
          type: string
          example: "idscheme"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        legalName:
          description: legal name of the alias
          type: string
          example: "legalname"
          minLength: 0
          maxLength: 50
          pattern: "^[a-zA-Z0-9]+$"
        returnCode:
          description: return code
          type: string
          example: "200"
          pattern: "^[0-9]+$"
    Error:
      description: Represent an individual error.
      type: object
      required:
        - code
        - message
      properties:
        code:
          description: Error Code.
          type: integer
          format: int32
        message:
          description: Error Message
          type: string
        details:
          description: Detailed information about the error
          type: string
###########################################################################=
#####
#                                   Parameters                             =
    #
###########################################################################=
#####
  parameters:
    x-deviceExperience:
      name: x-deviceExperience
      in: header
      description: |-
        Non-functional header to provide telemetry and debugging aids when =
logged to Splunk. The proposal is to have a single string encoded value wit=
h the below attributes to start off with. Other attributes can be added as =
the need arises

        TYPE:app|browser,PLATFORM:ios|android|windows|linux|macos,VIEWPORT:=
xs|sm|md|lg,ORIENTATION:portrait|landscape
      schema:
        type: array
        items:
          type: string
          pattern: ^[\w -]{1,250}$
      style: simple
      explode: false
      required: true
    x-deviceFingerprint:
      name: x-deviceFingerprint
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        A unique device finger print generated either by
          1. The NativeJS interface when device detection alludes to native=
 app
          2. The external RSA vendor javascript when device detection is no=
t a native app
      schema:
        type: string
        maxLength: 8000
        pattern: ^[a-zA-Z0-9%+=3D]+$
      required: false
    x-devicePerms:
      name: x-devicePerms
      in: header
      description: |-
        NOTE: Header is set only when invoking a SAFI flow from the UI

        Device permissions as returned by the NativeJS interface when devic=
e detection alludes to native app
        This header will not be present when a SAFI request is made from a =
browser
      schema:
        type: string
        pattern: ^[a-zA-Z0-9%+=3D]+$
        maxLength: 500
      required: false
    x-brandId:
      name: x-brandId
      in: header
      description: |-
        The `brand` as per Enterprise Reference Data
        NOTE:
        - The values here were previously aligned to NetIQ brands which map=
 to the Gel themes
        - These have now been normalised as per ERD from UI
        - The major changes are for STG where as per ERD the value is SGB
        All Experience APIs MUST change their swaggers to align with this c=
hange.
      schema:
        type: string
        enum:
          - WBC
          - SGB
          - BSA
          - BOM
          - RAMS
          - WNZL
      required: true

###########################################################################=
#####
#                           Responses                                      =
    #
###########################################################################=
#####
  responses:
    200healthCheckStatusResponse:
     description: healthcheck status
     content:
        application/json:
          schema:
            type: object
            properties:
              status:
                type: string
                enum:
                  - success
    200SuccessfulSingleResponse:
      description: beneficiary detail response
      content:
        application/json:
          schema:
            type: object
            properties:
              data:
                $ref: "#/components/schemas/BeneficiaryResponse"
    200SuccessfulRetrievalResponse:
      description: beneficiary creation response
      content:
        application/json:
          schema:
            type: object
            properties:
              data:
                type: object
                properties:
                  beneficiaries:
                    type: array
                    items:
                      $ref: "#/components/schemas/BeneficiaryResponse"
                  paging:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          description: Paging Unique Id
                          type: string
                          maxLength: 3
                          pattern: ^\d+$
                          example: '1'
                        pageSize:
                          description: Number of items per page
                          type: integer
                          format: int32
                          example: 50
                        count:
                          description: Total number of items available
                          type: integer
                          format: int32
                          example: 160
                        previousPageKey:
                          description: Key for start of previous page
                          type: string
                          pattern: ^\d+$
                          maxLength: 3
                          example: '0'
                        nextPageKey:
                          description: Key for start of next page
                          type: string
                          pattern: ^\d+$
                          maxLength: 3
                          example: '2'
                        moreItems:
                          description: Indicator to show if there are more =
items available. If true, more records are available (by narrowing search p=
arameters)
                          type: boolean
                          example: true
    200SuccessfulCreationResponse:
      description: beneficiary creation response
      content:
        application/json:
          schema:
            type: object
            properties:
              data:
                type: object
                properties:
                  beneficiaries:
                    type: array
                    items:
                      $ref: "#/components/schemas/BeneficiaryResponse"
    200SuccessfulDeletionBeneficiaryResponse:
      description: beneficiary deletion response
      content:
        application/json:
          schema:
            type: object
            properties:
              result:
                type: object
                properties:
                  id:
                    type: array
                    items:
                      type: string
    200SuccessfulDeletionAccountResponse:
      description: account deletion response
      content:
        application/json:
          schema:
            type: object
            properties:
              result:
                type: object
                properties:
                  accountId:
                    type: array
                    items:
                      type: string
    200AliasLookupResponse:
      description: Alias lookup response
      content:
        application/json:
          schema:
            type: object
            properties:
              data:
                type: object
                properties:
                  items:
                    $ref: "#/components/schemas/AliasLookupResponse"
    400BadRequest:
      description: |
        __Bad Request__

        Possible errors

        &lt;table&gt;
        &lt;tr&gt;
         &lt;th align=3D"left"&gt;Error Code&lt;/th&gt;
         &lt;th align=3D"left"&gt;Error Message&lt;/th&gt;
         &lt;th&gt;&amp;nbsp&amp;nbsp&lt;/th&gt;
         &lt;th&gt;Error Description&lt;/th&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;4001&lt;/td&gt;
         &lt;td&gt;Invalid header parameter&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;The required {parameter} in header parameter is missing =
or invalid.&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;4002&lt;/td&gt;
         &lt;td&gt;Invalid body parameter&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;The required {parameter} in body parameter is missing or=
 invalid.&lt;/td&gt;
        &lt;/tr&gt;
      content:
        application/json:
          schema:
            type: object
            properties:
              result:
                type: object
                properties:
                  errors:
                    type: array
                    items:
                      $ref: "#/components/schemas/Error"
            example:
              result:
                errors:
                  - code: 4001
                    message: Invalid Header Parameter
                    details: &gt;-
                      The required {parameter} in header parameter is missi=
ng or
                      invalid.
    500InternalServerErrorResponse:
      description: |
        __Internal Server Error__

        Possible errors

        &lt;table&gt;
        &lt;tr&gt;
         &lt;th align=3D"left"&gt;Error Code&lt;/th&gt;
         &lt;th align=3D"left"&gt;Error Message&lt;/th&gt;
         &lt;th&gt;&amp;nbsp&amp;nbsp&lt;/th&gt;
         &lt;th&gt;Error Description&lt;/th&gt;
        &lt;/tr&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;10001&lt;/td&gt;
         &lt;td&gt;Host Unavailable&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;The downstream system failed to accept the request.&lt;/=
td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;10002&lt;/td&gt;
         &lt;td&gt;Provider Timeout&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;The downstream system failed to respond within the expec=
ted time periods.&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;10003&lt;/td&gt;
         &lt;td&gt;Technical Error&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;   {Technical Error details} &lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
         &lt;td&gt;10004&lt;/td&gt;
         &lt;td&gt;Unauthorized&lt;/td&gt;
         &lt;td&gt;&lt;/td&gt;
         &lt;td&gt;Not authorized to access Ping Directory.&lt;/td&gt;
        &lt;/tr&gt;
      content:
        application/json:
          schema:
            type: object
            properties:
              result:
                type: object
                properties:
                  errors:
                    type: array
                    items:
                      $ref: "#/components/schemas/Error"
            example:
              result:
                errors:
                  - code: 10001
                    message: Host Unavailable
                    details: The downstream system failed to accept the req=
uest.
  securitySchemes:
    BasicAuth:
      type: http
      scheme: basic
</pre>
</div>
