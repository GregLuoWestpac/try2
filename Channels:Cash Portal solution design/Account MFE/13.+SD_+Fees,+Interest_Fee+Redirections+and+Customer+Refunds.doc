tachments/2182705430/image-2025-11-10_11-13-14.png?version=3D1&amp;modifica=
tionDate=3D1762733594763&amp;api=3Dv2" data-unresolved-comment-count=3D"0" =
data-linked-resource-id=3D"2201218929" data-linked-resource-version=3D"1" d=
ata-linked-resource-type=3D"attachment" data-linked-resource-default-alias=
=3D"image-2025-11-10_11-13-14.png" data-base-url=3D"https://confluence.srv.=
westpac.com.au" data-linked-resource-content-type=3D"image/png" data-linked=
