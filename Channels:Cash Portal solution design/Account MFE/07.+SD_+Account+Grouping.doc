<tbody class=3D"">
<tr class=3D"">
<th style=3D"text-align: left;" class=3D"confluenceTh"><span style=3D"color=
: rgb(0,51,102);">User Story</span></th>
<th style=3D"text-align: left;" class=3D"confluenceTh"><span style=3D"color=
: rgb(0,51,102);"><strong>Title</strong></span></th>
<th style=3D"text-align: left;" class=3D"confluenceTh"><p><span style=3D"co=
lor: rgb(0,51,102);"><span title=3D""><strong><em title=3D"">JIRA</em></str=
