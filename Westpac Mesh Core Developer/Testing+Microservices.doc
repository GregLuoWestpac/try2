urce-id=3D"1409781966" data-linked-resource-version=3D"1" data-linked-resou=
rce-type=3D"attachment" data-linked-resource-default-alias=3D"image2023-6-1=
3_11-25-41.png" data-base-url=3D"https://confluence.srv.westpac.com.au" dat=
a-linked-resource-content-type=3D"image/png" data-linked-resource-container=
-id=3D"1313874132" data-linked-resource-container-version=3D"12" alt=3D"" w=
idth=3D"468" height=3D"477"></span><span class=3D"confluence-embedded-file-=
