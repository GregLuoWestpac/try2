          }
        },
        "headers": {
          "Content-Type": "application/json; charset=3DUTF-8"
        },
        "matchingRules": {
          "body": {
            "$.data.assignments": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data.assignments[*].assignmentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.assignments[*].principal.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.assignments[*].principal.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.assignments[*].role.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.assignments[*].role.permissions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data.assignments[*].role.permissions[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/json(;\\s?charset=3D[\\w\\-]+)?"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "get role details with ID chapterLead",
      "providerStates": [
        {
          "name": "the role id chapterLead exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/inf/bnkng/resrcitm/usraccsprof/meshusrperms/v1/roles/chap=
terLead"
      },
      "response": {
        "body": {
          "data": {
            "id": "chapterLead",
            "name": "Design Chapter Lead",
            "permissions": [
              {
                "description": "Approve that an API contract meets the stan=
dards of design guild and is compliant with what was approved",
                "id": "APPROVE_API_CONTRACT",
                "name": "Approve API Contract"
              }
            ]
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=3DUTF-8"
        },
        "matchingRules": {
          "body": {
            "$.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.permissions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data.permissions[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.permissions[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.permissions[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/json(;\\s?charset=3D[\\w\\-]+)?"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
