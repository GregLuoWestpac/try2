p;api=3Dv2" data-unresolved-comment-count=3D"0" data-linked-resource-id=3D"=
1300588623" data-linked-resource-version=3D"1" data-linked-resource-type=3D=
"attachment" data-linked-resource-default-alias=3D"Picture10.png" data-base=
-url=3D"https://confluence.srv.westpac.com.au" data-linked-resource-content=
