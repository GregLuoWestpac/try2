<pre style=3D"font-size: 12px;">CREATE TABLE application_id_by_customer_id =
(
  customer_id text,
  last_updated_time timestamp,
  application_id text,
  mesh_header frozen&lt;mesh_header&gt;,
  PRIMARY KEY (customer_id, application_id)
  )
  WITH comment =3D 'Q1. Find applications for a given customer id';
   =20
CREATE TABLE application_id_by_staff_id (
  staff_id text,
  last_updated_time timestamp,               =20
  application_id text,
  mesh_header frozen&lt;mesh_header&gt;,
  PRIMARY KEY (staff_id, application_id)
  )
  WITH comment =3D 'Q2. Find applications assigned to a staff id';
  =20
CREATE TABLE application_details_by_application_id (
  application_id text PRIMARY KEY,
  age int,
  is_permanent_resident boolean,
  street text,
  suburb text,
  post_code text,
  phone_numbers set &lt;text&gt;,
  employer_names list &lt;text&gt;,
