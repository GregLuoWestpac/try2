  customer_id  text,
  mesh_header frozen&lt;mesh_header&gt;
  )
  WITH comment =3D 'Q3. Retrieve application details for a given applicatio=
n id';
  =20
CREATE TABLE employment_details (
  application_id text,
  employer_name text,=20
  street text,
  suburb text,
  post_code text,
