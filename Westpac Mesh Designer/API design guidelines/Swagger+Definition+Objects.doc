 plain" style=3D"text-align: left;">: {</code><br><code class=3D"js spaces"=
 style=3D"text-align: left;">&nbsp;&nbsp;&nbsp;&nbsp;</code><code class=3D"=
js string" style=3D"text-align: left;">"errors"</code><code class=3D"js pla=
in" style=3D"text-align: left;">: [</code><br><code class=3D"js spaces" sty=
le=3D"text-align: left;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</code><code c=
lass=3D"js plain" style=3D"text-align: left;">{</code><br><code class=3D"js=
 spaces" style=3D"text-align: left;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&n=
bsp;&nbsp;</code><code class=3D"js string" style=3D"text-align: left;">"cod=
e"</code><code class=3D"js plain" style=3D"text-align: left;">: 0,</code><b=
r><code class=3D"js spaces" style=3D"text-align: left;">&nbsp;&nbsp;&nbsp;&=
nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</code><code class=3D"js string" style=3D"text=
-align: left;">"message"</code><code class=3D"js plain" style=3D"text-align=
: left;">:<span>&nbsp;</span></code><code class=3D"js string" style=3D"text=
-align: left;">"string"</code><code class=3D"js plain" style=3D"text-align:=
 left;">,</code><br><code class=3D"js spaces" style=3D"text-align: left;">&=
nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</code><code class=3D"js str=
ing" style=3D"text-align: left;">"details"</code><code class=3D"js plain" s=
tyle=3D"text-align: left;">:<span>&nbsp;</span></code><code class=3D"js str=
ing" style=3D"text-align: left;">"string"</code><br><code class=3D"js space=
s" style=3D"text-align: left;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</code><=
