sp;&nbsp;&nbsp;"code":&nbsp;"M",</p><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=
&nbsp;&nbsp;=E2=80=9Cdescription=E2=80=9D: =E2=80=9CMale=E2=80=99</p><p>&nb=
sp;&nbsp;&nbsp;&nbsp;},</p><p>&nbsp;&nbsp;&nbsp;&nbsp;"status": {</p><p>&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"code":&nbsp;"A",</p><p>&nbsp;=
 =E2=80=9Cdescription=E2=80=9D: =E2=80=9Cactive</p><p>&nbsp;&nbsp;&nbsp;}</=
p></td>
